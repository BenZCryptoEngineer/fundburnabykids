# --- Credentials: NEVER commit ---
credentials.env
.env
.env.*
# allow the templates
!credentials.env.example
!.env.example

# --- Node / Astro ---
node_modules/
dist/
.astro/
.netlify/
.cache/
.turbo/
.next/

# --- Python (if scripts/ grows one) ---
__pycache__/
*.py[cod]
.venv/
venv/

# --- OS artifacts ---
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# --- Editors ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Claude Code (worktrees are ephemeral; settings.local.json is user-local permissions) ---
.claude/worktrees/
.claude/settings.local.json

# --- Logs and coverage ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
coverage/

# --- Build artifacts ---
*.tsbuildinfo
*.map

# --- Playwright ---
test-results/
playwright-report/

# --- netlify-cli writes a Deno lockfile when bundling Edge Functions runtime ---
deno.lock
