{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": [
    "MCP server configuration for Claude Code operating this repo.",
    "Replace each <<FILL_FROM_CREDENTIALS_ENV>> with the matching value from",
    "`credentials.env` at the repo root. Restart Claude Code after editing.",
    "Do NOT commit filled-in tokens — this file is committed as a template only."
  ],
  "mcpServers": {
    "porkbun": {
      "command": "uvx",
      "args": ["porkbun-mcp", "--get-muddy"],
      "env": {
        "PORKBUN_API_KEY": "<<FILL_FROM_CREDENTIALS_ENV:PORKBUN_API_KEY>>",
        "PORKBUN_SECRET_KEY": "<<FILL_FROM_CREDENTIALS_ENV:PORKBUN_SECRET_KEY>>"
      }
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--access-token",
        "<<FILL_FROM_CREDENTIALS_ENV:SUPABASE_PAT>>"
      ]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<<FILL_FROM_CREDENTIALS_ENV:GITHUB_PAT>>"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:/Projects/fundburnabykids"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    }
  }
}
