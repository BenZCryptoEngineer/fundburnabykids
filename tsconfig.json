{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "allowJs": false,
    "isolatedModules": true
  },
  "include": ["netlify/functions/**/*.ts"],
  "exclude": ["platform", "node_modules", "dist"]
}
