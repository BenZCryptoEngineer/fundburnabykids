# =============================================================================
# Burnaby Kids First — Credentials Template
# =============================================================================
# Copy this file to `credentials.env` (same directory) and fill in real values.
# `credentials.env` is gitignored. NEVER commit real secrets.
#
# Steps referenced below are from docs/FOUNDATION_SETUP.md.
# =============================================================================

# --- Porkbun (domain registrar) — Foundation Step 1 -------------------------
PORKBUN_API_KEY=pk1_REPLACE_ME
PORKBUN_SECRET_KEY=sk1_REPLACE_ME

# --- Canada Post PO Box (CASL physical address) — Step 2 -------------------
MAILING_ADDRESS="PO Box 44021 Burnaby RPO Kensington Sq, BC, V5B 4Y2"

# --- GitHub personal access token — Step 3 ----------------------------------
# Fine-grained PAT with: Contents R/W, Pull requests R/W, Metadata R
GITHUB_PAT=github_pat_REPLACE_ME

# --- Netlify personal access token — Step 4 ---------------------------------
NETLIFY_PAT=REPLACE_ME

# --- Supabase (ca-central-1) — Step 5 ---------------------------------------
SUPABASE_URL=https://REPLACE_ME.supabase.co
SUPABASE_ANON_KEY=eyJ_REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=eyJ_REPLACE_ME           # SECRET — backend only
SUPABASE_PAT=sbp_REPLACE_ME
SUPABASE_DB_PASSWORD=REPLACE_ME

# --- Buttondown (newsletter list — fortnightly updates) — Step 6 -----------
# Used ONLY for the newsletter list. Confirmation emails go via Resend.
BUTTONDOWN_API_KEY=REPLACE_ME
BUTTONDOWN_DKIM_RECORD=REPLACE_ME
BUTTONDOWN_SPF_INCLUDE=_spf.buttondown.email
BUTTONDOWN_DMARC_RECORD=v=DMARC1; p=quarantine; rua=mailto:dmarc@fundburnabykids.ca

# --- Resend (transactional — signature confirmation + admin alerts) ---------
# NEW (added in Phase 4A). FOUNDATION_SETUP.md needs a Step 6.5 amendment.
# Sign up at https://resend.com (free tier 3K/mo is enough for this campaign).
# Verify the fundburnabykids.ca domain — Resend gives you DKIM records.
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM="Fund Burnaby Kids <campaign@fundburnabykids.ca>"
# Optional documentation fields (not read by code — for audit/backup only).
# DKIM record value Resend gives you (the long p=MIGfMA... public key).
RESEND_DKIM_RECORD=REPLACE_ME
# SPF include — Resend uses Amazon SES under the hood, lives on send subdomain.
RESEND_SPF_INCLUDE=amazonses.com

# --- ImprovMX (inbound email forwarding) — Step 7 --------------------------
# API key is optional; MX records are fixed values.
IMPROVMX_API_KEY=REPLACE_ME_OR_LEAVE_BLANK
IMPROVMX_MX_1=mx1.improvmx.com
IMPROVMX_MX_2=mx2.improvmx.com

# --- Anthropic API key — Step 8 ---------------------------------------------
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# --- Cloudflare Turnstile (bot prevention on signature form) ---------------
# NEW (added in Phase 4A). FOUNDATION_SETUP.md needs a Step 5.5 amendment.
# Sign up at https://dash.cloudflare.com → Turnstile → Add site.
# Site = "fundburnabykids.ca", widget mode = "Managed".
# Site key is public (embedded in HTML). Secret key stays server-side.
TURNSTILE_SITE_KEY=0x4REPLACE_ME
TURNSTILE_SECRET=0x4REPLACE_ME
PUBLIC_TURNSTILE_SITE_KEY=0x4REPLACE_ME            # mirrored for Astro frontend

# --- Operational ------------------------------------------------------------
# Where the on-signature function sends PAC-pending notifications.
ADMIN_NOTIFICATION_EMAIL=ben@fundburnabykids.ca

# Site URL used in confirmation email links.
SITE_URL=https://fundburnabykids.ca

# --- Frontend (public, safe to embed in build) -----------------------------
PUBLIC_SUPABASE_URL=https://REPLACE_ME.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ_REPLACE_ME
