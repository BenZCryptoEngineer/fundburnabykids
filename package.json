{
  "name": "burnabykidsfirst-coalition",
  "private": true,
  "version": "0.0.1",
  "description": "Workspace root — Netlify Functions + Astro frontend for the Burnaby Kids First coalition platform.",
  "type": "module",
  "scripts": {
    "typecheck:functions": "tsc -p tsconfig.json --noEmit",
    "typecheck:platform": "cd platform && npm run check",
    "typecheck": "npm run typecheck:functions && npm run typecheck:platform",
    "test:e2e": "playwright test --config=tests/playwright.config.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@netlify/functions": "^2.8.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.0.0",
    "netlify-cli": "^25.6.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
