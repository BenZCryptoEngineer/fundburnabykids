---
// MlaInbox — bilingual rendering of an MLA's constituent-letter feed.
// Used by /mla/[id] and /zh/mla/[id]. Each row deep-links to the
// individual letter page at /letters/<token>.
//
// Hand-deliverable: print stylesheet collapses chrome so the page
// renders cleanly to PDF for delivery to MLA constituency offices.

import I18nText from '~/components/I18nText.astro';
import { formatDate, t, localizedUrl } from '~/lib/i18n';
import type { Lang } from '~/lib/i18n';
import type { PublicLetter } from '~/lib/supabase';

type Mla = {
  id: string;
  name: string;
  riding: { en: string; zh: string };
  riding_id: string | null;
};

interface Props {
  mla: Mla;
  letters: PublicLetter[];
  total: number;
  page: number;
  perPage: number;
  lang: Lang;
}

const { mla, letters, total, page, perPage, lang } = Astro.props;
const ridingName = t(mla.riding, lang);
const totalPages = Math.max(1, Math.ceil(total / perPage));
const letterPathBase = lang === 'zh' ? '/zh/letters/' : '/letters/';
// Trailing slash matches the trailingSlash:'always' invariant — without
// it, pagination links like /mla/kang?page=2 fire a 301 hop before
// resolving (also costs an extra Netlify function invocation per click).
const mlaPathBase = lang === 'zh' ? `/zh/mla/${mla.id}/` : `/mla/${mla.id}/`;
---

<section class="mla-inbox">
  <header class="mla-inbox__header">
    <p class="mla-inbox__kicker sans">
      <I18nText en="Constituent letters" zh="选区选民来信" lang={lang} />
    </p>
    <h1>
      <I18nText en="MLA " zh="MLA " lang={lang} />
      {mla.name} — {ridingName}
    </h1>
    <p class="mla-inbox__count sans">
      {lang === 'zh' ? (
        <><strong>{total}</strong> 位 {ridingName} 选区选民已写信：</>
      ) : (
        <><strong>{total}</strong> {total === 1 ? 'constituent has' : 'constituents have'} written from {ridingName}:</>
      )}
    </p>
  </header>

  {letters.length === 0 ? (
    <p class="mla-inbox__empty muted">
      <I18nText
        en="No confirmed letters from this riding yet. Be the first."
        zh="此选区还没有已确认来信。"
        lang={lang}
      />
    </p>
  ) : (
    <ol class="mla-inbox__list">
      {letters.map((l) => (
        <li class="mla-inbox__row">
          <span class="mla-inbox__bullet" aria-hidden="true">▸</span>
          <a class="mla-inbox__link" href={`${letterPathBase}${encodeURIComponent(l.letter_token)}/`}>
            <span class="mla-inbox__signer sans">
              <strong>{l.first_name} {l.last_initial}.</strong>, {l.school}
            </span>
            <time class="mla-inbox__date" datetime={l.signed_at}>
              {formatDate(l.signed_at, lang)}
            </time>
          </a>
        </li>
      ))}
    </ol>
  )}

  {totalPages > 1 && (
    <nav class="mla-inbox__pager sans" aria-label={lang === 'zh' ? '分页' : 'Pagination'}>
      {page > 1 && (
        <a href={`${mlaPathBase}?page=${page - 1}`}>
          ← <I18nText en="Newer" zh="较新" lang={lang} />
        </a>
      )}
      <span class="mla-inbox__pager-info muted">
        {lang === 'zh' ? `第 ${page} / ${totalPages} 页` : `Page ${page} of ${totalPages}`}
      </span>
      {page < totalPages && (
        <a href={`${mlaPathBase}?page=${page + 1}`}>
          <I18nText en="Older" zh="较旧" lang={lang} /> →
        </a>
      )}
    </nav>
  )}

  <p class="mla-inbox__back sans">
    <a href={localizedUrl('/', lang)}>
      ← <I18nText en="Back to campaign" zh="返回主页" lang={lang} />
    </a>
  </p>
</section>

<style>
  .mla-inbox {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 32px;
    box-shadow: var(--shadow-sm);
    max-width: 720px;
  }
  .mla-inbox__header {
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 20px;
  }
  .mla-inbox__kicker {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 6px;
  }
  .mla-inbox__header h1 {
    font-size: 24px;
    margin: 0 0 8px;
    color: var(--ink);
    line-height: 1.3;
  }
  .mla-inbox__count {
    font-size: 14px;
    color: var(--ink-soft);
    margin: 0;
  }
  .mla-inbox__count strong { color: var(--accent); font-size: 18px; }
  .mla-inbox__empty {
    font-size: 15px;
    padding: 24px 0;
    color: var(--muted);
  }
  .mla-inbox__list {
    list-style: none;
    padding: 0;
    margin: 0 0 20px;
  }
  .mla-inbox__row {
    display: flex;
    gap: 8px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line-soft);
  }
  .mla-inbox__row:last-child { border-bottom: none; }
  .mla-inbox__bullet {
    color: var(--accent);
    font-size: 14px;
    flex-shrink: 0;
    line-height: 1.5;
  }
  .mla-inbox__link {
    flex: 1;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }
  .mla-inbox__link:hover .mla-inbox__signer { color: var(--accent); }
  .mla-inbox__signer {
    font-size: 15px;
    line-height: 1.4;
  }
  .mla-inbox__date {
    font-size: 12px;
    color: var(--muted);
    flex-shrink: 0;
  }
  .mla-inbox__pager {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
    font-size: 14px;
  }
  .mla-inbox__pager a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }
  .mla-inbox__pager-info {
    font-size: 13px;
  }
  .mla-inbox__back {
    margin: 24px 0 0;
    font-size: 14px;
  }
  .mla-inbox__back a {
    color: var(--accent);
    text-decoration: none;
  }
  .muted { color: var(--muted); }
  @media print {
    .mla-inbox__pager,
    .mla-inbox__back { display: none; }
    .mla-inbox {
      border: none;
      box-shadow: none;
      padding: 0;
      max-width: 100%;
    }
    .mla-inbox__row { break-inside: avoid; }
  }
</style>
