---
// Inline-SVG icon component using Lucide (https://lucide.dev) glyphs.
// Lucide is a fork of Feather, MIT-licensed, ~1500 stroke icons. Used
// here as the canonical icon set so every UI affordance reads in the
// same visual language (replaces a previous mix of unicode emoji like
// 👪, 🏛️, 🤔 that looked inconsistent across OS-rendered emoji fonts).
//
// Usage:
//   <Icon name="school" />
//   <Icon name="users" size={28} class="some-class" />
//
// Color: SVGs use `stroke="currentColor"`, so set it via CSS `color`
// on the element or any ancestor. Default size 24 matches Lucide's
// canonical viewBox; override per-call if a tighter or larger glyph
// is needed (e.g. heroes vs. inline labels).
//
// Adding a new icon:
//   1. Find the SVG source on https://lucide.dev (copy the inner
//      <path>/<circle>/<line> elements only — not the outer <svg>).
//   2. Add a new `case` to the switch below mapping the lucide name
//      to its inner markup.
//   3. The wrapper <svg> sets stroke + viewBox + a11y attributes for
//      you, so each `case` only needs the geometry.

interface Props {
  /** Lucide icon name. See switch statement below for the supported set. */
  name: string;
  /** Pixel size for both width + height. Defaults to 24 (Lucide's native viewBox). */
  size?: number;
  /** Stroke width. Defaults to 1.75 — slightly lighter than Lucide's
      default 2, reads as more refined at the smaller sizes used in our UI. */
  strokeWidth?: number;
  /** Optional CSS class on the <svg>. */
  class?: string;
}

const { name, size = 24, strokeWidth = 1.75, class: className } = Astro.props;

// Lucide source: each case returns ONLY the inner SVG geometry.
// The outer <svg> wrapper is below and adds viewBox/stroke/a11y.
function lucidePaths(n: string): string {
  switch (n) {
    case 'help-circle':
      return '<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/>';
    case 'users':
      return '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>';
    case 'user':
      return '<path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>';
    case 'school':
      return '<path d="M14 22v-4a2 2 0 1 0-4 0v4"/><path d="m18 10 4 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-8l4-2"/><path d="M18 5v17"/><path d="m4 6 8-4 8 4"/><path d="M6 5v17"/><circle cx="12" cy="9" r="2"/>';
    case 'landmark':
      return '<line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/>';
    case 'briefcase':
      return '<rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>';
    case 'wallet':
      return '<path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1"/><path d="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"/>';
    case 'search':
      return '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>';
    case 'vote':
      return '<path d="m9 12 2 2 4-4"/><path d="M5 7c0-1.1.9-2 2-2h10a2 2 0 0 1 2 2v12H5V7Z"/><path d="M22 19H2"/>';
    case 'home':
      return '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>';
    case 'mail':
      return '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>';
    case 'send':
      return '<path d="M22 2 11 13"/><path d="M22 2 15 22l-4-9-9-4Z"/>';
    case 'baby':
      return '<path d="M9 12h.01"/><path d="M15 12h.01"/><path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/><path d="M19 6.3a9 9 0 0 1 1.8 3.9 2 2 0 0 1 0 3.6 9 9 0 0 1-17.6 0 2 2 0 0 1 0-3.6A9 9 0 0 1 12 3c2 0 3.5 1.1 3.5 2.5s-.9 2.5-2 2.5c-.8 0-1.5-.4-1.5-1"/>';
    case 'map':
      return '<polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" x2="9" y1="3" y2="18"/><line x1="15" x2="15" y1="6" y2="21"/>';
    case 'map-pinned':
      return '<path d="M18 8c0 4.5-6 9-6 9s-6-4.5-6-9a6 6 0 0 1 12 0Z"/><circle cx="12" cy="8" r="2"/><path d="M8.835 14H5a1 1 0 0 0-.9.7l-2 6c-.1.1-.1.2-.1.3 0 .6.4 1 1 1h18c.6 0 1-.4 1-1 0-.1 0-.2-.1-.3l-2-6a1 1 0 0 0-.9-.7h-3.835"/>';
    case 'check-circle':
      return '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>';
    case 'badge-check':
      return '<path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/>';
    case 'pencil':
      return '<path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/>';
    case 'target':
      return '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>';
    case 'calendar':
      return '<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>';
    case 'alert-triangle':
      return '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>';
    case 'mail-open':
      return '<path d="M21.2 8.4c.5.38.8.97.8 1.6v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V10a2 2 0 0 1 .8-1.6l8-6a2 2 0 0 1 2.4 0l8 6Z"/><path d="m22 10-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 10"/>';
    case 'clock':
      return '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>';
    case 'megaphone':
      return '<path d="m3 11 18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/>';
    case 'building':
      return '<rect width="16" height="20" x="4" y="2" rx="2" ry="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/>';
    case 'arrow-right':
      return '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>';
    case 'chevron-right':
      return '<path d="m9 18 6-6-6-6"/>';
    case 'info':
      return '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>';
    default:
      // Fallback: render a tiny placeholder square so layout doesn't
      // collapse silently. Caller should add an entry to the switch.
      return '<rect x="3" y="3" width="18" height="18" rx="2"/>';
  }
}
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  class={className}
  set:html={lucidePaths(name)}
/>
