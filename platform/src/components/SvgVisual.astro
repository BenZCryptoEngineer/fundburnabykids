---
// Inline an SVG visualization from src/data/visuals/{key}.{lang}.svg.
// Reads the file at build time via Vite's `?raw` glob import, so the markup
// is bundled alongside the component (works in both static SSG and SSR
// Netlify-Function output). Inlining lets us:
//   - style internals via CSS if needed
//   - avoid an extra HTTP request
//   - keep EN and ZH variants strictly separate per VISUAL_DESIGN policy
//
// Earlier revisions used readFileSync(import.meta.url + ...) which broke
// when bundled into the SSR worker (path resolved to .netlify/build/chunks
// instead of the project root). See CLAUDE.md "Vite native imports" note.
//
// Usage:
//   <SvgVisual visual="cascade" lang={lang} />
//   <SvgVisual visual="money" lang={lang} caption="Where the money lives" />

import I18nText from '~/components/I18nText.astro';
import type { Lang } from '~/lib/i18n';

interface Props {
  visual: 'cascade' | 'money' | 'scale' | 'responsibility';
  lang: Lang;
  /** optional kicker label above the visual */
  kicker?: string;
  /** optional headline above the visual */
  headline?: string;
  /** optional take-away below the visual */
  takeaway?: string;
}

const { visual, lang, kicker, headline, takeaway } = Astro.props;

// Eager raw glob: Vite resolves these at build, inlining SVG markup into
// the bundle. Keys are paths relative to this file.
const svgModules = import.meta.glob<string>('../data/visuals/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
});

const svgKey = `../data/visuals/${visual}.${lang}.svg`;
const svgContent =
  svgModules[svgKey] ?? `<!-- SVG ${visual}.${lang} not found -->`;

// Unique id so multiple SvgVisual instances on a page each get their own dialog.
const dialogId = `lightbox-${visual}-${lang}-${Math.random().toString(36).slice(2, 8)}`;
const zoomLabel = lang === 'zh' ? '放大查看' : 'Open larger view';
const closeLabel = lang === 'zh' ? '关闭' : 'Close';
---

<figure class="svg-visual">
  {kicker && <p class="svg-visual__kicker sans">{kicker}</p>}
  {headline && <h4 class="svg-visual__headline sans">{headline}</h4>}
  <button
    type="button"
    class="svg-visual__zoom"
    data-zoom-target={dialogId}
    aria-label={headline ? `${zoomLabel}: ${headline}` : zoomLabel}
  >
    <span class="svg-visual__media" set:html={svgContent} />
    <span class="svg-visual__zoom-hint sans" aria-hidden="true">
      <I18nText en="Tap to enlarge" zh="点击放大" lang={lang} />
    </span>
  </button>
  {takeaway && (
    <figcaption class="svg-visual__takeaway">
      <span class="sans muted">
        <I18nText en="Take-away: " zh="结论：" lang={lang} />
      </span>
      {takeaway}
    </figcaption>
  )}
</figure>

<dialog class="svg-lightbox" id={dialogId} aria-label={headline ?? zoomLabel}>
  <button
    type="button"
    class="svg-lightbox__close"
    data-zoom-close
    aria-label={closeLabel}
  >×</button>
  <p class="svg-lightbox__hint sans" aria-hidden="true">
    <I18nText
      en="Pinch or scroll to zoom · drag to pan"
      zh="双指缩放或滚轮缩放 · 拖动平移"
      lang={lang}
    />
  </p>
  <div class="svg-lightbox__viewport">
    <div class="svg-lightbox__media" set:html={svgContent} />
  </div>
  <div
    class="svg-lightbox__controls"
    role="toolbar"
    aria-label={lang === 'zh' ? '缩放控制' : 'Zoom controls'}
  >
    <button
      type="button"
      class="svg-lightbox__btn"
      data-zoom-out
      aria-label={lang === 'zh' ? '缩小' : 'Zoom out'}
    >−</button>
    <button
      type="button"
      class="svg-lightbox__btn"
      data-zoom-reset
      aria-label={lang === 'zh' ? '重置缩放' : 'Reset zoom'}
    >⟲</button>
    <button
      type="button"
      class="svg-lightbox__btn"
      data-zoom-in
      aria-label={lang === 'zh' ? '放大' : 'Zoom in'}
    >+</button>
  </div>
</dialog>

<script>
  // Single delegated handler — Astro hoists & dedupes this across instances.
  // The lightbox uses @panzoom/panzoom (~3KB gzip) for pinch-to-zoom on
  // touch devices, mouse-wheel zoom on desktop, and drag-to-pan on both.
  // The +/-/reset toolbar exists for keyboard a11y and as a discoverable
  // affordance for users who don't recognize the gesture vocabulary.
  import Panzoom from '@panzoom/panzoom';

  type DialogWithPz = HTMLDialogElement & {
    __pz?: ReturnType<typeof Panzoom>;
    __pzWheelBound?: boolean;
  };

  if (!(window as any).__svgLightboxBound) {
    (window as any).__svgLightboxBound = true;

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;

      // Open lightbox + lazy-init panzoom on first open of each dialog.
      const opener = target.closest<HTMLElement>('[data-zoom-target]');
      if (opener) {
        const id = opener.dataset.zoomTarget;
        if (!id) return;
        const dlg = document.getElementById(id) as DialogWithPz | null;
        if (!dlg || typeof dlg.showModal !== 'function') return;

        dlg.showModal();

        // Bind panzoom to the .svg-lightbox__media wrapper rather than
        // the inner SVG. The wrapper is 100% × 100% of the viewport so
        // the user's finger drag registers anywhere in the lightbox
        // content area, not just on the (narrow, ~90px tall in 1x view)
        // SVG element. Without this, on a phone the user has to land
        // their drag exactly on the visible SVG to pan, which felt
        // broken — touches in the empty space around the SVG fell
        // through to the dialog and were ignored. CSS transform on the
        // wrapper still moves the inline SVG inside.
        const media = dlg.querySelector<HTMLElement>('.svg-lightbox__media');
        if (media && !dlg.__pz) {
          dlg.__pz = Panzoom(media, {
            maxScale: 5,
            minScale: 1,
            startScale: 1,
            step: 0.3,
            // No `contain` option — neither 'inside' nor 'outside' fits:
            //   - 'outside' scales the wrapper up to fill parent height,
            //     making narrow horizontal timelines display as
            //     already-zoomed-in on initial open.
            //   - 'inside' refuses to let zoom-in exceed parent bounds,
            //     so the +/pinch buttons appear broken.
            // Without containment, panzoom lets the user freely zoom
            // up to maxScale and drag-pan anywhere. The trade-off is
            // the wrapper can be panned off-screen — the reset (⟲)
            // button and lightbox close-and-reopen both bring it back.
          });
          // Desktop: scroll wheel zooms (instead of scrolling the page).
          const container = dlg.querySelector<HTMLElement>('.svg-lightbox__viewport');
          if (container && !dlg.__pzWheelBound) {
            container.addEventListener(
              'wheel',
              (ev) => {
                ev.preventDefault();
                dlg.__pz?.zoomWithWheel(ev as WheelEvent);
              },
              { passive: false }
            );
            dlg.__pzWheelBound = true;
          }
        } else if (dlg.__pz) {
          // Re-open: reset zoom + pan to 1x center.
          dlg.__pz.reset({ animate: false });
        }
        return;
      }

      // Zoom toolbar buttons.
      const dlgFrom = (el: HTMLElement | null) =>
        el?.closest('dialog') as DialogWithPz | null;
      const zoomIn = target.closest<HTMLElement>('[data-zoom-in]');
      if (zoomIn) { dlgFrom(zoomIn)?.__pz?.zoomIn(); return; }
      const zoomOut = target.closest<HTMLElement>('[data-zoom-out]');
      if (zoomOut) { dlgFrom(zoomOut)?.__pz?.zoomOut(); return; }
      const zoomReset = target.closest<HTMLElement>('[data-zoom-reset]');
      if (zoomReset) { dlgFrom(zoomReset)?.__pz?.reset(); return; }

      // Close.
      const closer = target.closest<HTMLElement>('[data-zoom-close]');
      if (closer) {
        const dlg = closer.closest('dialog') as HTMLDialogElement | null;
        dlg?.close();
        return;
      }

      // Backdrop click — only when the click landed on the dialog element
      // itself (i.e. outside the panzoom viewport). Clicks inside the
      // viewport are consumed by panzoom's drag handler.
      if (target.tagName === 'DIALOG' && target.classList.contains('svg-lightbox')) {
        (target as HTMLDialogElement).close();
      }
    });
  }
</script>

<style>
  .svg-visual {
    margin: 0;
    padding: 24px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
  }
  .svg-visual__kicker {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 6px;
  }
  .svg-visual__headline {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 16px;
    color: var(--ink);
    line-height: 1.4;
  }
  .svg-visual__media {
    display: flex;
    justify-content: center;
    margin: 8px 0 16px;
  }
  .svg-visual__media :global(svg) {
    max-width: 100%;
    height: auto;
  }
  .svg-visual__zoom {
    display: block;
    width: 100%;
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-md);
    padding: 0;
    margin: 0;
    cursor: zoom-in;
    font: inherit;
    color: inherit;
    text-align: center;
    transition: border-color 0.15s, background 0.15s;
  }
  .svg-visual__zoom:hover,
  .svg-visual__zoom:focus-visible {
    border-color: var(--line);
    background: var(--cream);
  }
  .svg-visual__zoom:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .svg-visual__zoom-hint {
    display: inline-block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    padding: 4px 10px;
    margin: 0 0 8px;
    opacity: 1;
    border: 1px solid transparent;
    border-radius: var(--radius);
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .svg-visual__zoom-hint::before {
    content: "⊕ ";
    margin-right: 2px;
    font-weight: 700;
  }
  .svg-visual__zoom:hover .svg-visual__zoom-hint,
  .svg-visual__zoom:focus-visible .svg-visual__zoom-hint {
    color: var(--accent);
    border-color: var(--accent);
  }
  /* Touch devices have no :hover state, so the button affordance has to
     ship in the default style. On hover-capable wide viewports we keep
     the subtler look so the SVG visualization stays the visual focus.
     `(hover: none)` covers real phones; `(max-width: 560px)` covers
     desktop browsers resized narrow (and the preview tool's mobile
     viewport, which does not emulate `hover: none`). Either condition
     promotes the hint to a full pill button. */
  @media (hover: none), (max-width: 560px) {
    .svg-visual__zoom-hint {
      color: var(--accent);
      border-color: var(--line);
      background: var(--cream);
      font-size: 12px;
      padding: 7px 14px;
    }
  }
  /* Press feedback (touch tap, mouse click, keyboard Enter) — confirms
     the user that the tap registered before the dialog opens. */
  .svg-visual__zoom:active .svg-visual__zoom-hint {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }
  .svg-visual__takeaway {
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0;
    padding-top: 12px;
    border-top: 1px solid var(--line);
  }
  .muted { color: var(--muted); }

  /* Lightbox dialog — fullscreen-ish modal with panzoom-driven SVG. */
  .svg-lightbox {
    width: 90vw;
    max-width: 1200px;
    height: 85vh;
    max-height: 90vh;
    padding: 0;
    border: none;
    border-radius: var(--radius-lg);
    background: var(--paper);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    position: relative;
  }
  .svg-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.9);
  }
  .svg-lightbox__close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: var(--paper);
    color: var(--ink);
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
  .svg-lightbox__close:hover { background: var(--cream); color: var(--accent); }
  .svg-lightbox__close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Hint pill at the top — tells the user how to zoom/pan. */
  .svg-lightbox__hint {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 11px;
    color: var(--muted);
    background: var(--paper);
    padding: 4px 12px;
    border-radius: 999px;
    border: 1px solid var(--line);
    margin: 0;
    pointer-events: none;
    white-space: nowrap;
    max-width: calc(100% - 120px); /* leave room for close button */
    overflow: hidden;
    text-overflow: ellipsis;
    z-index: 1;
  }

  /* Viewport contains the panzoomed SVG. overflow:hidden is what
     keeps zoomed-out SVG from spilling into the controls / hint. */
  .svg-lightbox__viewport {
    width: 100%;
    height: 100%;
    padding: 56px 24px 80px; /* top: hint, bottom: controls */
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    overflow: hidden;
    /* touch-action: none lets panzoom fully handle gestures without
       the browser hijacking pinch as page-zoom or drag as scroll. */
    touch-action: none;
    cursor: grab;
  }
  .svg-lightbox__viewport:active { cursor: grabbing; }

  .svg-lightbox__media {
    /* Must take the viewport's full size so the inner SVG has a parent
       to size against. Without explicit width/height, the flex container
       collapses and the SVG (sized via max-width:100% of media) goes to
       zero. */
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .svg-lightbox__media :global(svg) {
    width: 100%;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    display: block;
  }

  /* Zoom toolbar at the bottom. 44×44 buttons meet WCAG 2.1 AA touch
     target size; visible in mid- and high-contrast color schemes. */
  .svg-lightbox__controls {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 4px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 4px;
    box-shadow: var(--shadow-sm);
    z-index: 2;
  }
  .svg-lightbox__btn {
    width: 44px;
    height: 44px;
    border-radius: var(--radius);
    border: 1px solid transparent;
    background: transparent;
    color: var(--ink);
    font-size: 20px;
    font-weight: 600;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .svg-lightbox__btn:hover {
    background: var(--cream);
    border-color: var(--line);
    color: var(--accent);
  }
  .svg-lightbox__btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .svg-lightbox__btn:active {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  /* Mobile fullscreen — phones get the entire viewport since narrow
     screens make a centered modal feel cramped. */
  @media (max-width: 560px) {
    .svg-lightbox {
      width: 100vw;
      max-width: 100vw;
      height: 100vh;
      max-height: 100vh;
      border-radius: 0;
      margin: 0;
    }
    .svg-lightbox__viewport {
      padding: 60px 12px 80px;
    }
    .svg-lightbox__hint {
      top: 14px;
      font-size: 10px;
      padding: 3px 10px;
    }
    .svg-lightbox__controls {
      bottom: 20px;
    }
  }
</style>
