---
// Recent verified signatories — calm card row with seamless horizontal
// marquee on desktop; vertical stack on mobile.
//
// Per UX research + privacy policy: first name + last initial + school
// only (neighbourhood + signed_at are public-record context but the
// neighbourhood was visually redundant when school name == neighbourhood
// name, e.g. "Capitol Hill · Capitol Hill"). Card shows: bold accent
// name + muted meta line ("School · 2h ago").
//
// CSS-scoping note. Astro auto-scopes <style> blocks via the
// `data-astro-cid-…` attribute on every emitted element. Our JS
// poller re-renders the track via innerHTML with raw string
// templates — those strings cannot inject the CID (it changes per
// build), which means scoped rules silently stop matching after the
// first poll. We use `<style is:global>` here and prefix every class
// with `signatories-` / `sig-card-` so name collisions can't happen.
// Tradeoff accepted: this single component now contributes a few
// global rules instead of paying the bug-of-the-week tax forever.

import I18nText from '~/components/I18nText.astro';
import type { Lang } from '~/lib/i18n';

interface Props {
  lang: Lang;
  /** How many to show in the marquee; default 20 (per UX research:
      'most recent 20' is a stronger recency-bias signal than 'all 80'
      and the visible marquee duplication is less noticeable). */
  limit?: number;
}

const { lang, limit = 20 } = Astro.props;

const url = import.meta.env.PUBLIC_SUPABASE_URL;
const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

type Sig = {
  first_name: string;
  last_initial: string;
  school: string;
  neighbourhood: string;
  signed_at: string;
};

let initial: Sig[] = [];
let totalCount = 0;
if (url && key) {
  try {
    // `Prefer: count=exact` causes PostgREST to include the total row
    // count in the Content-Range response header (format: "0-19/123").
    // We read the `/total` portion to display "X total signatures"
    // alongside the 20-item recency window.
    const res = await fetch(
      `${url}/rest/v1/public_signatures?select=first_name,last_initial,school,neighbourhood,signed_at&order=signed_at.desc&limit=${limit}`,
      {
        headers: {
          apikey: key,
          Authorization: `Bearer ${key}`,
          Prefer: 'count=exact',
        },
      }
    );
    if (res.ok) {
      initial = await res.json();
      const range = res.headers.get('content-range');
      const after = range?.split('/')[1];
      const parsed = after ? parseInt(after, 10) : NaN;
      if (Number.isFinite(parsed)) totalCount = parsed;
    }
  } catch {
    /* keep empty */
  }
}

// Sparse-state floor: per UX research, <6 unique items shouldn't
// marquee — a 3-pill loop visibly resets every few seconds and reads
// as broken. Below this count we render a static centred row.
const MARQUEE_FLOOR = 6;
const animate = initial.length >= MARQUEE_FLOOR;
---

<div class="signatories"
     data-supabase-url={url}
     data-supabase-key={key}
     data-poll-ms="60000"
     data-limit={limit}
     data-lang={lang}
     data-animate={animate ? 'true' : 'false'}
     data-empty-text={lang === 'zh' ? '成为第一位签名者 →' : 'Be the first to sign →'}>
  <p class="signatories-caption sans">
    <span class="signatories-caption__primary">
      <I18nText
        en={`Showing ${limit} most recent`}
        zh={`显示最近 ${limit} 个`}
        lang={lang}
      />
      {totalCount > 0 && (
        <>
          {' · '}
          <span class="signatories-caption__total" data-signatories-total>
            <I18nText
              en={`${totalCount} total verified signatures`}
              zh={`共 ${totalCount} 个已验证签名`}
              lang={lang}
            />
          </span>
        </>
      )}
    </span>
    <button
      type="button"
      class="signatories-view-all sans"
      data-view-all
      aria-haspopup="dialog"
      aria-controls="signatories-modal"
    >
      <I18nText en="View all →" zh="查看全部 →" lang={lang} />
    </button>
  </p>

  <div class="signatories-flow">
    {initial.length === 0 ? (
      <p class="signatories-empty" data-signatories-flow>
        <I18nText
          en="Be the first to sign →"
          zh="成为第一位签名者 →"
          lang={lang}
        />
      </p>
    ) : (
      <div
        class={`signatories-track${animate ? ' signatories-track--animated' : ''}`}
        data-signatories-flow
        aria-label={lang === 'zh' ? '最近确认的签名' : 'Recent confirmed signatures'}
      >
        {(animate ? [...initial, ...initial] : initial).map((s, i) => (
          <article
            class="sig-card"
            aria-hidden={animate && i >= initial.length ? 'true' : undefined}
          >
            <p class="sig-card__name sans">{s.first_name} {s.last_initial}.</p>
            <p class="sig-card__meta sans">
              <span class="sig-card__school">{s.school}</span>
              <span class="sig-card__sep" aria-hidden="true"> · </span>
              <time class="sig-card__time" datetime={s.signed_at}>—</time>
            </p>
          </article>
        ))}
      </div>
    )}
  </div>
</div>

<dialog class="signatories-modal" id="signatories-modal" aria-labelledby="signatories-modal-title">
  <header class="signatories-modal__header">
    <h2 id="signatories-modal-title" class="sans">
      <I18nText en="All confirmed signatures" zh="全部确认签名" lang={lang} />
    </h2>
    <button
      type="button"
      class="signatories-modal__close"
      data-close-signatories
      aria-label={lang === 'zh' ? '关闭' : 'Close'}
    >×</button>
  </header>
  <div class="signatories-modal__search">
    <input
      type="search"
      class="signatories-modal__input sans"
      data-signatories-search
      placeholder={lang === 'zh' ? '搜索名字或学校…' : 'Search name or school…'}
      autocomplete="off"
    />
    {/* Neighbourhood filter — populated client-side once data loads.
        Per UX research, proximity-based social proof (Capitol Hill
        parents seeing 8 Capitol Hill names) is stronger than the
        diffuse all-neighbourhoods view. */}
    <select
      class="signatories-modal__select sans"
      data-signatories-neighbourhood
      aria-label={lang === 'zh' ? '按街区筛选' : 'Filter by neighbourhood'}
    >
      <option value="">{lang === 'zh' ? '全部街区' : 'All neighbourhoods'}</option>
    </select>
    <p class="signatories-modal__count sans muted" data-signatories-count>—</p>
  </div>
  <div class="signatories-modal__list-wrap">
    <ol class="signatories-modal__list" data-signatories-list role="list"></ol>
    <p class="signatories-modal__empty sans muted" data-signatories-no-match hidden>
      <I18nText
        en="No signatures match your search."
        zh="没有符合搜索的签名。"
        lang={lang}
      />
    </p>
    <p class="signatories-modal__loading sans muted" data-signatories-loading>
      <I18nText en="Loading…" zh="加载中…" lang={lang} />
    </p>
  </div>
</dialog>

<script>
  // Format an ISO timestamp as a short relative time ("just now",
  // "5m ago", "2h ago", "3d ago"), or a date stamp past 7 days.
  // Bilingual via Intl.RelativeTimeFormat.
  function formatRelative(isoLike: string, lang: 'en' | 'zh'): string {
    const then = new Date(isoLike).getTime();
    if (!Number.isFinite(then)) return '';
    const now = Date.now();
    const diffSec = Math.round((then - now) / 1000); // negative = past
    const absSec = Math.abs(diffSec);
    const locale = lang === 'zh' ? 'zh-CN' : 'en-CA';
    const rtf = new Intl.RelativeTimeFormat(locale, { numeric: 'auto', style: 'narrow' });
    if (absSec < 60) return lang === 'zh' ? '刚刚' : 'just now';
    if (absSec < 3600) return rtf.format(Math.round(diffSec / 60), 'minute');
    if (absSec < 86400) return rtf.format(Math.round(diffSec / 3600), 'hour');
    if (absSec < 86400 * 7) return rtf.format(Math.round(diffSec / 86400), 'day');
    // Past a week, show absolute short date.
    return new Intl.DateTimeFormat(locale, { month: 'short', day: 'numeric' })
      .format(new Date(isoLike));
  }

  function paintTimes(scope: ParentNode, lang: 'en' | 'zh') {
    scope.querySelectorAll<HTMLTimeElement>('time.sig-card__time').forEach((el) => {
      const iso = el.getAttribute('datetime');
      if (!iso) return;
      el.textContent = formatRelative(iso, lang);
    });
  }

  document.querySelectorAll<HTMLElement>('.signatories').forEach((el) => {
    const url = el.dataset.supabaseUrl;
    const key = el.dataset.supabaseKey;
    const pollMs = parseInt(el.dataset.pollMs || '60000', 10);
    const limit = parseInt(el.dataset.limit || '60', 10);
    const lang = (el.dataset.lang === 'zh' ? 'zh' : 'en') as 'en' | 'zh';
    if (!url || !key) {
      // Still paint times for the SSR-rendered cards (they'll
      // otherwise show "—" forever).
      paintTimes(el, lang);
      return;
    }

    // Paint the SSR-rendered timestamps once on hydration.
    paintTimes(el, lang);

    const flowOuter = el.querySelector<HTMLElement>('.signatories-flow');
    if (!flowOuter) return;

    function escapeHtml(s: string) {
      return s.replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
      }[c]!));
    }

    type Sig = {
      first_name: string; last_initial: string;
      school: string; neighbourhood: string; signed_at: string;
    };

    const emptyText = el.dataset.emptyText || 'Be the first to sign →';
    const MARQUEE_FLOOR = 6;
    const ariaLabel = lang === 'zh' ? '最近确认的签名' : 'Recent confirmed signatures';

    function cardHtml(s: Sig, ariaHide: boolean): string {
      return (
        `<article class="sig-card"${ariaHide ? ' aria-hidden="true"' : ''}>` +
          `<p class="sig-card__name sans">${escapeHtml(s.first_name)} ${escapeHtml(s.last_initial)}.</p>` +
          `<p class="sig-card__meta sans">` +
            `<span class="sig-card__school">${escapeHtml(s.school)}</span>` +
            `<span class="sig-card__sep" aria-hidden="true"> · </span>` +
            `<time class="sig-card__time" datetime="${escapeHtml(s.signed_at)}">—</time>` +
          `</p>` +
        `</article>`
      );
    }

    async function poll() {
      try {
        const res = await fetch(
          `${url}/rest/v1/public_signatures?select=first_name,last_initial,school,neighbourhood,signed_at&order=signed_at.desc&limit=${limit}`,
          {
            headers: {
              apikey: key!,
              Authorization: `Bearer ${key!}`,
              Prefer: 'count=exact',
            },
          }
        );
        if (!res.ok) return;
        const sigs: Sig[] = await res.json();
        if (!Array.isArray(sigs)) return;
        // Live-update the total signatures caption from Content-Range.
        const range = res.headers.get('content-range');
        const after = range?.split('/')[1];
        const total = after ? parseInt(after, 10) : NaN;
        if (Number.isFinite(total)) {
          const totalEl = el.querySelector<HTMLElement>('[data-signatories-total]');
          if (totalEl) {
            totalEl.textContent = lang === 'zh'
              ? `共 ${total} 个已验证签名`
              : `${total} total verified signatures`;
          }
        }
        if (sigs.length === 0) {
          flowOuter!.innerHTML =
            `<p class="signatories-empty" data-signatories-flow>${escapeHtml(emptyText)}</p>`;
          return;
        }
        const animate = sigs.length >= MARQUEE_FLOOR;
        const trackClass = `signatories-track${animate ? ' signatories-track--animated' : ''}`;
        const list = animate ? sigs.concat(sigs) : sigs;
        const cards = list
          .map((s, i) => cardHtml(s, animate && i >= sigs.length))
          .join('');
        flowOuter!.innerHTML =
          `<div class="${trackClass}" data-signatories-flow aria-label="${escapeHtml(ariaLabel)}">` +
            cards +
          `</div>`;
        paintTimes(flowOuter!, lang);
      } catch {
        /* keep last good */
      }
    }

    poll();
    setInterval(poll, pollMs);
  });

  // ─── "View all signatures" modal ────────────────────────────────
  // Lazily fetches the full public_signatures list on first open
  // (no limit), populates a searchable scrollable list. Saves +
  // restores window.scrollY around open/close to dodge iOS Safari's
  // body-overflow-toggle scroll-loss quirk (same pattern as the
  // SvgVisual lightbox).
  (() => {
    const modal = document.getElementById('signatories-modal') as HTMLDialogElement | null;
    if (!modal || typeof modal.showModal !== 'function') return;

    type Sig = {
      first_name: string; last_initial: string;
      school: string; neighbourhood: string; signed_at: string;
    };

    const feed = document.querySelector<HTMLElement>('.signatories');
    const url = feed?.dataset.supabaseUrl;
    const key = feed?.dataset.supabaseKey;
    const lang = (feed?.dataset.lang === 'zh' ? 'zh' : 'en') as 'en' | 'zh';

    const listEl = modal.querySelector<HTMLOListElement>('[data-signatories-list]');
    const countEl = modal.querySelector<HTMLElement>('[data-signatories-count]');
    const noMatchEl = modal.querySelector<HTMLElement>('[data-signatories-no-match]');
    const loadingEl = modal.querySelector<HTMLElement>('[data-signatories-loading]');
    const searchEl = modal.querySelector<HTMLInputElement>('[data-signatories-search]');
    const neighbourhoodEl = modal.querySelector<HTMLSelectElement>('[data-signatories-neighbourhood]');
    const triggers = document.querySelectorAll<HTMLButtonElement>('[data-view-all]');

    let allSigs: Sig[] = [];
    let savedScrollY = 0;

    function escapeHtml(s: string) {
      return s.replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
      }[c]!));
    }

    function formatDate(iso: string): string {
      const d = new Date(iso);
      if (!Number.isFinite(d.getTime())) return '';
      return new Intl.DateTimeFormat(lang === 'zh' ? 'zh-CN' : 'en-CA', {
        year: 'numeric', month: 'short', day: 'numeric',
      }).format(d);
    }

    function rowHtml(s: Sig): string {
      return (
        `<li class="sig-row">` +
          `<span class="sig-row__name sans">${escapeHtml(s.first_name)} ${escapeHtml(s.last_initial)}.</span>` +
          `<span class="sig-row__school sans">${escapeHtml(s.school)}</span>` +
          `<span class="sig-row__date sans">${escapeHtml(formatDate(s.signed_at))}</span>` +
        `</li>`
      );
    }

    function render(filtered: Sig[]) {
      if (!listEl) return;
      // Three render states managed mutually-exclusively:
      //   1. allSigs.length === 0 → DB has zero confirmed sigs (or
      //      pre-fetch). Hide list, hide no-match, show empty caption.
      //   2. allSigs.length > 0 && filtered.length === 0 → search
      //      excluded everything. Show no-match.
      //   3. filtered.length > 0 → render rows.
      if (allSigs.length === 0) {
        listEl.innerHTML = '';
        if (noMatchEl) noMatchEl.hidden = true;
        if (countEl) {
          countEl.textContent = lang === 'zh'
            ? '尚无确认签名'
            : 'No confirmed signatures yet';
        }
        return;
      }
      if (countEl) {
        countEl.textContent = lang === 'zh'
          ? `共 ${allSigs.length} 个签名 · 显示 ${filtered.length}`
          : `${allSigs.length} total signatures · showing ${filtered.length}`;
      }
      if (filtered.length === 0) {
        listEl.innerHTML = '';
        if (noMatchEl) noMatchEl.hidden = false;
      } else {
        // Cap at 2000 rows for DOM perf — campaigns this size are rare
        // but the cap protects older phones from a Long Task spike on
        // initial render. Search still applies to the full list.
        listEl.innerHTML = filtered.slice(0, 2000).map(rowHtml).join('');
        if (noMatchEl) noMatchEl.hidden = true;
      }
    }

    function applyFilter() {
      const q = searchEl ? searchEl.value.trim().toLowerCase() : '';
      const neighbourhood = neighbourhoodEl ? neighbourhoodEl.value : '';
      let filtered = allSigs;
      if (neighbourhood) {
        filtered = filtered.filter((s) => s.neighbourhood === neighbourhood);
      }
      if (q) {
        filtered = filtered.filter((s) =>
          (s.first_name + ' ' + s.last_initial).toLowerCase().includes(q) ||
          s.school.toLowerCase().includes(q) ||
          s.neighbourhood.toLowerCase().includes(q)
        );
      }
      render(filtered);
    }

    // Build the neighbourhood select options from the loaded data.
    // Each option shows "Name (count)" so the user immediately sees
    // where the cluster of signers actually is.
    function populateNeighbourhoodOptions() {
      if (!neighbourhoodEl) return;
      const counts = new Map<string, number>();
      for (const s of allSigs) {
        if (!s.neighbourhood) continue;
        counts.set(s.neighbourhood, (counts.get(s.neighbourhood) ?? 0) + 1);
      }
      // Sort alphabetically; counts shown inline next to each label.
      const sorted = Array.from(counts.entries()).sort((a, b) =>
        a[0].localeCompare(b[0])
      );
      // Preserve the leading "All neighbourhoods" option, replace the rest.
      const allOption = neighbourhoodEl.options[0];
      neighbourhoodEl.innerHTML = '';
      if (allOption) neighbourhoodEl.appendChild(allOption);
      for (const [name, count] of sorted) {
        const opt = document.createElement('option');
        opt.value = name;
        opt.textContent = `${name} (${count})`;
        neighbourhoodEl.appendChild(opt);
      }
    }

    async function loadAll() {
      if (!url || !key) {
        if (loadingEl) loadingEl.hidden = true;
        return;
      }
      if (loadingEl) loadingEl.hidden = false;
      // Skip refetch if we already have rows (open-close-reopen reuses cache).
      if (allSigs.length > 0) {
        if (loadingEl) loadingEl.hidden = true;
        return;
      }
      try {
        // Range header lets us pull more than the default 1000-row cap.
        const res = await fetch(
          `${url}/rest/v1/public_signatures?select=first_name,last_initial,school,neighbourhood,signed_at&order=signed_at.desc`,
          { headers: { apikey: key, Authorization: `Bearer ${key}`, Range: '0-9999' } }
        );
        if (res.ok) {
          const json = await res.json();
          if (Array.isArray(json)) allSigs = json;
        }
      } catch { /* allSigs stays empty */ }
      if (loadingEl) loadingEl.hidden = true;
      populateNeighbourhoodOptions();
      render(allSigs);
    }

    triggers.forEach((btn) => {
      btn.addEventListener('click', () => {
        savedScrollY = window.scrollY;
        modal.showModal();
        // Reset search + neighbourhood + scroll-to-top of list on each open.
        if (searchEl) searchEl.value = '';
        if (neighbourhoodEl) neighbourhoodEl.value = '';
        if (listEl?.parentElement) listEl.parentElement.scrollTop = 0;
        // If first open AND we have credentials: show loading, fetch.
        // Otherwise (cached data, or no env to fetch): hide loading
        // immediately and render whatever state we have. Without the
        // explicit hide here, the SSR-rendered loading paragraph
        // shows indefinitely whenever url/key aren't available.
        if (allSigs.length === 0 && url && key) {
          if (loadingEl) loadingEl.hidden = false;
          if (noMatchEl) noMatchEl.hidden = true;
          if (listEl) listEl.innerHTML = '';
          loadAll();
        } else {
          if (loadingEl) loadingEl.hidden = true;
          applyFilter();
        }
      });
    });

    modal.addEventListener('close', () => {
      window.scrollTo({ top: savedScrollY, left: 0, behavior: 'instant' as ScrollBehavior });
    });

    modal.querySelector('[data-close-signatories]')?.addEventListener('click', () => modal.close());

    // Backdrop click closes (only when the click landed on the dialog itself).
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });

    searchEl?.addEventListener('input', applyFilter);
    neighbourhoodEl?.addEventListener('change', applyFilter);
  })();
</script>

<style is:global>
  /* Hoisted to global so the JS poller's freshly-templated cards
     match these rules — Astro auto-scoping appends a per-build CID
     attribute to every selector, but innerHTML strings can't carry
     it without per-build coupling. Class names are uniquely prefixed
     (`signatories-` / `sig-card-`) to avoid collisions. */

  .signatories {
    margin: 24px 0;
  }
  .signatories-caption {
    font-size: 13px;
    color: var(--ink-soft);
    margin-bottom: 12px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }
  .signatories-caption__primary {
    display: inline;
  }
  .signatories-caption__total {
    color: var(--muted, #6B7280);
  }
  .signatories-view-all {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    color: var(--accent, #1C3F8F);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    flex-shrink: 0;
  }
  .signatories-view-all:hover,
  .signatories-view-all:focus-visible {
    text-decoration: underline;
    outline: none;
  }

  /* Outer mask — clips the marquee track and softens the edges so
     cards don't pop in/out abruptly. */
  .signatories-flow {
    position: relative;
    overflow: hidden;
    padding: 4px 0;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      black 32px,
      black calc(100% - 32px),
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      black 32px,
      black calc(100% - 32px),
      transparent 100%
    );
  }

  .signatories-track {
    display: flex;
    gap: 12px;
    width: max-content;
  }
  .signatories-track--animated {
    /* ~40 px/s, calmer than a news ticker. 50s loop fits ~30 pills × 2.
       If the campaign grows past 100, this can be made content-aware. */
    animation: signatories-scroll 50s linear infinite;
  }
  .signatories-flow:hover .signatories-track--animated,
  .signatories-flow:focus-within .signatories-track--animated {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .signatories-track--animated {
      animation: none;
    }
  }
  @keyframes signatories-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .signatories-empty {
    color: var(--muted);
    font-style: italic;
    padding: 8px 0;
  }

  .sig-card {
    flex: 0 0 auto;
    min-width: 180px;
    background: var(--paper, #fff);
    border: 1px solid var(--line, #e5e7eb);
    border-radius: 8px;
    padding: 10px 14px;
    box-shadow: var(--shadow-sm, 0 1px 2px rgba(0, 0, 0, 0.04));
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sig-card__name {
    font-size: 14px;
    font-weight: 700;
    color: var(--accent, #1C3F8F);
    line-height: 1.3;
    margin: 0;
  }
  .sig-card__meta {
    font-size: 11px;
    color: var(--muted, #6B7280);
    line-height: 1.4;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sig-card__sep {
    margin: 0 4px;
  }

  /* "View all" modal — searchable list of every confirmed signature.
     Note `display: flex` is bound to [open] so the browser's default
     `dialog:not([open]) { display: none }` continues to apply when
     the dialog is closed; otherwise our explicit display value would
     leak the modal markup into the page even when it shouldn't show. */
  .signatories-modal {
    width: min(560px, calc(100vw - 32px));
    max-width: 560px;
    height: 80vh;
    max-height: 80vh;
    padding: 0;
    border: 1px solid var(--line, #e5e7eb);
    border-radius: 12px;
