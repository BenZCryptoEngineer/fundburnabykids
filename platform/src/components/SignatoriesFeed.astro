---
// Recent verified signatories — calm card row with seamless horizontal
// marquee on desktop; vertical stack on mobile.
//
// Per UX research + privacy policy: first name + last initial + school
// only (neighbourhood + signed_at are public-record context but the
// neighbourhood was visually redundant when school name == neighbourhood
// name, e.g. "Capitol Hill · Capitol Hill"). Card shows: bold accent
// name + muted meta line ("School · 2h ago").
//
// CSS-scoping note. Astro auto-scopes <style> blocks via the
// `data-astro-cid-…` attribute on every emitted element. Our JS
// poller re-renders the track via innerHTML with raw string
// templates — those strings cannot inject the CID (it changes per
// build), which means scoped rules silently stop matching after the
// first poll. We use `<style is:global>` here and prefix every class
// with `signatories-` / `sig-card-` so name collisions can't happen.
// Tradeoff accepted: this single component now contributes a few
// global rules instead of paying the bug-of-the-week tax forever.

import I18nText from '~/components/I18nText.astro';
import type { Lang } from '~/lib/i18n';

interface Props {
  lang: Lang;
  /** How many to show; default 60 */
  limit?: number;
}

const { lang, limit = 60 } = Astro.props;

const url = import.meta.env.PUBLIC_SUPABASE_URL;
const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

type Sig = {
  first_name: string;
  last_initial: string;
  school: string;
  neighbourhood: string;
  signed_at: string;
};

let initial: Sig[] = [];
if (url && key) {
  try {
    const res = await fetch(
      `${url}/rest/v1/public_signatures?select=first_name,last_initial,school,neighbourhood,signed_at&order=signed_at.desc&limit=${limit}`,
      { headers: { apikey: key, Authorization: `Bearer ${key}` } }
    );
    if (res.ok) initial = await res.json();
  } catch {
    /* keep empty */
  }
}

// Sparse-state floor: per UX research, <6 unique items shouldn't
// marquee — a 3-pill loop visibly resets every few seconds and reads
// as broken. Below this count we render a static centred row.
const MARQUEE_FLOOR = 6;
const animate = initial.length >= MARQUEE_FLOOR;
---

<div class="signatories"
     data-supabase-url={url}
     data-supabase-key={key}
     data-poll-ms="60000"
     data-limit={limit}
     data-lang={lang}
     data-animate={animate ? 'true' : 'false'}
     data-empty-text={lang === 'zh' ? '成为第一位签名者 →' : 'Be the first to sign →'}>
  <p class="signatories-caption sans">
    <I18nText
      en="Recent confirmed signatures"
      zh="最近确认的签名"
      lang={lang}
    />
  </p>

  <div class="signatories-flow">
    {initial.length === 0 ? (
      <p class="signatories-empty" data-signatories-flow>
        <I18nText
          en="Be the first to sign →"
          zh="成为第一位签名者 →"
          lang={lang}
        />
      </p>
    ) : (
      <div
        class={`signatories-track${animate ? ' signatories-track--animated' : ''}`}
        data-signatories-flow
        aria-label={lang === 'zh' ? '最近确认的签名' : 'Recent confirmed signatures'}
      >
        {(animate ? [...initial, ...initial] : initial).map((s, i) => (
          <article
            class="sig-card"
            aria-hidden={animate && i >= initial.length ? 'true' : undefined}
          >
            <p class="sig-card__name sans">{s.first_name} {s.last_initial}.</p>
            <p class="sig-card__meta sans">
              <span class="sig-card__school">{s.school}</span>
              <span class="sig-card__sep" aria-hidden="true"> · </span>
              <time class="sig-card__time" datetime={s.signed_at}>—</time>
            </p>
          </article>
        ))}
      </div>
    )}
  </div>
</div>

<script>
  // Format an ISO timestamp as a short relative time ("just now",
  // "5m ago", "2h ago", "3d ago"), or a date stamp past 7 days.
  // Bilingual via Intl.RelativeTimeFormat.
  function formatRelative(isoLike: string, lang: 'en' | 'zh'): string {
    const then = new Date(isoLike).getTime();
    if (!Number.isFinite(then)) return '';
    const now = Date.now();
    const diffSec = Math.round((then - now) / 1000); // negative = past
    const absSec = Math.abs(diffSec);
    const locale = lang === 'zh' ? 'zh-CN' : 'en-CA';
    const rtf = new Intl.RelativeTimeFormat(locale, { numeric: 'auto', style: 'narrow' });
    if (absSec < 60) return lang === 'zh' ? '刚刚' : 'just now';
    if (absSec < 3600) return rtf.format(Math.round(diffSec / 60), 'minute');
    if (absSec < 86400) return rtf.format(Math.round(diffSec / 3600), 'hour');
    if (absSec < 86400 * 7) return rtf.format(Math.round(diffSec / 86400), 'day');
    // Past a week, show absolute short date.
    return new Intl.DateTimeFormat(locale, { month: 'short', day: 'numeric' })
      .format(new Date(isoLike));
  }

  function paintTimes(scope: ParentNode, lang: 'en' | 'zh') {
    scope.querySelectorAll<HTMLTimeElement>('time.sig-card__time').forEach((el) => {
      const iso = el.getAttribute('datetime');
      if (!iso) return;
      el.textContent = formatRelative(iso, lang);
    });
  }

  document.querySelectorAll<HTMLElement>('.signatories').forEach((el) => {
    const url = el.dataset.supabaseUrl;
    const key = el.dataset.supabaseKey;
    const pollMs = parseInt(el.dataset.pollMs || '60000', 10);
    const limit = parseInt(el.dataset.limit || '60', 10);
    const lang = (el.dataset.lang === 'zh' ? 'zh' : 'en') as 'en' | 'zh';
    if (!url || !key) {
      // Still paint times for the SSR-rendered cards (they'll
      // otherwise show "—" forever).
      paintTimes(el, lang);
      return;
    }

    // Paint the SSR-rendered timestamps once on hydration.
    paintTimes(el, lang);

    const flowOuter = el.querySelector<HTMLElement>('.signatories-flow');
    if (!flowOuter) return;

    function escapeHtml(s: string) {
      return s.replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
      }[c]!));
    }

    type Sig = {
      first_name: string; last_initial: string;
      school: string; neighbourhood: string; signed_at: string;
    };

    const emptyText = el.dataset.emptyText || 'Be the first to sign →';
    const MARQUEE_FLOOR = 6;
    const ariaLabel = lang === 'zh' ? '最近确认的签名' : 'Recent confirmed signatures';

    function cardHtml(s: Sig, ariaHide: boolean): string {
      return (
        `<article class="sig-card"${ariaHide ? ' aria-hidden="true"' : ''}>` +
          `<p class="sig-card__name sans">${escapeHtml(s.first_name)} ${escapeHtml(s.last_initial)}.</p>` +
          `<p class="sig-card__meta sans">` +
            `<span class="sig-card__school">${escapeHtml(s.school)}</span>` +
            `<span class="sig-card__sep" aria-hidden="true"> · </span>` +
            `<time class="sig-card__time" datetime="${escapeHtml(s.signed_at)}">—</time>` +
          `</p>` +
        `</article>`
      );
    }

    async function poll() {
      try {
        const res = await fetch(
          `${url}/rest/v1/public_signatures?select=first_name,last_initial,school,neighbourhood,signed_at&order=signed_at.desc&limit=${limit}`,
          { headers: { apikey: key!, Authorization: `Bearer ${key!}` } }
        );
        if (!res.ok) return;
        const sigs: Sig[] = await res.json();
        if (!Array.isArray(sigs)) return;
        if (sigs.length === 0) {
          flowOuter!.innerHTML =
            `<p class="signatories-empty" data-signatories-flow>${escapeHtml(emptyText)}</p>`;
          return;
        }
        const animate = sigs.length >= MARQUEE_FLOOR;
        const trackClass = `signatories-track${animate ? ' signatories-track--animated' : ''}`;
        const list = animate ? sigs.concat(sigs) : sigs;
        const cards = list
          .map((s, i) => cardHtml(s, animate && i >= sigs.length))
          .join('');
        flowOuter!.innerHTML =
          `<div class="${trackClass}" data-signatories-flow aria-label="${escapeHtml(ariaLabel)}">` +
            cards +
          `</div>`;
        paintTimes(flowOuter!, lang);
      } catch {
        /* keep last good */
      }
    }

    poll();
    setInterval(poll, pollMs);
  });
</script>

<style is:global>
  /* Hoisted to global so the JS poller's freshly-templated cards
     match these rules — Astro auto-scoping appends a per-build CID
     attribute to every selector, but innerHTML strings can't carry
     it without per-build coupling. Class names are uniquely prefixed
     (`signatories-` / `sig-card-`) to avoid collisions. */

  .signatories {
    margin: 24px 0;
  }
  .signatories-caption {
    font-size: 13px;
    color: var(--ink-soft);
    margin-bottom: 12px;
  }

  /* Outer mask — clips the marquee track and softens the edges so
     cards don't pop in/out abruptly. */
  .signatories-flow {
    position: relative;
    overflow: hidden;
    padding: 4px 0;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      black 32px,
      black calc(100% - 32px),
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      black 32px,
      black calc(100% - 32px),
      transparent 100%
    );
  }

  .signatories-track {
    display: flex;
    gap: 12px;
    width: max-content;
  }
  .signatories-track--animated {
    /* ~40 px/s, calmer than a news ticker. 50s loop fits ~30 pills × 2.
       If the campaign grows past 100, this can be made content-aware. */
    animation: signatories-scroll 50s linear infinite;
  }
  .signatories-flow:hover .signatories-track--animated,
  .signatories-flow:focus-within .signatories-track--animated {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .signatories-track--animated {
      animation: none;
    }
  }
  @keyframes signatories-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .signatories-empty {
    color: var(--muted);
    font-style: italic;
    padding: 8px 0;
  }

  .sig-card {
    flex: 0 0 auto;
    min-width: 180px;
    background: var(--paper, #fff);
    border: 1px solid var(--line, #e5e7eb);
    border-radius: 8px;
    padding: 10px 14px;
    box-shadow: var(--shadow-sm, 0 1px 2px rgba(0, 0, 0, 0.04));
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sig-card__name {
    font-size: 14px;
    font-weight: 700;
    color: var(--accent, #1C3F8F);
    line-height: 1.3;
    margin: 0;
  }
  .sig-card__meta {
    font-size: 11px;
    color: var(--muted, #6B7280);
    line-height: 1.4;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sig-card__sep {
    margin: 0 4px;
  }

  /* Mobile: stop the marquee, stack the first few cards vertically.
     A horizontal ticker on a 360 px viewport reads as cramped + janky,
     and most mobile users skim a vertical stack faster anyway. */
  @media (max-width: 640px) {
    .signatories-flow {
      -webkit-mask-image: none;
      mask-image: none;
      overflow: visible;
    }
    .signatories-track,
    .signatories-track--animated {
      display: flex;
      flex-direction: column;
      width: auto;
      gap: 8px;
      animation: none;
    }
    .signatories-track--animated > .sig-card[aria-hidden="true"] {
      display: none;
    }
    .signatories-track > .sig-card:nth-child(n+6) {
      display: none;
    }
    .sig-card {
      min-width: 0;
    }
  }
</style>
