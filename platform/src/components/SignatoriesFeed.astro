---
// Recent verified signatories — Avaaz-style scrolling pill flow.
// Per UX research + privacy policy: first name + last initial + school
// + neighbourhood only. Polled every 60s for new entries.

import I18nText from '~/components/I18nText.astro';
import type { Lang } from '~/lib/i18n';

interface Props {
  lang: Lang;
  /** How many to show; default 60 */
  limit?: number;
}

const { lang, limit = 60 } = Astro.props;

const url = import.meta.env.PUBLIC_SUPABASE_URL;
const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

type Sig = {
  first_name: string;
  last_initial: string;
  school: string;
  neighbourhood: string;
  signed_at: string;
};

let initial: Sig[] = [];
if (url && key) {
  try {
    const res = await fetch(
      `${url}/rest/v1/public_signatures?select=first_name,last_initial,school,neighbourhood,signed_at&order=signed_at.desc&limit=${limit}`,
      { headers: { apikey: key, Authorization: `Bearer ${key}` } }
    );
    if (res.ok) initial = await res.json();
  } catch {
    /* keep empty */
  }
}
---

<div class="signatories"
     data-supabase-url={url}
     data-supabase-key={key}
     data-poll-ms="60000"
     data-limit={limit}
     data-empty-text={lang === 'zh' ? '成为第一位签名者 →' : 'Be the first to sign →'}>
  <p class="signatories__caption sans">
    <I18nText
      en="Recent confirmed signatures"
      zh="最近确认的签名"
      lang={lang}
    />
  </p>

  <div class="signatories__flow">
    {/* Two render modes: empty-state (single message) or marquee track.
        The track wraps the pills and gets a CSS animation that scrolls
        them left infinitely. To make the loop seamless, the same pill
        list is rendered twice in the track — at -50% translateX the
        second copy lands exactly where the first started. */}
    {initial.length === 0 ? (
      <p class="signatories__empty" data-signatories-flow>
        <I18nText
          en="Be the first to sign →"
          zh="成为第一位签名者 →"
          lang={lang}
        />
      </p>
    ) : (
      <div class="signatories__track" data-signatories-flow aria-label="Recent confirmed signatures">
        {[...initial, ...initial].map((s, i) => (
          <span
            class="sig-pill"
            title={`${s.school}, ${s.neighbourhood}`}
            aria-hidden={i >= initial.length ? 'true' : undefined}
          >
            <span class="sig-pill__name sans">{s.first_name} {s.last_initial}.</span>
            <span class="sig-pill__where">{s.school}</span>
          </span>
        ))}
      </div>
    )}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.signatories').forEach((el) => {
    const url = el.dataset.supabaseUrl;
    const key = el.dataset.supabaseKey;
    const pollMs = parseInt(el.dataset.pollMs || '60000', 10);
    const limit = parseInt(el.dataset.limit || '60', 10);
    if (!url || !key) return;

    const flowOuter = el.querySelector<HTMLElement>('.signatories__flow');
    if (!flowOuter) return;

    function escapeHtml(s: string) {
      return s.replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
      }[c]!));
    }

    type Sig = {
      first_name: string; last_initial: string;
      school: string; neighbourhood: string; signed_at: string;
    };

    const emptyText = el.dataset.emptyText || 'Be the first to sign →';

    function pillHtml(s: Sig, ariaHide: boolean): string {
      return (
        `<span class="sig-pill" title="${escapeHtml(s.school + ', ' + s.neighbourhood)}"` +
          (ariaHide ? ' aria-hidden="true"' : '') + `>` +
          `<span class="sig-pill__name sans">${escapeHtml(s.first_name)} ${escapeHtml(s.last_initial)}.</span>` +
          `<span class="sig-pill__where">${escapeHtml(s.school)}</span>` +
        `</span>`
      );
    }

    async function poll() {
      try {
        const res = await fetch(
          `${url}/rest/v1/public_signatures?select=first_name,last_initial,school,neighbourhood,signed_at&order=signed_at.desc&limit=${limit}`,
          { headers: { apikey: key!, Authorization: `Bearer ${key!}` } }
        );
        if (!res.ok) return;            // network/server glitch — keep last good
        const sigs: Sig[] = await res.json();
        if (!Array.isArray(sigs)) return; // shape unexpected — keep last good
        // Empty array IS legitimate (e.g. fresh campaign / admin wipe);
        // render the empty-state pill so stale SSR-baked entries don't
        // ghost-linger on the page after the underlying rows go away.
        if (sigs.length === 0) {
          flowOuter!.innerHTML =
            `<p class="signatories__empty" data-signatories-flow>${escapeHtml(emptyText)}</p>`;
          return;
        }
        // Render pills twice in the track so the CSS marquee
        // translateX(-50%) loops seamlessly. Second copy is
        // aria-hidden so screen readers only hear each signer once.
        const firstPass = sigs.map((s) => pillHtml(s, false)).join('');
        const secondPass = sigs.map((s) => pillHtml(s, true)).join('');
        flowOuter!.innerHTML =
          `<div class="signatories__track" data-signatories-flow aria-label="Recent confirmed signatures">` +
            firstPass + secondPass +
          `</div>`;
      } catch {
        /* keep last good */
      }
    }
    poll();
    setInterval(poll, pollMs);
  });
</script>

<style>
  .signatories {
    margin: 24px 0;
  }
  .signatories__caption {
    font-size: 13px;
    color: var(--ink-soft);
    margin-bottom: 12px;
  }
  /* Outer mask — clips the marquee track to the row width and provides
     a soft fade on the left/right edges so pills don't appear to pop in. */
  .signatories__flow {
    position: relative;
    overflow: hidden;
    padding: 4px 0;
    /* Soft fade-out at edges via mask (fall back gracefully on browsers
       that don't support mask-image — pills just clip to box edge). */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0,
      black 24px,
      black calc(100% - 24px),
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0,
      black 24px,
      black calc(100% - 24px),
      transparent 100%
    );
  }
  .signatories__track {
    display: inline-flex;
    gap: 6px;
    width: max-content;
    /* Animation duration is heuristic — 60s for ~30 pills × 2 copies
       reads as a calm continuous flow. Tune by content density if the
       campaign list grows past a few hundred. */
    animation: signatories-scroll 60s linear infinite;
  }
  .signatories__flow:hover .signatories__track {
    animation-play-state: paused;
  }
  /* Respect users who opt out of motion — fall back to static row,
     truncated to viewport (the mask fade still covers the cut). */
  @media (prefers-reduced-motion: reduce) {
    .signatories__track {
      animation: none;
    }
  }
  @keyframes signatories-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .signatories__empty {
    color: var(--muted);
    font-style: italic;
    padding: 8px 0;
  }
  .sig-pill {
    display: inline-flex;
    flex-direction: column;
    background: var(--accent);
    color: #fff;
    padding: 6px 10px;
    border-radius: 4px;
    font-size: 12px;
    line-height: 1.3;
    flex: 0 0 auto;
  }
  .sig-pill__name {
    font-weight: 600;
  }
  .sig-pill__where {
    font-size: 11px;
    opacity: 0.85;
    margin-top: 1px;
  }
</style>
