---
// StakeholderMap — civics-101 diagram of BC public education + how the
// $9.4M case lands on Burnaby families. The campaign mentions a lot of
// acronyms (BCPSEA, DPAC, PAC, SD41, Treasury Board, MLA) without ever
// teaching the structure that connects them. A politically-disengaged
// parent reading the homepage hits a wall at "BCPSEA admits this is
// their interpretive error" without knowing what BCPSEA is in plain
// language.
//
// Two render modes:
//   inline=false (default) — only the fullscreen dialog renders. Other
//     components (e.g. PersonaSelector's helper bar) provide trigger
//     buttons that open the dialog by ID. Keeps the homepage compact;
//     parents who DO want the civics lesson click in.
//   inline=true            — also renders a full inline section above
//     the dialog (the original behavior). Useful if you want the
//     diagram visible by default on a specific page.
//
// The diagram body (4 tiers + numbered story + takeaway) is extracted
// into _StakeholderMapBody.astro so it can be rendered both inline AND
// inside the dialog without duplicating the markup.
//
// Mobile: dialog has @panzoom/panzoom-driven pinch-to-zoom (same
// gesture vocabulary as SvgVisual.astro elsewhere on the site).
//
// EN/ZH split: every string in the body partial is rendered through
// <I18nText> so adding or fixing translations stays in one place.

import I18nText from '~/components/I18nText.astro';
import Icon from '~/components/Icon.astro';
import StakeholderMapBody from '~/components/_StakeholderMapBody.astro';
import type { Lang } from '~/lib/i18n';

interface Props {
  lang: Lang;
  /** When true, also render the diagram inline as a visible section.
      Default false: only the fullscreen dialog renders; trigger from
      other components by referencing the dialog ID. */
  inline?: boolean;
}

const { lang, inline = false } = Astro.props;

// Stable dialog ID so trigger buttons in OTHER components (e.g.
// PersonaSelector helper bar) can reference it. Only one StakeholderMap
// instance per page is supported.
const dialogId = 'stakeholder-zoom';
const zoomLabel = lang === 'zh' ? '放大查看完整图' : 'Tap to enlarge full diagram';
const closeLabel = lang === 'zh' ? '关闭' : 'Close';
---

{inline && (
  <section class="smap" id="how-it-works">
    <div class="wrap-wide">
      <header class="smap__header">
        <p class="kicker sans">
          <I18nText
            en="Civics, in plain language"
            zh="政治课，用大白话讲"
            lang={lang}
          />
        </p>
        <h2>
          <I18nText
            en="How public education in BC actually works — and where you fit in"
            zh="BC 公立教育到底怎么运作 — 你在这张图里是哪个位置"
            lang={lang}
          />
        </h2>
        <p class="smap__lede">
          <I18nText
            en="If you've heard names like BCPSEA, DPAC, Treasury Board, MLA and felt lost — this is for you. One diagram, four tiers, every name in plain English."
            zh="如果你听到 BCPSEA、DPAC、Treasury Board、MLA 这些名词觉得一头雾水 — 这张图是给你的。四层结构，每个名词用大白话解释。"
            lang={lang}
          />
        </p>
      </header>

      <StakeholderMapBody lang={lang} />

      <button
        type="button"
        class="smap__zoom-btn sans"
        data-smap-zoom-open={dialogId}
        aria-label={zoomLabel}
      >
        <Icon name="search" size={16} />
        <span>{zoomLabel}</span>
      </button>
    </div>
  </section>
)}

<!-- Fullscreen zoom dialog — same diagram, panzoom-able for mobile
     readability. Always rendered, with the body partial embedded
     directly so it's available immediately on first open (no clone
     dance like the previous revision). -->
<dialog class="smap-zoom" id={dialogId} aria-label={zoomLabel}>
  <button
    type="button"
    class="smap-zoom__close icon-close"
    data-smap-zoom-close
    aria-label={closeLabel}
  >×</button>
  <p class="smap-zoom__hint sans" aria-hidden="true">
    <I18nText
      en="Pinch or scroll to zoom · drag to pan · use +/−/⟲ buttons"
      zh="双指缩放或滚轮缩放 · 拖动平移 · 也可用 +/−/⟲ 按钮"
      lang={lang}
    />
  </p>
  <div class="smap-zoom__viewport" data-smap-zoom-viewport>
    <div class="smap-zoom__media" data-smap-zoom-media>
      <StakeholderMapBody lang={lang} />
    </div>
  </div>
  <div class="smap-zoom__controls" role="toolbar" aria-label={lang === 'zh' ? '缩放控制' : 'Zoom controls'}>
    <button type="button" class="smap-zoom__btn" data-smap-zoom-out aria-label={lang === 'zh' ? '缩小' : 'Zoom out'}>−</button>
    <button type="button" class="smap-zoom__btn" data-smap-zoom-reset aria-label={lang === 'zh' ? '重置缩放' : 'Reset zoom'}>⟲</button>
    <button type="button" class="smap-zoom__btn" data-smap-zoom-in aria-label={lang === 'zh' ? '放大' : 'Zoom in'}>+</button>
  </div>
</dialog>

<script>
  // Mobile zoom for the StakeholderMap. Same gesture vocabulary as
  // SvgVisual.astro elsewhere on the site (panzoom for pinch / wheel
  // / drag, +/-/reset buttons for keyboard a11y).
  import Panzoom from '@panzoom/panzoom';

  type DialogWithPz = HTMLDialogElement & {
    __pz?: ReturnType<typeof Panzoom>;
    __pzWheelBound?: boolean;
    __savedScrollY?: number;
  };

  if (!(window as any).__smapZoomBound) {
    (window as any).__smapZoomBound = true;

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;

      // Open
      const opener = target.closest<HTMLElement>('[data-smap-zoom-open]');
      if (opener) {
        const id = opener.dataset.smapZoomOpen;
        if (!id) return;
        const dlg = document.getElementById(id) as DialogWithPz | null;
        if (!dlg || typeof dlg.showModal !== 'function') return;

        dlg.__savedScrollY = window.scrollY;
        dlg.showModal();
        const viewport = dlg.querySelector<HTMLElement>('.smap-zoom__viewport');
        if (viewport) viewport.scrollTo(0, 0);

        const media = dlg.querySelector<HTMLElement>('[data-smap-zoom-media]');
        const isNarrow = window.matchMedia('(max-width: 560px)').matches;
        if (media && !dlg.__pz) {
          dlg.__pz = Panzoom(media, {
            maxScale: 4,
            minScale: 0.5,
            startScale: isNarrow ? 1 : 0.85,
            step: 0.3,
          });
          const container = dlg.querySelector<HTMLElement>('.smap-zoom__viewport');
          if (container && !dlg.__pzWheelBound) {
            container.addEventListener(
              'wheel',
              (ev) => {
                ev.preventDefault();
                dlg.__pz?.zoomWithWheel(ev as WheelEvent);
              },
              { passive: false }
            );
            dlg.__pzWheelBound = true;
          }
          dlg.addEventListener('close', () => {
            const y = dlg.__savedScrollY;
            if (typeof y === 'number') {
              window.scrollTo({ top: y, left: 0, behavior: 'instant' as ScrollBehavior });
            }
          });
        } else if (dlg.__pz) {
          dlg.__pz.zoom(isNarrow ? 1 : 0.85, { animate: false });
          dlg.__pz.pan(0, 0, { animate: false });
        }
        return;
      }

      // Toolbar buttons
      const dlgFrom = (el: HTMLElement | null) =>
        el?.closest('dialog') as DialogWithPz | null;
      const zoomIn = target.closest<HTMLElement>('[data-smap-zoom-in]');
      if (zoomIn) { dlgFrom(zoomIn)?.__pz?.zoomIn(); return; }
      const zoomOut = target.closest<HTMLElement>('[data-smap-zoom-out]');
      if (zoomOut) { dlgFrom(zoomOut)?.__pz?.zoomOut(); return; }
      const zoomReset = target.closest<HTMLElement>('[data-smap-zoom-reset]');
      if (zoomReset) { dlgFrom(zoomReset)?.__pz?.reset(); return; }

      // Close
      const closer = target.closest<HTMLElement>('[data-smap-zoom-close]');
      if (closer) {
        const dlg = closer.closest('dialog') as HTMLDialogElement | null;
        dlg?.close();
        return;
      }

      // Backdrop click
      if (target.tagName === 'DIALOG' && target.classList.contains('smap-zoom')) {
        (target as HTMLDialogElement).close();
      }
    });
  }
</script>

<style is:global>
  /* All .smap*/ /* and .smap-zoom* styles are global because the
     StakeholderMap diagram body lives in a separate partial component
     (_StakeholderMapBody.astro) — Astro's scoped CSS would attach a
     different data-astro-cid attribute to elements in the partial vs.
     elements rendered here, so scoped selectors wouldn't match. All
     class names are well-namespaced (.smap__, .smap-zoom__) so the
     global rules can't leak into other components. */

  .smap {
    padding: 64px 0;
    background: var(--paper);
    border-top: 1px solid var(--line);
  }
  .smap__header {
    max-width: 760px;
    margin-bottom: 28px;
  }
  .smap .kicker {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 12px;
  }
  .smap__header h2 {
    font-family: var(--font-sans);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 12px;
    color: var(--ink);
  }
  .smap__lede {
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Tier sections ─────────────────────────────────────────────── */
  .smap__diagram {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .smap__tier {
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 18px 18px 22px;
  }
  .smap__tier--province { border-left: 4px solid #1E40AF; }
  .smap__tier--district { border-left: 4px solid #047857; }
  .smap__tier--school   { border-left: 4px solid #B45309; }
  .smap__tier--you      { border-left: 4px solid var(--accent); }

  .smap__tier-label {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 10px;
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 14px;
    letter-spacing: 0.01em;
  }
  .smap__tier-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--ink);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
  }
  .smap__tier-meta {
    font-weight: 400;
    font-size: 13px;
    font-style: italic;
  }

  /* ── Row layouts (cols stack on mobile) ────────────────────────── */
  .smap__row {
    display: grid;
    gap: 12px;
  }
  .smap__row--3col { grid-template-columns: repeat(3, 1fr); }
  .smap__row--2col { grid-template-columns: repeat(2, 1fr); }
  .smap__row--1col { grid-template-columns: 1fr; }
  @media (max-width: 900px) {
    .smap__row--3col { grid-template-columns: 1fr; }
    .smap__row--2col { grid-template-columns: 1fr; }
  }

  /* ── Box (one organization) ────────────────────────────────────── */
  .smap__box {
    position: relative;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 16px 16px 14px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .smap__box--warning  { border-color: #FCA5A5; background: #FEF6F4; }
  .smap__box--lever    { border-color: #86EFAC; background: #F0FDF4; }
  .smap__box--victim   { border-color: #FDBA74; background: #FFFAF5; }
  .smap__box--you      { border-color: var(--accent); background: var(--cream); border-width: 2px; }

  .smap__box-head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }
  .smap__icon {
    color: var(--accent);
    display: inline-flex;
    flex-shrink: 0;
  }
  .smap__box-title {
    flex: 1;
    margin: 0;
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.3;
  }
  .smap__num {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--ink);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
  }
  .smap__num--1 { background: #DC2626; }
  .smap__num--2 { background: #EA580C; }
  .smap__num--2-cont { background: #EA580C; opacity: 0.7; }
  .smap__num--3 { background: #047857; }
  .smap__num--4 { background: var(--accent); }

  .smap__metaphor {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink);
  }
  .smap__role {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-soft);
  }
  .smap__role--strong {
    font-weight: 600;
    color: var(--ink);
    font-size: 14px;
  }
  .smap__badge {
    margin: 6px 0 0;
    padding: 8px 10px;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.4;
    border-radius: var(--radius);
  }
  .smap__badge--warn  { background: #FECACA; color: #991B1B; }
  .smap__badge--lever { background: #BBF7D0; color: #14532D; }

  .smap__mla-list {
    margin: 0;
    padding-left: 16px;
    list-style: disc;
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink-soft);
  }
  .smap__mla-list li { margin-bottom: 2px; }
  .smap__star { color: #047857; font-weight: 700; }

  .smap__roles {
    margin: 4px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .smap__roles li {
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-soft);
    padding-left: 32px;
    position: relative;
  }
  .smap__roles li strong { color: var(--ink); }
  .smap__role-icon {
    position: absolute;
    left: 0;
    top: 1px;
    color: var(--accent);
    display: inline-flex;
  }

  .smap .muted, .smap-zoom .muted { color: var(--muted); }

  /* ── Story + Takeaway ──────────────────────────────────────────── */
  .smap__story {
    margin-top: 8px;
    padding: 20px 22px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
  }
  .smap__story-title {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 12px;
  }
  .smap__story-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .smap__story-list li {
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-soft);
    padding-left: 36px;
    position: relative;
  }
  .smap__story-list li strong { color: var(--ink); }
  .smap__story-num {
    position: absolute;
    left: 0;
    top: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--ink);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
  }

  .smap__takeaway {
    margin-top: 4px;
    padding: 20px 22px;
    background: var(--cream);
    border-left: 4px solid var(--accent);
    border-radius: var(--radius-md);
  }
  .smap__takeaway-text {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink);
  }

  /* ── Zoom button + dialog ──────────────────────────────────────── */
  .smap__zoom-btn {
    margin-top: 18px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: 14px;
    font-weight: 600;
    color: var(--accent);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  .smap__zoom-btn:hover,
  .smap__zoom-btn:focus-visible {
    background: var(--cream);
    border-color: var(--accent);
  }
  .smap__zoom-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  @media (max-width: 560px) {
    .smap__zoom-btn {
      width: 100%;
      justify-content: center;
      padding: 14px 16px;
      font-size: 15px;
    }
  }

  .smap-zoom {
    width: 95vw;
    max-width: 1400px;
    height: 92vh;
    max-height: 95vh;
    padding: 0;
    border: none;
    border-radius: var(--radius-lg);
    background: var(--paper);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    position: relative;
  }
  .smap-zoom::backdrop { background: rgba(0, 0, 0, 0.9); }
  .smap-zoom__close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
  }
  .smap-zoom__hint {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 11px;
    color: var(--muted);
    background: var(--paper);
    padding: 4px 12px;
    border-radius: 999px;
    border: 1px solid var(--line);
    margin: 0;
    pointer-events: none;
    white-space: nowrap;
    max-width: calc(100% - 120px);
    overflow: hidden;
    text-overflow: ellipsis;
    z-index: 1;
  }
  .smap-zoom__viewport {
    width: 100%;
    height: 100%;
    padding: 56px 24px 80px;
    box-sizing: border-box;
    overflow: hidden;
    touch-action: none;
    cursor: grab;
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }
  .smap-zoom__viewport:active { cursor: grabbing; }
  .smap-zoom__media {
    width: 100%;
    max-width: 1100px;
  }
  .smap-zoom__controls {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 4px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 4px;
    box-shadow: var(--shadow-sm);
    z-index: 2;
  }
  .smap-zoom__btn {
    width: 44px;
    height: 44px;
    border-radius: var(--radius);
    border: 1px solid transparent;
    background: transparent;
    color: var(--ink);
    font-size: 20px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .smap-zoom__btn:hover { background: var(--cream); color: var(--accent); border-color: var(--line); }
  .smap-zoom__btn:active { background: var(--accent); color: #fff; border-color: var(--accent); }

  /* Mobile fullscreen lightbox */
  @media (max-width: 560px) {
    .smap-zoom {
      position: fixed;
      inset: 0;
      width: 100vw;
      max-width: 100vw;
      height: 100vh;
      max-height: 100vh;
      height: 100dvh;
      max-height: 100dvh;
      border-radius: 0;
      margin: 0;
    }
    .smap-zoom__viewport { padding: 60px 12px 80px; }
  }

  /* Lock background page scroll while the zoom dialog is open. */
  body:has(dialog.smap-zoom[open]) {
    overflow: hidden;
  }
</style>
