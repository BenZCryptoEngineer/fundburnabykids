---
// Persona selector — three cards (Parent / PAC / Trustee) above an
// inline expand panel. Click a card → that persona's panel opens with
// 2 tailored SVG visualizations + CTA. Click the same card → close.
//
// Pattern: source HTML behavior, rebuilt as Astro components.
// Per UX research, scroll-snap was suggested as alternative; chose
// inline-expand for closer fidelity to the source's interaction model.
// Future iteration can switch to scroll-snap if data shows worse engagement.

import { getEntry } from 'astro:content';
import I18nText from '~/components/I18nText.astro';
import SvgVisual from '~/components/SvgVisual.astro';
import { t, localizedUrl } from '~/lib/i18n';
import type { Lang } from '~/lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const personasEntry = await getEntry('campaign', 'personas');
const data = personasEntry?.data as any;

type Persona = {
  id: string;
  icon: string;
  title: { en: string; zh: string };
  visualizations: string[];
  cta_primary: { label: { en: string; zh: string }; target: string };
  cta_secondary: { label: { en: string; zh: string }; target: string };
};

type VisMeta = {
  kicker: { en: string; zh: string };
  head: { en: string; zh: string };
  take: { en: string; zh: string };
};

const personas: Persona[] = data?.personas ?? [];
const visMeta: Record<string, VisMeta> = data?.visualizations_meta ?? {};

function ctaHref(target: string): string {
  if (target.startsWith('http') || target.startsWith('mailto:')) return target;
  if (target.startsWith('#')) return localizedUrl(target.slice(0), lang);
  return target;
}
---

<section class="personas" id="your-angle">
  <div class="wrap-wide">
    <header class="personas__header">
      <p class="kicker sans">
        <I18nText
          en="Find your angle"
          zh="找你的切入点"
          lang={lang}
        />
      </p>
      <h2>
        <I18nText
          en="Three short paths into the same case."
          zh="进入同一份证据的三条短路径。"
          lang={lang}
        />
      </h2>
    </header>

    {/* Helper bar — escape hatch for parents who feel lost about the
        institutional vocabulary (BCPSEA, DPAC, Treasury Board, MLA).
        Clicking opens the StakeholderMap dialog (rendered separately
        via <StakeholderMap />). The dialog ID 'stakeholder-zoom' is
        the stable identifier — see StakeholderMap.astro for matching
        side. */}
    <button
      type="button"
      class="personas__helper sans"
      data-smap-zoom-open="stakeholder-zoom"
    >
      <span class="personas__helper-icon" aria-hidden="true">🤔</span>
      <span class="personas__helper-text">
        <strong>
          <I18nText
            en="Confused by the names?"
            zh="对这些机构名词感到陌生？"
            lang={lang}
          />
        </strong>
        <span>
          <I18nText
            en="BCPSEA, DPAC, PAC, SD41, Treasury Board, MLA — what each one actually does, in plain language. ~1 minute read."
            zh="BCPSEA、DPAC、PAC、SD41、Treasury Board、MLA — 每个机构到底在做什么，用大白话讲清楚。约 1 分钟。"
            lang={lang}
          />
        </span>
      </span>
      <span class="personas__helper-chevron" aria-hidden="true">→</span>
    </button>

    <div class="personas__cards" role="tablist">
      {personas.map((p, idx) => (
        <button
          class="persona-card"
          role="tab"
          type="button"
          data-persona={p.id}
          data-default-active={idx === 0 ? 'true' : 'false'}
          aria-controls={`persona-panel-${p.id}`}
          aria-selected={idx === 0 ? 'true' : 'false'}
        >
          <span class="persona-card__icon" aria-hidden="true">{p.icon}</span>
          <span class="persona-card__title">{t(p.title, lang)}</span>
          <span class="persona-card__chevron" aria-hidden="true">→</span>
        </button>
      ))}
    </div>

    <div class="personas__panels">
      {personas.map((p, idx) => (
        <div
          class="persona-panel"
          id={`persona-panel-${p.id}`}
          data-panel={p.id}
          role="tabpanel"
          aria-hidden={idx === 0 ? 'false' : 'true'}
          hidden={idx !== 0}
        >
          <div class="persona-panel__visuals">
            {p.visualizations.map((visKey) => {
              const meta = visMeta[visKey];
              return (
                <SvgVisual
                  visual={visKey as 'cascade' | 'money' | 'scale' | 'responsibility'}
                  lang={lang}
                  kicker={meta?.kicker ? t(meta.kicker, lang) : undefined}
                  headline={meta?.head ? t(meta.head, lang) : undefined}
                  takeaway={meta?.take ? t(meta.take, lang) : undefined}
                />
              );
            })}
          </div>

          <div class="persona-panel__cta">
            <a class="btn btn--primary" href={ctaHref(p.cta_primary.target)}>
              {t(p.cta_primary.label, lang)}
            </a>
            <a class="btn btn--ghost" href={ctaHref(p.cta_secondary.target)}>
              {t(p.cta_secondary.label, lang)}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.persona-card');
  const panels = document.querySelectorAll<HTMLElement>('.persona-panel');

  function activate(id: string) {
    cards.forEach((c) => {
      const active = c.dataset.persona === id;
      c.classList.toggle('persona-card--active', active);
      c.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    panels.forEach((p) => {
      const active = p.dataset.panel === id;
      p.hidden = !active;
      p.setAttribute('aria-hidden', active ? 'false' : 'true');
    });
  }

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const id = card.dataset.persona;
      if (!id) return;
      // Toggle behavior: clicking the active card closes the section
      const isActive = card.classList.contains('persona-card--active');
      if (isActive) {
        card.classList.remove('persona-card--active');
        card.setAttribute('aria-selected', 'false');
        panels.forEach((p) => {
          if (p.dataset.panel === id) {
            p.hidden = true;
            p.setAttribute('aria-hidden', 'true');
          }
        });
      } else {
        activate(id);
      }
    });
  });

  // Allow deep-linking via ?persona=parent
  const url = new URL(window.location.href);
  const wanted = url.searchParams.get('persona');
  if (wanted) activate(wanted);
</script>

<style>
  .personas {
    padding: 64px 0;
    background: var(--cream);
    border-top: 1px solid var(--line);
  }
  .personas__header {
    margin-bottom: 32px;
    max-width: 640px;
  }
  .kicker {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 12px;
  }
  .personas__header h2 {
    font-family: var(--font-sans);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    color: var(--ink);
  }
  /* Helper bar — full-width clickable that opens the StakeholderMap
     civics dialog. Sits between the header and the persona cards so
     it's seen by people who'd otherwise bounce off the persona names
     too. Visually distinct from the cards (dashed border, accent
     color) so it reads as a help link, not a 4th persona. */
  .personas__helper {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    margin-bottom: 24px;
    background: var(--paper);
    border: 1px dashed var(--accent);
    border-radius: var(--radius-md);
    /* Sans-serif to match the persona cards below (which explicitly
       set --font-sans). Without this the helper bar inherits body's
       serif, creating a visual mismatch with the cards next to it. */
    font-family: var(--font-sans);
    text-align: left;
    cursor: pointer;
    color: var(--ink);
    transition: background 0.15s, border-style 0.15s;
  }
  .personas__helper:hover,
  .personas__helper:focus-visible {
    background: var(--cream);
    border-style: solid;
  }
  .personas__helper:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .personas__helper-icon {
    font-size: 24px;
    line-height: 1;
    flex-shrink: 0;
  }
  .personas__helper-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-size: 13px;
    line-height: 1.45;
    color: var(--ink-soft);
  }
  .personas__helper-text strong {
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
  }
  .personas__helper-chevron {
    font-size: 18px;
    color: var(--accent);
    flex-shrink: 0;
  }
  @media (max-width: 560px) {
    .personas__helper { padding: 12px 14px; gap: 10px; }
    .personas__helper-text { font-size: 12.5px; }
  }

  .personas__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }
  @media (max-width: 720px) {
    .personas__cards { grid-template-columns: 1fr; }
  }
  .persona-card {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 16px 20px;
    text-align: left;
    cursor: pointer;
    font-family: var(--font-sans);
    transition: border-color 0.15s, transform 0.1s;
    color: var(--ink);
  }
  .persona-card:hover {
    border-color: var(--accent);
  }
  .persona-card--active {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }
  .persona-card--active .persona-card__chevron {
    transform: rotate(90deg);
  }
  .persona-card__icon {
    font-size: 28px;
    line-height: 1;
    flex-shrink: 0;
  }
  .persona-card__title {
    flex: 1;
    font-size: 15px;
    font-weight: 600;
    line-height: 1.3;
  }
  .persona-card__chevron {
    color: var(--muted);
    font-size: 18px;
    transition: transform 0.2s;
  }
  .persona-card--active .persona-card__chevron {
    color: rgba(255, 255, 255, 0.85);
  }

  .personas__panels {
    margin-top: 8px;
  }
  .persona-panel {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 32px;
    margin-bottom: 16px;
  }
  .persona-panel__visuals {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }
  @media (max-width: 720px) {
    .persona-panel__visuals { grid-template-columns: 1fr; }
  }
  .persona-panel__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }

  /* Local button overrides if Hero's btn classes not in scope here */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 20px;
    border-radius: var(--radius-md);
    border: 2px solid transparent;
    font-family: var(--font-sans);
    font-weight: 600;
    text-decoration: none;
    font-size: 15px;
    transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.1s;
    cursor: pointer;
  }
  .btn--primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }
  .btn--primary:hover {
    background: var(--accent-deep);
    border-color: var(--accent-deep);
    color: #fff;
    transform: translateY(-1px);
  }
  .btn--ghost {
    background: transparent;
    color: var(--accent);
    border-color: var(--line);
  }
  .btn--ghost:hover {
    border-color: var(--accent);
  }
</style>
