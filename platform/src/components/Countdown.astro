---
// Live countdown to budget adoption (May 27, 2026 Pacific Time).
// Server renders initial value at build; client-side JS updates every minute.
//
// At zero, switches to "Budget adopted" — the campaign timeline ends.

import I18nText from '~/components/I18nText.astro';
import type { Lang } from '~/lib/i18n';

interface Props {
  /** ISO date in Pacific Time (with offset) */
  deadline: string;
  lang: Lang;
}

const { deadline, lang } = Astro.props;

const target = new Date(deadline);
const now = new Date();
const ms = target.getTime() - now.getTime();
const expired = ms <= 0;

let initialLabel = '';
if (expired) {
  initialLabel = lang === 'zh' ? '预算已通过' : 'Budget adopted';
} else {
  const days = Math.floor(ms / 86400000);
  const hours = Math.floor((ms % 86400000) / 3600000);
  if (days > 1) {
    initialLabel = lang === 'zh' ? `${days} 天` : `${days} days`;
  } else if (days === 1) {
    initialLabel = lang === 'zh' ? `1 天 ${hours} 小时` : `1 day, ${hours} hours`;
  } else {
    initialLabel = lang === 'zh' ? `${hours} 小时` : `${hours} hours`;
  }
}
---

<span class="countdown" data-deadline={deadline} data-lang={lang}>
  <span class="countdown__dot" aria-hidden="true"></span>
  <span class="countdown__text tabular">{initialLabel}</span>
  <span class="countdown__suffix">
    <I18nText
      en="until budget adoption"
      zh="至预算通过日"
      lang={lang}
    />
  </span>
</span>

<script>
  document.querySelectorAll<HTMLElement>('.countdown').forEach((el) => {
    const deadline = el.dataset.deadline;
    const lang = el.dataset.lang as 'en' | 'zh';
    if (!deadline) return;
    const target = new Date(deadline);

    function update() {
      const ms = target.getTime() - Date.now();
      const textEl = el.querySelector('.countdown__text');
      if (!textEl) return;
      if (ms <= 0) {
        textEl.textContent = lang === 'zh' ? '预算已通过' : 'Budget adopted';
        el.classList.add('countdown--expired');
        return;
      }
      const days = Math.floor(ms / 86400000);
      const hours = Math.floor((ms % 86400000) / 3600000);
      if (days > 1) {
        textEl.textContent = lang === 'zh' ? `${days} 天` : `${days} days`;
      } else if (days === 1) {
        textEl.textContent = lang === 'zh' ? `1 天 ${hours} 小时` : `1 day, ${hours} hours`;
      } else {
        textEl.textContent = lang === 'zh' ? `${hours} 小时` : `${hours} hours`;
      }
    }
    update();
    setInterval(update, 60_000);
  });
</script>

<style>
  .countdown {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--warm-soft);
    color: var(--warm);
    padding: 6px 14px;
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .countdown__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--warm);
    animation: countdown-pulse 1.6s ease-in-out infinite;
  }
  .countdown__suffix {
    color: var(--warm);
    opacity: 0.85;
    font-weight: 500;
  }
  .countdown--expired {
    background: var(--line-soft);
    color: var(--ink-soft);
  }
  .countdown--expired .countdown__dot {
    background: var(--ink-soft);
    animation: none;
  }
  @keyframes countdown-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  @media (prefers-reduced-motion: reduce) {
    .countdown__dot { animation: none; }
  }
</style>
