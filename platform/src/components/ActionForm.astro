---
// The signature + send form. POSTs to Netlify Forms; Netlify webhook
// fires the on-signature Function which writes Supabase + sends the
// transactional confirmation email via Resend.
//
// Per UX research: live "public listing preview" calms privacy fears.
// Per PRD §9.1: data-netlify + bot-field honeypot + form-name hidden.
// Per VISUAL_DESIGN: Turnstile loaded server-side rendered, widget
// hydrated client-side.

import { getEntry } from 'astro:content';
import I18nText from '~/components/I18nText.astro';
import { t, localizedUrl } from '~/lib/i18n';
import type { Lang } from '~/lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const schools = (await getEntry('campaign', 'schools'))?.data as any;
const letter = (await getEntry('campaign', 'letter'))?.data as any;
const mlas = (await getEntry('campaign', 'mlas'))?.data?.mlas as Array<any> ?? [];

// Flatten the school list for the school → neighbourhood help dialog and
// for the dropdown render. Each school is `{ name, neighbourhood }` after
// the v0.3 schema migration in schools.yaml.
type SchoolEntry = { name: string; neighbourhood: string };
const schoolGroups: Array<{ groupKey: 'elementary' | 'secondary' | 'other'; labelEn: string; labelZh: string; items: SchoolEntry[] }> = [
  { groupKey: 'elementary', labelEn: 'Elementary', labelZh: '小学', items: schools?.elementary ?? [] },
  { groupKey: 'secondary',  labelEn: 'Secondary',  labelZh: '中学', items: schools?.secondary ?? [] },
  { groupKey: 'other',      labelEn: 'Other',      labelZh: '其它', items: schools?.other ?? [] },
];

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const subjectEn = letter?.subject?.en ?? '';
const bodyTemplateEn = letter?.body_template_en ?? '';

// Build recipient list for mailto: TO and CC
const recipientsTo = mlas.filter((m) => m.recipient_role === 'to').map((m) => m.email);
const recipientsCc = mlas.filter((m) => m.recipient_role === 'cc').map((m) => m.email);

// Encode for safe embedding as data attribute
const dataMailto = JSON.stringify({
  subject: subjectEn,
  body: bodyTemplateEn,
  to: recipientsTo,
  cc: recipientsCc,
});
---

<section class="action-form-section" id="act">
  <div class="wrap">
    <header class="action-form-header">
      <p class="kicker sans">
        <I18nText
          en="Take action — 60 seconds"
          zh="行动 — 60 秒"
          lang={lang}
        />
      </p>
      <h2>
        <I18nText
          en="Sign the petition. Send the pre-filled email. Both go to MLAs together."
          zh="签署请愿。发送预填邮件。两个一起送到 MLA。"
          lang={lang}
        />
      </h2>
    </header>

    {/* Live public-listing preview */}
    <div class="public-preview-card">
      <p class="public-preview-label sans">
        <I18nText
          en="↓ This is what appears publicly. Your full name, email, and exact postal code stay private."
          zh="↓ 公开后这就是大家看到的。你的全名、邮箱、完整邮编不公开。"
          lang={lang}
        />
      </p>
      <div class="public-preview" id="public-preview">
        <span class="preview-name">
          <I18nText en="Your Name" zh="你的名字" lang={lang} />
        </span>
        <span class="preview-meta">
          <I18nText en="Your School · Your Neighbourhood" zh="你的学校 · 你的街区" lang={lang} />
        </span>
      </div>
    </div>

    <form
      class="action-form"
      name="signature"
      method="POST"
      action={localizedUrl('/confirm-thanks', lang)}
      data-netlify="true"
      netlify-honeypot="bot-field"
      data-mailto={dataMailto}
    >
      <input type="hidden" name="form-name" value="signature" />
      <input type="hidden" name="locale" value={lang} />
      <p class="hidden" aria-hidden="true">
        <label>
          <I18nText en="Don't fill this:" zh="不要填这个：" lang={lang} />
          <input name="bot-field" />
        </label>
      </p>

      <div class="form-row form-row--two">
        <div class="field">
          <label for="firstname">
            <I18nText en="First name" zh="名" lang={lang} />
          </label>
          <input type="text" name="firstname" id="firstname" required maxlength="40" autocomplete="given-name" />
        </div>
        <div class="field">
          <label for="lastname">
            <I18nText en="Last name" zh="姓" lang={lang} />
          </label>
          <input type="text" name="lastname" id="lastname" required maxlength="40" autocomplete="family-name" />
        </div>
      </div>

      <div class="field">
        <label for="email">
          <I18nText en="Email" zh="邮箱" lang={lang} />
        </label>
        <input type="email" name="email" id="email" required maxlength="254" autocomplete="email" />
        <p class="hint">
          <I18nText
            en="One confirmation email comes here. Updates only if you opt in below."
            zh="一封确认邮件会发到这里。后续更新只在你勾选订阅时才发。"
            lang={lang}
          />
        </p>
      </div>

      <div class="form-row form-row--two">
        <div class="field">
          <label for="school" class="field-label-with-help">
            <I18nText en="Your child's school" zh="孩子的学校" lang={lang} />
            <button
              type="button"
              class="help-icon"
              data-open-modal="school-neighbourhood-help"
              aria-label={lang === 'zh' ? '查看学校与街区的对应表' : 'View school → neighbourhood mapping'}
            >?</button>
          </label>
          <select name="school" id="school" required data-school-select>
            <option value="" data-neighbourhood="">— {t({en: 'select', zh: '选择'}, lang)} —</option>
            {schoolGroups.map((group) => group.items.length > 0 && (
              <optgroup label={lang === 'zh' ? group.labelZh : group.labelEn}>
                {group.items.map((s) => (
                  <option value={s.name} data-neighbourhood={s.neighbourhood}>{s.name}</option>
                ))}
              </optgroup>
            ))}
          </select>
          <p class="hint" data-school-hint hidden>
            <I18nText en="Neighbourhood: " zh="街区：" lang={lang} />
            <strong data-school-hint-value></strong>
          </p>
          {/* Hidden form field — populated by JS from the selected school's
              data-neighbourhood. on-signature.ts derives the canonical value
              from its own SCHOOL_NEIGHBOURHOODS table (don't trust client),
              but submitting it lets us cross-check + flag mismatches in logs. */}
          <input type="hidden" name="school_neighbourhood" data-school-neighbourhood-input value="" />
        </div>
        <div class="field">
          <label for="grade">
            <I18nText en="Grade" zh="年级" lang={lang} />
          </label>
          <select name="grade" id="grade" required>
            <option value="">— {t({en: 'select', zh: '选择'}, lang)} —</option>
            <option value="K">K</option>
            {Array.from({length: 12}, (_, i) => i + 1).map((n) => <option value={String(n)}>{n}</option>)}
            <option value="multiple">{lang === 'zh' ? '多个孩子' : 'Multiple children'}</option>
            <option value="future">{lang === 'zh' ? '未来入学' : 'Future student'}</option>
          </select>
        </div>
      </div>

      <div class="field">
        <label for="postal">
          <I18nText en="Postal code" zh="邮编" lang={lang} />
        </label>
        <input
          type="text"
          name="postal"
          id="postal"
          required
          pattern="^[Vv][0-9][A-Za-z]\s?[0-9][A-Za-z][0-9]$"
          placeholder="V5C 5W6"
          autocomplete="postal-code"
          maxlength="7"
          inputmode="text"
          autocapitalize="characters"
          spellcheck="false"
          data-postal-input
        />
        <p class="hint">
          <I18nText
            en="Used to map you to your provincial MLA's riding for the riding map. Full code never displayed publicly."
            zh="用于将你的签名归到对应省级 MLA 选区（地图用）。完整邮编从不公开。"
            lang={lang}
          />
        </p>
      </div>

      <fieldset class="consents">
        <legend class="sr-only">
          <I18nText en="Consents" zh="同意项" lang={lang} />
        </legend>

        <label class="consent">
          <input type="checkbox" name="consent-public" required />
          <span>
            <strong>
              <I18nText
                en="Display my first name + last initial + school + neighbourhood publicly"
                zh="同意公开显示我的名 + 姓首字母 + 学校 + 街区"
                lang={lang}
              />
            </strong>
            <span class="consent-required">
              {' '}
              <I18nText en="(required to count)" zh="（必选 — 否则签名不计入）" lang={lang} />
            </span>
          </span>
        </label>

        <label class="consent">
          <input type="checkbox" name="consent-updates" />
          <span>
            <I18nText
              en="Send me updates (~once every 2 weeks until campaign closes). One-click unsubscribe in every email."
              zh="发送更新邮件给我（约 2 周一封，直到活动结束）。每封邮件一键退订。"
              lang={lang}
            />
          </span>
        </label>

        <label class="consent">
          <input type="checkbox" name="consent-letter" checked />
          <span>
            <I18nText
              en="Also open a pre-filled email to my MLA + the Education Minister when I submit."
              zh="提交时同时打开一封预填给我 MLA 和教育部长的邮件。"
              lang={lang}
            />
          </span>
        </label>
      </fieldset>

      {turnstileSiteKey && (
        <div class="turnstile-wrap">
          <div class="cf-turnstile" data-sitekey={turnstileSiteKey}></div>
        </div>
      )}

      <button type="submit" class="btn btn--primary btn--lg btn--block">
        <I18nText
          en="Sign — and send your email →"
          zh="签名 — 并发送邮件 →"
          lang={lang}
        />
      </button>

      <p class="form-footer-note muted">
        <I18nText
          en="By submitting you confirm you've read our"
          zh="提交即表示你阅读了我们的"
          lang={lang}
        />{' '}
        <a href={localizedUrl('/privacy', lang)}>
          <I18nText en="privacy policy" zh="隐私政策" lang={lang} />
        </a>.
      </p>
    </form>
  </div>
</section>

{/* School → neighbourhood transparency dialog. Opened by the "?" button
    next to the school field. PAC / parents can scan the table and flag
    wrong rows back to us so the mapping improves over time. */}
<dialog class="school-help-modal" id="school-neighbourhood-help" aria-labelledby="school-neighbourhood-help-title">
  <div class="school-help-modal__inner">
    <header class="school-help-modal__header">
      <h2 id="school-neighbourhood-help-title">
        <I18nText
          en="School → neighbourhood mapping"
          zh="学校与街区对照表"
          lang={lang}
        />
      </h2>
      <button class="school-help-modal__close" type="button" data-close-modal aria-label="Close">×</button>
    </header>
    <div class="school-help-modal__body">
      <p class="school-help-modal__lede">
        <I18nText
          en="The neighbourhood shown next to your name comes from your child's school, not your postal code (postal-code FSAs cross neighbourhood boundaries — V5B alone covers Capitol Hill, Brentwood, and Burnaby Heights). If a row below looks wrong, email"
          zh="你姓名旁显示的街区来自孩子的学校，不是邮编（邮编 FSA 会跨街区——V5B 同时覆盖 Capitol Hill、Brentwood、Burnaby Heights）。如果下面有任何对应错误，请来信"
          lang={lang}
        />{' '}
        <a href="mailto:hello@fundburnabykids.ca?subject=School%20mapping%20correction">hello@fundburnabykids.ca</a>{' '}
        <I18nText en="and we'll fix it." zh="，我们会修正。" lang={lang} />
      </p>
      <table class="school-help-modal__table">
        <thead>
          <tr>
            <th><I18nText en="School" zh="学校" lang={lang} /></th>
            <th><I18nText en="Neighbourhood" zh="街区" lang={lang} /></th>
          </tr>
        </thead>
        <tbody>
          {schoolGroups.map((group) => group.items.length > 0 && (
            <>
              <tr class="school-help-modal__group">
                <td colspan="2">{lang === 'zh' ? group.labelZh : group.labelEn}</td>
              </tr>
              {group.items.map((s) => (
                <tr>
                  <td>{s.name}</td>
                  <td class="school-help-modal__nb">{s.neighbourhood}</td>
                </tr>
              ))}
            </>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</dialog>

{turnstileSiteKey && (
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<script>
  (function () {
    const formEl = document.querySelector<HTMLFormElement>('form.action-form');
    if (!formEl) return;
    const form: HTMLFormElement = formEl;

    const previewName = form.parentElement?.querySelector<HTMLElement>('.preview-name');
    const previewMeta = form.parentElement?.querySelector<HTMLElement>('.preview-meta');

    const schoolSelect = form.querySelector<HTMLSelectElement>('[data-school-select]');
    const schoolHint = form.querySelector<HTMLElement>('[data-school-hint]');
    const schoolHintValue = form.querySelector<HTMLElement>('[data-school-hint-value]');
    const schoolNeighInput = form.querySelector<HTMLInputElement>('[data-school-neighbourhood-input]');

    function selectedNeighbourhood(): string {
      if (!schoolSelect) return '';
      const opt = schoolSelect.options[schoolSelect.selectedIndex];
      return opt?.dataset.neighbourhood ?? '';
    }

    function updatePreview() {
      const fn = (form.elements.namedItem('firstname') as HTMLInputElement | null)?.value.trim() || 'Your name';
      const ln = (form.elements.namedItem('lastname') as HTMLInputElement | null)?.value.trim() || '';
      const initial = ln ? ln[0].toUpperCase() + '.' : '';
      const sch = (form.elements.namedItem('school') as HTMLSelectElement | null)?.value || 'Your school';
      const neigh = selectedNeighbourhood() || 'Your neighbourhood';

      // Update the inline hint under the school dropdown so the user can
      // verify the derived neighbourhood the moment they pick a school.
      if (schoolNeighInput) schoolNeighInput.value = selectedNeighbourhood();
      if (schoolHint && schoolHintValue) {
        if (selectedNeighbourhood()) {
          schoolHintValue.textContent = selectedNeighbourhood();
          schoolHint.hidden = false;
        } else {
          schoolHint.hidden = true;
        }
      }

      if (previewName) previewName.textContent = `${fn}${initial ? ' ' + initial : ''}`;
      if (previewMeta) previewMeta.textContent = `${sch} · ${neigh}`;
    }

    form.addEventListener('input', updatePreview);
    form.addEventListener('change', updatePreview);
    updatePreview();

    // Postal code normalization: on every keystroke, trim whitespace and
    // uppercase. Mobile keyboards autocapitalize the first letter only,
    // so users typically end up with "V5b 3x6" — we accept either case
    // in the pattern, but normalizing here makes the submitted value
    // canonical for the FSA → riding lookup in netlify/functions/_shared.ts.
    const postalEl = form.querySelector<HTMLInputElement>('[data-postal-input]');
    if (postalEl) {
      postalEl.addEventListener('input', () => {
        const raw = postalEl.value;
        const cleaned = raw.toUpperCase().replace(/^\s+|\s+$/g, '');
        if (cleaned !== raw) {
          // Preserve caret roughly: setting value moves caret to end,
          // which is the right behaviour as users type left-to-right.
          postalEl.value = cleaned;
        }
      });
    }

    // Close the school-help dialog when the user clicks the dim backdrop
    // (PacKitModal's global handler only matches dialog.pac-modal).
    document.querySelectorAll<HTMLDialogElement>('dialog.school-help-modal').forEach((dlg) => {
      dlg.addEventListener('click', (e) => {
        if (e.target === dlg) dlg.close();
      });
    });

    // On submit: build the mailto URL and STASH it in sessionStorage so
    // /confirm-thanks can render it as a real anchor for the user to click.
    //
    // Earlier revisions called window.open('mailto:...') during submit.
    // Browsers without a registered mailto: handler (Chrome on a fresh
    // profile is the common case) treat that as a current-tab navigation
    // to the mailto: URL — the form's POST is cancelled, the user lands
    // on a blank "mailto:..." page, and the signature is never recorded.
    //
    // Stashing instead means: form POST → Netlify Forms → /confirm-thanks
    // happens cleanly, and the email opens on user gesture from a real
    // <a href="mailto:..."> anchor on that page.
    form.addEventListener('submit', () => {
      const sendLetter = (form.elements.namedItem('consent-letter') as HTMLInputElement | null)?.checked;
      // Always clear stale data, even if user UNCHECKED the letter consent
      // — otherwise a previous submission's mailto would resurface.
      try { sessionStorage.removeItem('fbk_mailto'); } catch { /* private mode */ }
      if (!sendLetter) return;

      const mailtoData = form.dataset.mailto;
      if (!mailtoData) return;
      try {
        const m = JSON.parse(mailtoData) as { subject: string; body: string; to: string[]; cc: string[] };
        const fn = (form.elements.namedItem('firstname') as HTMLInputElement).value.trim();
        const ln = (form.elements.namedItem('lastname') as HTMLInputElement).value.trim();
        const sch = (form.elements.namedItem('school') as HTMLSelectElement).value;
        const grade = (form.elements.namedItem('grade') as HTMLSelectElement).value;
        const postal = (form.elements.namedItem('postal') as HTMLInputElement).value;
        const body = m.body
          .replace(/\{FIRST\}/g, fn)
          .replace(/\{LAST\}/g, ln)
          .replace(/\{SCHOOL\}/g, sch)
          .replace(/\{GRADE\}/g, grade)
          .replace(/\{POSTAL\}/g, postal);
        const url =
          `mailto:${encodeURIComponent(m.to.join(','))}` +
          `?cc=${encodeURIComponent(m.cc.join(','))}` +
          `&subject=${encodeURIComponent(m.subject)}` +
          `&body=${encodeURIComponent(body)}`;
        try {
          sessionStorage.setItem('fbk_mailto', url);
        } catch {
          // sessionStorage unavailable (private mode, etc.) — silent fail.
          // /confirm-thanks will simply not render the button; user can
          // still send manually from the email template on the page.
        }
      } catch (err) {
        console.error('mailto build failed:', err);
      }
    });
  })();
</script>

<style>
  .action-form-section {
    padding: 64px 0;
    background: var(--paper);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .action-form-header {
    margin-bottom: 32px;
  }
  .kicker {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 12px;
  }
  .action-form-header h2 {
    font-family: var(--font-sans);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    color: var(--ink);
  }

  /* Live preview card */
  .public-preview-card {
    background: var(--cream);
    border: 1px dashed var(--line);
    border-radius: var(--radius-md);
    padding: 16px 20px;
    margin-bottom: 24px;
  }
  .public-preview-label {
    font-size: 12px;
    color: var(--muted);
    margin: 0 0 8px;
  }
  .public-preview {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .preview-name {
    font-family: var(--font-sans);
    font-weight: 600;
    color: var(--ink);
    font-size: 16px;
  }
  .preview-meta {
    font-size: 14px;
    color: var(--muted);
  }

  /* Form */
  .action-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .form-row {
    display: grid;
    gap: 20px;
  }
  .form-row--two {
    grid-template-columns: 1fr 1fr;
  }
  @media (max-width: 560px) {
    .form-row--two { grid-template-columns: 1fr; }
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .field label {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
  }
  .field input,
  .field select {
    font-family: inherit;
    font-size: 16px;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
    color: var(--ink);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .field input:focus,
  .field select:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(28, 63, 143, 0.15);
  }
  /* Postal code: visually uppercase as user types so they see the
     normalized form. Actual value is also normalized via JS on input
     so the submitted form data is canonical. */
  #postal {
    text-transform: uppercase;
  }
  .hint {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--muted);
    margin: 0;
    line-height: 1.4;
  }

  /* Consents */
  .consents {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 16px 20px;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .consent {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    cursor: pointer;
    font-size: 14px;
    line-height: 1.5;
  }
  .consent input[type="checkbox"] {
    width: 18px;
    height: 18px;
    margin-top: 2px;
    flex-shrink: 0;
  }
  .consent-required {
    color: var(--warm);
    font-weight: 600;
    font-size: 12px;
  }

  /* Turnstile */
  .turnstile-wrap {
    display: flex;
    justify-content: center;
    margin: 8px 0;
  }

  /* Submit */
  .btn--block {
    width: 100%;
    font-size: 18px;
    padding: 16px;
  }

  .form-footer-note {
    font-family: var(--font-sans);
    font-size: 12px;
    text-align: center;
    margin: 0;
  }

  .hidden { display: none; }

  /* School field — help icon and inline neighbourhood echo. */
  .field-label-with-help {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .help-icon {
    background: var(--cream);
    border: 1px solid var(--line);
    color: var(--accent);
    width: 18px;
    height: 18px;
    border-radius: 50%;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    padding: 0;
    display: inline-grid;
    place-items: center;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .help-icon:hover,
  .help-icon:focus-visible {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    outline: none;
  }
  [data-school-hint] {
    margin-top: 4px;
  }
  [data-school-hint] strong { color: var(--accent); }

  /* School → neighbourhood help dialog. */
  .school-help-modal {
    width: min(560px, calc(100vw - 32px));
    max-height: calc(100vh - 64px);
    padding: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--paper);
    box-shadow: var(--shadow-lg);
  }
