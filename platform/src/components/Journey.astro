---
// Grade-by-grade impact heatmap. 10 services × 13 grades grid.
// Click a grade column header → highlights that column + renders an
// impact summary card below ("A student in Grade X loses these
// services...").
//
// State colors per VISUAL_DESIGN.md:
//   have → success green        service available
//   lost → grey + dashed border  already cut in 25-26
//   risk → orange diagonal       at risk if 26-27 underfunded
//   gone → red                   likely eliminated outright

import { getEntry } from 'astro:content';
import { t } from '~/lib/i18n';
import I18nText from '~/components/I18nText.astro';
import type { Lang } from '~/lib/i18n';
import { OUTCOME_REACHED } from '~/lib/outcome';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const journeyEntry = await getEntry('campaign', 'journey');
const data = journeyEntry?.data as any;

type Grade = { id: string; label: string };
type GradeCell = { state: 'have' | 'lost' | 'risk' | 'gone'; tip?: { en: string; zh?: string } };
type Service = {
  id: string;
  name: { en: string; zh: string };
  note?: { en: string; zh: string };
  grades: Record<string, GradeCell>;
};

const grades: Grade[] = data?.grades ?? [];
const services: Service[] = data?.services ?? [];

// Pre-serialize the data we need on the client for impact summary
const clientData = {
  lang,
  grades,
  services: services.map((s) => ({
    id: s.id,
    name: t(s.name, lang),
    note: s.note ? t(s.note, lang) : '',
    grades: Object.fromEntries(
      Object.entries(s.grades).map(([gid, cell]: [string, any]) => [
        gid,
        { state: cell.state, tip: cell.tip ? t(cell.tip, lang) : '' },
      ])
    ),
  })),
};
---

<section class="journey" id="journey">
  <div class="wrap-wide">
    <header class="journey__header">
      <p class="kicker sans">
        <I18nText
          en="Pick your child's grade"
          zh="选择孩子的年级"
          lang={lang}
        />
      </p>
      <h2>
        <I18nText
          en="What this looks like for your child."
          zh="对你孩子而言意味着什么。"
          lang={lang}
        />
      </h2>
      <p class="journey__lede">
        <I18nText
          en="Each row is a service. Each column is a grade. Pick your child's grade below to see exactly what they lose."
          zh="每一行是一项服务。每一列是一个年级。在下方选择孩子的年级，看 ta 具体失去了什么。"
          lang={lang}
        />
      </p>
    </header>

    {/* Desktop grade selector bar — explicit affordance per Prompt 03.
        Mobile uses .journey-mobile__grade-grid (different layout, also
        wired to the same renderSummary call). The "Click a column
        header" hint copy is removed since the bar makes the picker
        discoverable on its own. */}
    <div class="journey__selector-bar sans" data-journey-selector>
      <span class="journey__selector-prompt">
        <I18nText en="My child is in:" zh="我的孩子在：" lang={lang} />
      </span>
      <div class="journey__selector-buttons" role="group" aria-label={lang === 'zh' ? '选择年级' : 'Select grade'}>
        {grades.map((g) => (
          <button
            type="button"
            class="journey__selector-btn"
            data-pick-grade={g.id}
            aria-pressed="false"
          >{g.label}</button>
        ))}
        <button
          type="button"
          class="journey__selector-btn journey__selector-btn--all"
          data-pick-grade-clear
          aria-pressed="true"
        >
          <I18nText en="Show all" zh="全部" lang={lang} />
        </button>
      </div>
    </div>

    <div class="journey__legend sans">
      <span class="legend-item"><span class="legend-cell legend-cell--have"></span><I18nText en="Currently available (after last year's cuts)" zh="目前还在（去年砍剩的）" lang={lang} /></span>
      <span class="legend-item"><span class="legend-cell legend-cell--lost"></span><I18nText en="Already cut last year" zh="去年已被削减" lang={lang} /></span>
      <span class="legend-item"><span class="legend-cell legend-cell--risk"></span><I18nText en="At risk if not funded" zh="若未拨款则有风险" lang={lang} /></span>
      <span class="legend-item"><span class="legend-cell legend-cell--gone"></span><I18nText en="Eliminated or near-zero" zh="已取消或趋近于零" lang={lang} /></span>
    </div>

    <div class="journey__scroll-hint sans" aria-hidden="true">
      <I18nText en="← swipe to scan all grades →" zh="← 左右滑动查看全部年级 →" lang={lang} />
    </div>

    {/* ─── Mobile-only personalized impact view ──────────────────────
        Phones get a different presentation than desktop. The 13-grade
        table on a 360px viewport is unreadable; horizontal scroll
        kills the at-a-glance pattern that makes the table valuable.
        Mobile users get: pick your grade → see exactly what your
        child loses, in three colour-coded sections. Per Prompt 07. */}
    <div class="journey-mobile" data-mobile-impact>
      <div class="journey-mobile__selector">
        <p class="journey-mobile__prompt sans">
          <I18nText en="My child is in Grade:" zh="我的孩子在：" lang={lang} />
        </p>
        <div class="journey-mobile__grade-grid" role="group" aria-label={lang === 'zh' ? '选择年级' : 'Select grade'}>
          {grades.map((g) => (
            <button
              type="button"
              class="journey-mobile__grade-btn sans"
              data-mobile-grade={g.id}
              aria-pressed="false"
            >{g.label}</button>
          ))}
        </div>
      </div>

      <div class="journey-mobile__empty" data-mobile-empty>
        <p>
          <span aria-hidden="true">👆</span>{' '}
          <I18nText
            en="Pick your child's grade to see what they specifically lose."
            zh="选择你孩子的年级，看 ta 具体失去了什么。"
            lang={lang}
          />
        </p>
      </div>

      <div class="journey-mobile__result" data-mobile-result hidden>
        <header class="journey-mobile__result-head">
          <h3 class="sans" data-mobile-result-title></h3>
          <button
            type="button"
            class="journey-mobile__share sans"
            data-mobile-share
            aria-label={lang === 'zh' ? '分享' : 'Share'}
          >
            <span aria-hidden="true">📲</span>{' '}
            <I18nText en="Share" zh="分享" lang={lang} />
          </button>
        </header>

        <section class="journey-mobile__section journey-mobile__section--gone" data-mobile-gone-section hidden>
          <h4 class="sans">
            <span aria-hidden="true">🔴</span>{' '}
            <I18nText en="Already eliminated for your child" zh="已经从你孩子那里取消" lang={lang} />
          </h4>
          <ul data-mobile-gone></ul>
        </section>

        <section class="journey-mobile__section journey-mobile__section--lost" data-mobile-lost-section hidden>
          <h4 class="sans">
            <span aria-hidden="true">⚪</span>{' '}
            <I18nText en="Already cut last year" zh="去年已被削减" lang={lang} />
          </h4>
          <ul data-mobile-lost></ul>
        </section>

        <section class="journey-mobile__section journey-mobile__section--risk" data-mobile-risk-section hidden>
          <h4 class="sans">
            <span aria-hidden="true">🟠</span>{' '}
            <I18nText en="At risk if not funded" zh="若未拨款则有风险" lang={lang} />
          </h4>
          <ul data-mobile-risk></ul>
        </section>

        <section class="journey-mobile__section journey-mobile__section--have" data-mobile-have-section hidden>
          <h4 class="sans">
            <span aria-hidden="true">🟫</span>{' '}
            <I18nText en="Still available (for now)" zh="目前还在（暂时）" lang={lang} />
          </h4>
          <ul data-mobile-have></ul>
        </section>

        {/* Mobile CTA hidden in outcome state — sign-up is closed
            (ActionForm renders a closed-state notice). The journey
            heatmap above is still useful as historical context for
            what was at stake. */}
        {!OUTCOME_REACHED && (
          <a class="journey-mobile__cta sans" href="#act">
            <I18nText
              en="Sign + email your MLA — 60 seconds →"
              zh="签名 + 给你的 MLA 发邮件 — 60 秒 →"
              lang={lang}
            />
          </a>
        )}

        <details class="journey-mobile__full-table">
          <summary class="sans">
            <I18nText
              en="See full grade-by-grade table"
              zh="查看完整的年级对照表"
              lang={lang}
            />
          </summary>
          <p class="journey-mobile__full-hint sans muted">
            <I18nText en="← swipe to see all grades →" zh="← 左右滑动看所有年级 →" lang={lang} />
          </p>
        </details>
      </div>
    </div>

    <div class="journey__table-wrap">
      <table class="journey__table" data-journey>
        <thead>
          <tr>
            <th class="journey__corner">
              <I18nText en="Service" zh="服务" lang={lang} />
            </th>
            {grades.map((g) => (
              <th class="journey__grade-header" data-grade={g.id} scope="col">
                <button class="journey__grade-btn sans" type="button" data-pick-grade={g.id}>
                  {g.label}
                </button>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {services.map((s) => (
            <tr>
              <th class="journey__service" scope="row">
                <span class="journey__service-name sans">{t(s.name, lang)}</span>
                {s.note && <span class="journey__service-note muted">{t(s.note, lang)}</span>}
              </th>
              {grades.map((g) => {
                const cell = s.grades[g.id];
                if (!cell) {
                  return <td class="journey__cell journey__cell--na" data-grade={g.id} aria-label="not applicable"></td>;
                }
                // The `?` glyph signals to the user "this cell carries a
                // conditional / hypothetical claim — hover for the source
                // and reasoning." Risk cells are the only ones that name
                // a future-conditional outcome (e.g. "if $9.4M not funded
                // → 259 EAs cut"). Lost / gone / have cells carry hard
                // facts (or hard absence of cuts) and need no caveat.
                const showHelp = cell.state === 'risk';
                return (
                  <td
                    class={`journey__cell cell cell--${cell.state}${showHelp ? ' cell--has-help' : ''}`}
                    data-grade={g.id}
                    data-state={cell.state}
                    title={cell.tip ? t(cell.tip, lang) : undefined}
                  >{showHelp && <span class="cell-help" aria-hidden="true">?</span>}</td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="journey__summary" data-impact-summary hidden>
      <h3 class="journey__summary-title sans" data-summary-title></h3>
      <ul class="journey__summary-list" data-summary-list></ul>
    </div>

    <details class="journey__sources sans">
      <summary>
        <I18nText
          en="Sources for every cell — verify any claim →"
          zh="每个单元格的来源——核实任何一项 →"
          lang={lang}
        />
      </summary>
      <ul class="journey__sources-list">
        <li>
          <I18nText en="$9.4M arbitration liability + BCPSEA misinterpretation + Q3 reserve impact ($4.3M would-have-been → $4.8M arbitration draw → $2,712 remaining) + 3-year fund balance projection (-$6.3M by 2028/29)" zh="940万仲裁负债 + BCPSEA误解读 + 第三季度储备影响（本应$4.3M → 仲裁抽走$4.8M → 剩 $2,712）+ 三年基金余额预测（2028/29 达 -$6.3M）" lang={lang} />
          {' — '}
          <a href="https://burnabyschools.ca/wp-content/uploads/2026/04/2026-2027-Preliminary-Budget-Report_FINAL.pdf" target="_blank" rel="noopener noreferrer">SD41 2026-27 Preliminary Budget Report (FINAL, PDF), pages 18–21</a>
          {' · '}
          <a href="https://burnabyschools.ca/unfunded-ruling-could-devastate-districts-budget/" target="_blank" rel="noopener noreferrer">SD41 Official Statement (Apr 15 2026)</a>
        </li>
        <li>
          <I18nText en="$4.2M cuts in 2025-26 (36.86 FTE) — Elementary Band, Elementary Custodial, Counselling, Mandarin Program, MACC, BETA Mini, Library Assistants" zh="2025-26 削减 $4.2M（36.86 FTE）— 小学乐队、小学清洁、辅导员、中文课、MACC、BETA Mini、图书助理" lang={lang} />
          {' — '}
          <a href="https://burnabyschools.ca/wp-content/uploads/2025/05/2025-26-Operating-Budget-Presentation-27may2025.pdf" target="_blank" rel="noopener noreferrer">SD41 2025/26 Operating Budget Presentation (PDF), page 13</a>
        </li>
        <li>
          <I18nText en="Grade 7 band eliminated in all 41 elementary schools — ~1,200 students" zh="7年级乐队课在全部41所小学取消——约1,200学生" lang={lang} />
          {' — '}
          <a href="https://www.cbc.ca/news/canada/british-columbia/b-c-school-band-cuts-1.7515565" target="_blank" rel="noopener noreferrer">CBC News (Music education advocates...)</a>
          {' · '}
          <a href="https://burnabyschools.ca/wp-content/uploads/2025/05/2025-26-Operating-Budget-Presentation-27may2025.pdf" target="_blank" rel="noopener noreferrer">SD41 2025/26 Operating Budget Presentation (PDF), p.13 (line 'Elementary Band 4.30 / $515,528')</a>
        </li>
        <li>
          <I18nText en="EAs uniquely vulnerable (no legal minimum) — up to 259 positions could be cut if $9.4M not funded; class size +2 students/class scenario; 45 secondary counsellors / 27,000 students" zh="EA 无法定最低配置——如 $9.4M 不到位最多 259 岗位可被砍；班级 +2 人情境；45 中学辅导员对 27,000 学生" lang={lang} />
          {' — '}
          <a href="http://dpac.burnabypac.ca/wp-content/uploads/sites/2/2026/04/DPAC-Fact-Sheet.pdf" target="_blank" rel="noopener noreferrer">Burnaby DPAC Fact Sheet (PDF), pages 2–3</a>
        </li>
        <li>
          <I18nText en="$5B Contingencies Vote covering 'caseload pressures, current collective bargaining mandate costs and other costs uncertain at the time of building the budget'" zh="$5B 应急基金涵盖『案件压力、当前集体谈判授权成本及其他在编制预算时不确定的成本』" lang={lang} />
          {' — '}
          <a href="https://www.bcbudget.gov.bc.ca/2026/fiscal/" target="_blank" rel="noopener noreferrer">BC Budget 2026 — Fiscal Plan (Expense outlook section)</a>
        </li>
      </ul>
      <p class="journey__sources-note muted">
        <I18nText
          en="Cell colours reflect documented current state. Cells marked with ? indicate a conditional claim (e.g. 'at risk if $9.4M not funded'); hover the cell to see the source and assumption."
          zh="单元格颜色反映记录的当前状态。带 ? 标记的单元格代表条件性判断（例如『如 $9.4M 不到位则有风险』）；将鼠标悬停在单元格上可查看来源和假设。"
          lang={lang}
        />
      </p>
    </details>
  </div>
</section>

<script type="application/json" id="journey-data" set:html={JSON.stringify(clientData)} is:inline></script>
<script>
  type Cell = { state: 'have' | 'lost' | 'risk' | 'gone'; tip: string };
  type ServiceShape = {
    id: string;
    name: string;
    note: string;
    grades: Record<string, Cell>;
  };
  type Data = {
    lang: 'en' | 'zh';
    grades: Array<{ id: string; label: string }>;
    services: ServiceShape[];
  };

  const dataEl = document.getElementById('journey-data');
  if (!dataEl) {
    console.warn('Journey: no data element');
  } else {
    const data: Data = JSON.parse(dataEl.textContent || '{}');
    const table = document.querySelector<HTMLElement>('[data-journey]');
    const summary = document.querySelector<HTMLElement>('[data-impact-summary]');
    const summaryTitle = document.querySelector<HTMLElement>('[data-summary-title]');
    const summaryList = document.querySelector<HTMLElement>('[data-summary-list]');

    function renderSummary(gradeId: string) {
      if (!summary || !summaryTitle || !summaryList) return;

      const gradeLabel = data.grades.find((g) => g.id === gradeId)?.label ?? gradeId;

      // Find services with state lost/risk/gone for this grade.
      const items = data.services
        .map((s) => ({ s, cell: s.grades[gradeId] }))
        .filter(({ cell }) => cell && (cell.state === 'lost' || cell.state === 'risk' || cell.state === 'gone'));

      const titleEn = `A student in Grade ${gradeLabel}: what they lose`;
      const titleZh = `${gradeLabel} 年级学生：失去的服务`;
      summaryTitle.textContent = data.lang === 'zh' ? titleZh : titleEn;

      summaryList.innerHTML = '';
      if (items.length === 0) {
        const li = document.createElement('li');
        li.textContent = data.lang === 'zh' ? '此年级没有标记为有风险的服务。' : 'No services flagged at-risk for this grade.';
        li.className = 'muted';
        summaryList.appendChild(li);
      } else {
        for (const { s, cell } of items) {
          const li = document.createElement('li');
          const stateLabel: Record<string, { en: string; zh: string }> = {
            lost: { en: 'already cut', zh: '已削减' },
            risk: { en: 'at risk', zh: '有风险' },
            gone: { en: 'likely eliminated', zh: '可能取消' },
          };
          const tag = stateLabel[cell.state][data.lang];
          li.innerHTML =
            `<span class="summary-state summary-state--${cell.state} sans">${tag}</span>` +
            ` <strong>${s.name}</strong>` +
            (cell.tip ? ` — <span class="muted">${cell.tip}</span>` : '');
          summaryList.appendChild(li);
        }
      }

      summary.hidden = false;
    }

    document.querySelectorAll<HTMLButtonElement>('[data-pick-grade]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const gradeId = btn.dataset.pickGrade;
        if (!gradeId) return;
        // Toggle highlighted column
        if (table) {
          table.querySelectorAll<HTMLElement>('[data-grade]').forEach((cell) => {
            cell.classList.toggle('journey__highlighted', cell.dataset.grade === gradeId);
          });
        }
        // Sync aria-pressed on the new selector-bar buttons.
        document.querySelectorAll<HTMLButtonElement>('[data-pick-grade]').forEach((b) => {
          b.setAttribute('aria-pressed', b.dataset.pickGrade === gradeId ? 'true' : 'false');
        });
        const showAllBtn = document.querySelector<HTMLButtonElement>('[data-pick-grade-clear]');
        if (showAllBtn) showAllBtn.setAttribute('aria-pressed', 'false');
        renderSummary(gradeId);
      });
    });

    // "Show all" button — clears column highlight and hides summary.
    const showAllBtn = document.querySelector<HTMLButtonElement>('[data-pick-grade-clear]');
    showAllBtn?.addEventListener('click', () => {
      if (table) {
        table.querySelectorAll<HTMLElement>('.journey__highlighted').forEach((cell) => {
          cell.classList.remove('journey__highlighted');
        });
      }
      document.querySelectorAll<HTMLButtonElement>('[data-pick-grade]').forEach((b) => {
        b.setAttribute('aria-pressed', 'false');
      });
      showAllBtn.setAttribute('aria-pressed', 'true');
      if (summary) summary.hidden = true;
    });

    // ─── Mobile personalized impact ─────────────────────────────────
    // Buttons populate four sections (gone / lost / risk / have)
    // grouped from the same per-cell data already serialized for the
    // desktop summary. Empty sections are hidden so the result feels
    // tailored to the picked grade rather than padded with placeholders.
    const mobileEmpty = document.querySelector<HTMLElement>('[data-mobile-empty]');
    const mobileResult = document.querySelector<HTMLElement>('[data-mobile-result]');
    const mobileResultTitle = document.querySelector<HTMLElement>('[data-mobile-result-title]');
    const mobileGoneSection = document.querySelector<HTMLElement>('[data-mobile-gone-section]');
    const mobileLostSection = document.querySelector<HTMLElement>('[data-mobile-lost-section]');
    const mobileRiskSection = document.querySelector<HTMLElement>('[data-mobile-risk-section]');
    const mobileHaveSection = document.querySelector<HTMLElement>('[data-mobile-have-section]');
    const mobileGoneList = document.querySelector<HTMLElement>('[data-mobile-gone]');
    const mobileLostList = document.querySelector<HTMLElement>('[data-mobile-lost]');
    const mobileRiskList = document.querySelector<HTMLElement>('[data-mobile-risk]');
    const mobileHaveList = document.querySelector<HTMLElement>('[data-mobile-have]');
    const mobileShareBtn = document.querySelector<HTMLElement>('[data-mobile-share]');
    const mobileGradeBtns = document.querySelectorAll<HTMLButtonElement>('[data-mobile-grade]');

    let currentMobileGrade = '';
    let currentMobileCounts = { gone: 0, lost: 0, risk: 0, have: 0 };

    function escapeHtmlMobile(s: string) {
      return s.replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
      }[c]!));
    }

    function firstSentence(s: string): string {
      // Use first sentence of the description. "Without EA hours: ..."
      // splits on either "." or "。" — keeps it concise per UX research.
      const m = s.match(/^[^.。]*[.。]/);
      return m ? m[0] : s.split(/\s+/).slice(0, 16).join(' ');
    }

    function renderMobile(gradeId: string) {
      if (!mobileResult || !mobileEmpty || !mobileResultTitle) return;

      const gradeLabel = data.grades.find((g) => g.id === gradeId)?.label ?? gradeId;
      const titleEn = `Showing impacts for Grade ${gradeLabel}`;
      const titleZh = `${gradeLabel} 年级的影响`;
      mobileResultTitle.textContent = data.lang === 'zh' ? titleZh : titleEn;

      const buckets: Record<'gone'|'lost'|'risk'|'have', string[]> = {
        gone: [], lost: [], risk: [], have: [],
      };

      for (const s of data.services) {
        const cell = s.grades[gradeId];
        if (!cell || !cell.state) continue;
        const note = s.note ? firstSentence(s.note) : '';
        const li =
          `<li class="jm-item">` +
            `<strong class="jm-item__name">${escapeHtmlMobile(s.name)}</strong>` +
            (note ? `<span class="jm-item__note muted">${escapeHtmlMobile(note)}</span>` : '') +
          `</li>`;
        buckets[cell.state].push(li);
      }

      currentMobileCounts = {
        gone: buckets.gone.length,
        lost: buckets.lost.length,
        risk: buckets.risk.length,
        have: buckets.have.length,
      };

      const sections: Array<['gone'|'lost'|'risk'|'have', HTMLElement | null, HTMLElement | null]> = [
        ['gone', mobileGoneSection, mobileGoneList],
        ['lost', mobileLostSection, mobileLostList],
        ['risk', mobileRiskSection, mobileRiskList],
        ['have', mobileHaveSection, mobileHaveList],
      ];
      for (const [state, section, list] of sections) {
        if (!section || !list) continue;
        if (buckets[state].length === 0) {
          section.hidden = true;
          list.innerHTML = '';
        } else {
          list.innerHTML = buckets[state].join('');
          section.hidden = false;
        }
      }

      mobileEmpty.hidden = true;
      mobileResult.hidden = false;
    }

    mobileGradeBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const gradeId = btn.dataset.mobileGrade;
        if (!gradeId) return;
        currentMobileGrade = gradeId;
        // Visual selected state
        mobileGradeBtns.forEach((b) => {
          const pressed = b.dataset.mobileGrade === gradeId;
          b.setAttribute('aria-pressed', pressed ? 'true' : 'false');
        });
        renderMobile(gradeId);
      });
    });

    // "See full grade-by-grade table" expander on mobile. The desktop
    // table-wrap and scroll-hint are hidden on mobile via media query.
    // When the user opens the details, toggle a class on the
    // .journey root so the matching CSS rule re-shows them.
    const fullTableDetails = document.querySelector<HTMLDetailsElement>('.journey-mobile__full-table');
    const journeyRoot = document.querySelector<HTMLElement>('.journey');
    fullTableDetails?.addEventListener('toggle', () => {
      if (!journeyRoot) return;
      journeyRoot.classList.toggle('journey--show-full', fullTableDetails.open);
      // When opening, scroll the now-visible table into view so the
      // user understands what just appeared.
      if (fullTableDetails.open) {
        const wrap = document.querySelector<HTMLElement>('.journey__table-wrap');
        wrap?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    // Share handler — navigator.share when available, clipboard fallback.
    mobileShareBtn?.addEventListener('click', async () => {
      if (!currentMobileGrade) return;
      const gradeLabel = data.grades.find((g) => g.id === currentMobileGrade)?.label ?? currentMobileGrade;
      const lostCount = currentMobileCounts.gone + currentMobileCounts.lost;
      const riskCount = currentMobileCounts.risk;
      const text = data.lang === 'zh'
        ? `我在本拿比读 ${gradeLabel} 年级的孩子已经失去了 ${lostCount} 项服务，另有 ${riskCount} 项面临削减风险。BC 省政府有 50 亿元 Contingencies Vote 可以解决，但还没拨款。https://fundburnabykids.ca`
        : `My Grade ${gradeLabel} child at Burnaby schools has lost ${lostCount} services and ${riskCount} more are at risk. BC has $5B in the Contingencies Vote that could fix this. They haven't. Sign at https://fundburnabykids.ca`;
      const title = data.lang === 'zh'
        ? 'Fund Burnaby Kids — 我家孩子失去了什么'
        : 'Fund Burnaby Kids — what my child is losing';
      const url = 'https://fundburnabykids.ca/';
      try {
        if (navigator.share) {
          await navigator.share({ title, text, url });
        } else if (navigator.clipboard) {
          await navigator.clipboard.writeText(`${text} ${url}`);
          const original = mobileShareBtn.innerHTML;
          mobileShareBtn.innerHTML = data.lang === 'zh' ? '已复制 ✓' : 'Copied ✓';
          setTimeout(() => { if (mobileShareBtn) mobileShareBtn.innerHTML = original; }, 2200);
        } else {
          window.prompt(data.lang === 'zh' ? '复制以下文字并分享：' : 'Copy + paste to share:', `${text} ${url}`);
        }
      } catch { /* user cancelled */ }
    });
  }
</script>

