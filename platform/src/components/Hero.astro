---
// Campaign hero — countdown + headline + counter + dual CTA + founder line.
// Designed for civic-credibility (UK Parliament / Toronto Council Scorecard
// style), not activist-platform marketing. Every claim must be auditable.

import { getEntry } from 'astro:content';
import I18nText from '~/components/I18nText.astro';
import Icon from '~/components/Icon.astro';
import Countdown from '~/components/Countdown.astro';
import SignatureCounter from '~/components/SignatureCounter.astro';
import ProgressBar from '~/components/ProgressBar.astro';
import RidingMap from '~/components/RidingMap.astro';
import { localizedUrl, t } from '~/lib/i18n';
import type { Lang } from '~/lib/i18n';
import { OUTCOME_REACHED, OUTCOME_SOURCE_URL, DPAC_DAY_OF_ACTION_URL } from '~/lib/outcome';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const meta = (await getEntry('campaign', 'fund-burnaby-kids'))?.data as any;
const thresholds = (await getEntry('campaign', 'thresholds'))?.data as any;

const headline = (meta?.headline ? t(meta.headline, lang) : '') as string;
const subheadline = (meta?.subheadline ? t(meta.subheadline, lang) : '') as string;
const askAmount = meta?.ask?.amount_label ?? '$9.4M';
const founderName = meta?.founder?.name ?? 'Ben Zhou';
const founderRole = meta?.founder?.role ? t(meta.founder.role, lang) : '';

// meta.deadline may come back as a Date object from the YAML loader.
// Normalize to ISO date string before composing the deadline timestamp.
function normalizeDeadline(raw: unknown): string {
  if (raw instanceof Date) {
    const y = raw.getUTCFullYear();
    const m = String(raw.getUTCMonth() + 1).padStart(2, '0');
    const d = String(raw.getUTCDate()).padStart(2, '0');
    return `${y}-${m}-${d}T00:00:00-07:00`;
  }
  if (typeof raw === 'string' && /^\d{4}-\d{2}-\d{2}/.test(raw)) {
    return `${raw.slice(0, 10)}T00:00:00-07:00`;
  }
  return '2026-05-27T00:00:00-07:00';
}
const deadline = normalizeDeadline(meta?.deadline);
const goal = thresholds?.goal ?? 2000;

// PAC endorsement banner (Prompt 12). Fetched server-side from
// public_pac_endorsements view (only `verified` rows, no PII). Renders
// only when there's at least 1 PAC. The first PAC is psychologically
// the most valuable — surfacing it here, not just in the coalition
// section below, makes "at least one school's PAC has signed off"
// visible to every visitor in the first viewport.
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
type HeroPac = { school: string; students: number };
let pacEndorsements: HeroPac[] = [];
if (supabaseUrl && supabaseKey) {
  try {
    const res = await fetch(
      `${supabaseUrl}/rest/v1/public_pac_endorsements?select=school,students&order=approval_date.desc.nullslast`,
      { headers: { apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` } }
    );
    if (res.ok) pacEndorsements = await res.json();
  } catch { /* keep empty */ }
}
const firstPac = pacEndorsements[0];
const totalPacs = pacEndorsements.length;
---

<section class="hero">
  <div class="wrap-wide hero__inner">

    {/* PAC endorsement banner (Prompt 12 + client polling). Always
        emitted in the DOM but `hidden` when no PAC has been verified
        yet — that way the inline poll script (below) can flip it
        visible later without needing the page to be rebuilt. SSR
        seeds the initial state; polling refreshes every 60s. */}
    <a
      class="hero__pac-banner sans"
      href="#coalition"
      data-pac-banner
      data-supabase-url={supabaseUrl}
      data-supabase-key={supabaseKey}
      data-lang={lang}
      hidden={pacEndorsements.length === 0}
    >
      <span class="hero__pac-banner__badge"><Icon name="badge-check" size={18} /></span>
      <span class="hero__pac-banner__text">
        <I18nText en="Endorsed by" zh="已获 endorse：" lang={lang} />
        {' '}
        <strong data-pac-schools>{pacEndorsements.map((p) => p.school).join(', ')}</strong>
      </span>
      <span class="hero__pac-banner__chevron" aria-hidden="true">→</span>
    </a>

    {/* Countdown pill + consequence (Prompt 11). The pill alone reads
        as abstract time scarcity ("28 days" — feels far away). Pairing
        it with the locked-in consequence line activates loss aversion:
        "after this date, the cuts persist for the 2026-27 school
        year." Tooltip on the countdown gives the procedural detail.

        Riding-map teaser sits inline next to the countdown so the
        first-viewport orientation also includes "this is about MY
        riding." Click → opens the full choropleth in a dialog with
        per-riding signature counts. The full RidingMap component
        renders inside the dialog (mounted always so polling + SSR
        seed work). */}
    {/* Countdown row + consequence — only relevant in active-campaign
        state. Once OUTCOME_REACHED, the May 27 budget-adoption deadline
        is moot (the specific ask was funded before then), so we hide
        both the Countdown pill and the "after this date, cuts locked
        in" line. Restoring the active hero is a single flip of
        OUTCOME_REACHED in src/lib/outcome.ts. */}
    {!OUTCOME_REACHED && (
      <>
        <div class="hero__countdown-row">
          <Countdown deadline={deadline} lang={lang} />
        </div>
        <p class="hero__countdown-consequence sans">
          {lang === 'zh' ? (
            <>
              5 月 27 日之后，削减将<strong>锁定到 2026-27 学年</strong>。9 月之前没有&ldquo;下一次机会&rdquo;。
            </>
          ) : (
            <>
              After May 27, the cuts are <strong>locked in for the 2026-27 school year</strong>. There is no &ldquo;next chance&rdquo; before September.
            </>
          )}
        </p>
      </>
    )}

    {/* Kicker — flips between active-campaign provenance ("BC Budget 2026
        · SD41 · Arbitration funding") and outcome-state date stamp
        ("Outcome — April 30, 2026") so the first thing readers see
        matches the page's current purpose. */}
    <p class="hero__kicker sans">
      {OUTCOME_REACHED ? (
        <I18nText
          en="Outcome — April 30, 2026"
          zh="结果 — 2026 年 4 月 30 日"
          lang={lang}
        />
      ) : (
        <I18nText
          en="BC Budget 2026 · Burnaby School District 41 · Arbitration funding"
          zh="BC Budget 2026 · Burnaby 学区 SD41 · 仲裁裁决拨款"
          lang={lang}
        />
      )}
    </p>

    {OUTCOME_REACHED ? (
      <>
        {/* Outcome-state hero body — parallel-actor framing.
            Specific ask resolved (paragraphs 1-2), DPAC's broader
            structural work explicitly distinct (paragraph 3),
            campaign infrastructure preserved as future asset
            (paragraph 4). Source link to the SD41 Board's own
            announcement under the body. */}
        <h1 class="hero__headline hero__headline--outcome">
          <I18nText en="Outcome reached." zh="诉求达成。" lang={lang} />
        </h1>
        <div class="hero__outcome-body">
          <p class="hero__outcome-lead">
            {lang === 'zh' ? (
              <>2026 年 4 月 30 日，省府承诺承担本次仲裁裁决的全部 <span class="hero__amount">$9.4M</span> 成本。本次活动的具体诉求已得到解决。</>
            ) : (
              <>On April 30, 2026, the Province committed to fund the full <span class="hero__amount">$9.4M</span> arbitration cost. The specific ask of this campaign is resolved.</>
            )}
          </p>
          <p>
            <I18nText
              en="This was a campaign about a specific, structural failure: a provincial bargaining body misinterpreted Burnaby's contract, and the cost was being passed to local classrooms. That's now been corrected."
              zh="本次活动针对的是一个具体的结构性失误：省级集体谈判机构误读了 Burnaby 的合同，本应由省级承担的成本被转嫁到本地课堂。这一失误现已得到纠正。"
              lang={lang}
            />
          </p>
          <p>
            {lang === 'zh' ? (
              <>Burnaby DPAC 仍在持续推进更宽泛的长期教育拨款不足议题——他们的 <a href={DPAC_DAY_OF_ACTION_URL} target="_blank" rel="noopener noreferrer">5 月 1 日 Day of Action</a> 照常举行。那是与本次活动具体诉求相区分但互补的工作。</>
            ) : (
              <>Burnaby DPAC continues its broader work on chronic underfunding — their <a href={DPAC_DAY_OF_ACTION_URL} target="_blank" rel="noopener noreferrer">May 1 Day of Action</a> is still on, and that work is distinct from but complementary to this campaign's specific ask.</>
            )}
          </p>
          <p>
            <I18nText
              en="What we built here — the data, the framework, the coalition of parents who showed up — doesn't disappear. We're thinking about what comes next."
              zh="我们在这里建立的东西——数据、方法论、站出来的家长联盟——不会消失。下一步要做什么，我们正在思考。"
              lang={lang}
            />
          </p>
          <p class="hero__outcome-source sans">
            <a href={OUTCOME_SOURCE_URL} target="_blank" rel="noopener noreferrer">
              <I18nText en="Read the SD41 announcement ↗" zh="阅读 SD41 公告 ↗" lang={lang} />
            </a>
          </p>
        </div>
      </>
    ) : (
      <>
        {/* Headline (highlights $X.XM as a styled span) */}
        <h1 class="hero__headline">
          {(() => {
            const parts = headline.split(askAmount);
            if (parts.length === 2) {
              return (
                <>{parts[0]}<span class="hero__amount">{askAmount}</span>{parts[1]}</>
              );
            }
            return headline;
          })()}
        </h1>

        {/* Subheadline */}
        {subheadline && <p class="hero__sub">{subheadline}</p>}
      </>
    )}

    {/* Counter + Progress */}
    <div class="hero__counter">
      <SignatureCounter lang={lang} goal={goal} />
    </div>

    {/* ProgressBar: hidden in outcome state — the "X of 2000 signatures"
        progress meter implies an active goal, which is moot once the
        ask is resolved. SignatureCounter above keeps the historical
        count visible. */}
    {!OUTCOME_REACHED && <ProgressBar lang={lang} />}

    {/* Riding-map teaser pill — sits below the SignatureCounter and
        above the dual CTAs. Designed as a subtle "interactive element"
        affordance (line-soft pill with map icon + arrow), not a hidden
        help link. Earlier rev used "?" trailing a dotted-underline
        line, but parents read it as glossary help, not "interactive
        map". Map icon + action verb + → makes the affordance obvious
        without competing with the primary CTAs below. */}
    <button
      type="button"
      class="hero__map-link"
      data-hero-map-open
      aria-label={lang === 'zh' ? '查看签名按选区分布' : 'See signatures by Burnaby riding'}
    >
      <span class="hero__map-link__icon"><Icon name="map" size={18} /></span>
      <span class="hero__map-link__text">
        {OUTCOME_REACHED ? (
          <I18nText
            en="See signatures by Burnaby riding"
            zh="看签名按选区分布"
            lang={lang}
          />
        ) : (
          <I18nText
            en="See live signatures by Burnaby riding"
            zh="看签名按选区分布（实时）"
            lang={lang}
          />
        )}
      </span>
      <span class="hero__map-link__arrow" aria-hidden="true">→</span>
    </button>

    {/* Dual CTA — hidden in outcome state. The active CTAs ("Sign +
        email your MLA" / "Read the case first") drive the action
        funnel that's now closed. The hero outcome body already carries
        the source link to the SD41 announcement and the DPAC May 1
        hand-off, so no replacement CTAs are needed. */}
    {!OUTCOME_REACHED && (
      <div class="hero__cta-row">
        <a class="btn btn--primary btn--lg" href={localizedUrl('/#act', lang)}>
          <I18nText
            en="Sign + email your MLA — 60 seconds"
            zh="签名 + 给你的 MLA 发邮件 — 60 秒"
            lang={lang}
          />
        </a>
        <a class="btn btn--ghost btn--lg" href={localizedUrl('/#why', lang)}>
          <I18nText
            en="Read the case first"
            zh="先看证据"
            lang={lang}
          />
        </a>
      </div>
    )}

    {/* Founder credit */}
    <p class="hero__founder sans">
      <I18nText en="Founded by " zh="发起人：" lang={lang} />
      <strong>{founderName}</strong>
      {founderRole && <span class="muted">, {founderRole}</span>}
      {' · '}
      <a href={localizedUrl('/#about', lang)}>
        <I18nText en="About this campaign" zh="关于本活动" lang={lang} />
      </a>
    </p>

  </div>
</section>

{/* Riding-map dialog — opened by the ? trigger above. Wraps the full
    RidingMap (non-embedded, with its own kicker / h2 / source citation
    so users get the complete context). RidingMap is mounted always
    (not lazy-rendered) so SSR seed + 30s polling keep it in sync
    whether or not the dialog has been opened. */}
<dialog class="hero-map-dialog" id="hero-riding-map" aria-label={lang === 'zh' ? 'Burnaby 选区签名分布' : 'Burnaby riding signatures'}>
  <button
    type="button"
    class="hero-map-dialog__close icon-close"
    data-hero-map-close
    aria-label={lang === 'zh' ? '关闭' : 'Close'}
  >×</button>
  <div class="hero-map-dialog__viewport">
    <RidingMap lang={lang} />
  </div>
</dialog>

<script>
  // Riding-map dialog open/close. Lightweight — the inner RidingMap
  // is SVG that renders at native size suitable for tap targets; no
  // panzoom needed.
  if (!(window as any).__heroMapBound) {
    (window as any).__heroMapBound = true;
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;

      const opener = target.closest<HTMLElement>('[data-hero-map-open]');
      if (opener) {
        const dlg = document.getElementById('hero-riding-map') as HTMLDialogElement | null;
        if (dlg && typeof dlg.showModal === 'function') {
          (dlg as any).__savedY = window.scrollY;
          dlg.showModal();
        }
        return;
      }

      const closer = target.closest<HTMLElement>('[data-hero-map-close]');
      if (closer) {
        const dlg = closer.closest('dialog') as HTMLDialogElement | null;
        dlg?.close();
        return;
      }

      if (target.tagName === 'DIALOG' && target.classList.contains('hero-map-dialog')) {
        (target as HTMLDialogElement).close();
      }
    });

    const dlg = document.getElementById('hero-riding-map');
    dlg?.addEventListener('close', () => {
      const y = (dlg as any).__savedY;
      if (typeof y === 'number') {
        window.scrollTo({ top: y, left: 0, behavior: 'instant' as ScrollBehavior });
      }
    });
  }
</script>

<script>
  // PAC banner client-side polling. SSR seeds the initial state from
  // Supabase at build time; without polling, every new PAC verification
  // would only show up after a Netlify rebuild. 60s interval matches
  // SignatoriesFeed. Updates textContent + hidden flag on existing
  // elements — does NOT innerHTML rebuild, so Astro's scoped CSS
  // (data-astro-cid attrs) keeps matching.
  document.querySelectorAll<HTMLElement>('[data-pac-banner]').forEach((banner) => {
    const url = banner.dataset.supabaseUrl;
    const key = banner.dataset.supabaseKey;
    const lang = (banner.dataset.lang === 'zh' ? 'zh' : 'en') as 'en' | 'zh';
    if (!url || !key) return;

    const schoolsEl = banner.querySelector<HTMLElement>('[data-pac-schools]');

    type Pac = { school: string; students: number };

    async function poll() {
      try {
        const res = await fetch(
          `${url}/rest/v1/public_pac_endorsements?select=school,students&order=approval_date.desc.nullslast`,
          { headers: { apikey: key!, Authorization: `Bearer ${key!}` } }
        );
        if (!res.ok) return;
        const pacs = (await res.json()) as Pac[];
        if (!Array.isArray(pacs)) return;

        if (pacs.length === 0) {
          banner.hidden = true;
          return;
        }
        banner.hidden = false;
        // List every PAC in the banner. CSS text-overflow:ellipsis on
        // .hero__pac-banner__text trims gracefully if the list grows
        // long. On the day there are 6+ PACs we can revisit the
        // "+N more" abbreviation.
        if (schoolsEl) schoolsEl.textContent = pacs.map((p) => p.school).join(', ');
      } catch {
        /* keep last good state */
      }
    }

    poll();
    setInterval(poll, 60_000);
  });
</script>

<style>
  .hero {
    padding: 48px 0 32px;
    background: var(--cream);
  }
  .hero__inner {
    max-width: 820px;
  }
  /* PAC endorsement banner (Prompt 12). Subtle but unmissable verified-
     style chip; clickable as a jump-link to the coalition section. */
  .hero__pac-banner {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--paper);
    border: 1px solid var(--success, #15803D);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    margin-bottom: 12px;
    transition: background 0.15s, transform 0.15s;
    max-width: 100%;
  }
  .hero__pac-banner:hover {
    background: rgba(21, 128, 61, 0.06);
    transform: translateY(-1px);
  }
  .hero__pac-banner__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--success, #15803D);
    flex-shrink: 0;
  }
  .hero__pac-banner__text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .hero__pac-banner__chevron {
    color: var(--success, #15803D);
    font-weight: 700;
    flex-shrink: 0;
  }

  .hero__countdown-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  /* Riding-map teaser pill — sub-CTA between ProgressBar and the
     dual primary CTAs. Subtle pill chrome (line-soft bg + 1px line
     border) signals "interactive element" without competing with the
     primary buttons. Map icon on the left + action verb in the
     middle + arrow on the right makes it obvious that clicking opens
     a map view. Inline-flex so it auto-sizes to its content rather
     than stretching across the hero. */
  .hero__map-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin: 14px 0 22px;
    padding: 8px 14px;
    background: var(--line-soft);
    border: 1px solid var(--line);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink-soft);
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s, transform 0.1s;
  }
  .hero__map-link:hover,
  .hero__map-link:focus-visible {
    background: var(--cream);
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }
  .hero__map-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .hero__map-link__icon {
    color: var(--accent);
    display: inline-flex;
    flex-shrink: 0;
  }
  .hero__map-link__text {
    /* No more dotted underline — the pill chrome carries the
       affordance; underlining inside a pill reads noisy. */
  }
  .hero__map-link__arrow {
    color: var(--accent);
    font-size: 14px;
    line-height: 1;
    transition: transform 0.15s;
  }
  .hero__map-link:hover .hero__map-link__arrow,
  .hero__map-link:focus-visible .hero__map-link__arrow {
    transform: translateX(2px);
  }

  /* Riding-map dialog — centered modal on desktop, full-screen on
     phones (consistent with SvgVisual / SmapZoom patterns). */
  .hero-map-dialog {
    width: 95vw;
    max-width: 1000px;
    height: 90vh;
    max-height: 92vh;
    padding: 0;
    border: none;
    border-radius: var(--radius-lg);
    background: var(--paper);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    position: relative;
  }
  .hero-map-dialog::backdrop { background: rgba(0, 0, 0, 0.85); }
  .hero-map-dialog__close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
  }
  .hero-map-dialog__viewport {
    width: 100%;
    height: 100%;
    overflow: auto;
    padding: 12px;
    box-sizing: border-box;
  }
  .hero-map-dialog__viewport :global(.riding-map) {
    padding: 0;
    background: transparent;
    border-top: none;
  }

  @media (max-width: 560px) {
    .hero-map-dialog {
      position: fixed;
      inset: 0;
      width: 100vw;
      max-width: 100vw;
      height: 100vh;
      max-height: 100vh;
      height: 100dvh;
      max-height: 100dvh;
      border-radius: 0;
      margin: 0;
    }
  }

  :global(body:has(dialog.hero-map-dialog[open])) {
    overflow: hidden;
  }



  .hero__countdown-consequence {
    margin: 0 0 24px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 600px;
  }
  .hero__countdown-consequence strong {
    color: var(--warm);
    font-weight: 700;
  }
  .hero__kicker {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 12px;
  }
  .hero__headline {
    font-family: var(--font-sans);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 16px;
    max-width: 800px;
  }
  .hero__amount {
    color: var(--warm);
    font-style: italic;
    font-weight: 800;
    white-space: nowrap;
  }
  .hero__sub {
    font-size: clamp(17px, 2.2vw, 20px);
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0 0 28px;
    max-width: 640px;
  }

  /* Outcome-state hero: smaller H1 ("Outcome reached.") + multi-paragraph
     body. The active hero's display H1 is sized clamp(32px, 5vw, 52px)
     because it has to drive action; the outcome state is informational,
     so the H1 dials back to leave more visual weight for the
     paragraphs below. The lead paragraph picks up the scale where the
     active subhead sat (clamp(17-20px)) so $9.4M is still the visual
     anchor. */
  .hero__headline--outcome {
    font-size: clamp(28px, 4vw, 42px);
    margin-bottom: 20px;
  }
  .hero__outcome-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 700px;
    margin: 0 0 12px;
  }
  .hero__outcome-body > p {
    margin: 0;
    font-size: clamp(15px, 2vw, 17px);
    line-height: 1.65;
    color: var(--ink-soft);
  }
  .hero__outcome-body > p.hero__outcome-lead {
    font-size: clamp(17px, 2.4vw, 20px);
    line-height: 1.55;
    color: var(--ink);
    font-weight: 500;
  }
  .hero__outcome-body a {
    color: var(--accent);
    text-decoration: underline;
    font-weight: 500;
  }
  .hero__outcome-body a:hover {
    text-decoration: none;
  }
  .hero__outcome-body > p.hero__outcome-source {
    font-size: 13px;
    margin-top: 4px;
  }
  .hero__outcome-body > p.hero__outcome-source a {
    color: var(--success);
