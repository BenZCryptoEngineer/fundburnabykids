---
// Campaign hero — countdown + headline + counter + dual CTA + founder line.
// Designed for civic-credibility (UK Parliament / Toronto Council Scorecard
// style), not activist-platform marketing. Every claim must be auditable.

import { getEntry } from 'astro:content';
import I18nText from '~/components/I18nText.astro';
import Countdown from '~/components/Countdown.astro';
import SignatureCounter from '~/components/SignatureCounter.astro';
import ProgressBar from '~/components/ProgressBar.astro';
import { localizedUrl, t } from '~/lib/i18n';
import type { Lang } from '~/lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const meta = (await getEntry('campaign', 'fund-burnaby-kids'))?.data as any;
const thresholds = (await getEntry('campaign', 'thresholds'))?.data as any;

const headline = (meta?.headline ? t(meta.headline, lang) : '') as string;
const subheadline = (meta?.subheadline ? t(meta.subheadline, lang) : '') as string;
const askAmount = meta?.ask?.amount_label ?? '$9.4M';
const founderName = meta?.founder?.name ?? 'Ben Zhou';
const founderRole = meta?.founder?.role ? t(meta.founder.role, lang) : '';

// meta.deadline may come back as a Date object from the YAML loader.
// Normalize to ISO date string before composing the deadline timestamp.
function normalizeDeadline(raw: unknown): string {
  if (raw instanceof Date) {
    const y = raw.getUTCFullYear();
    const m = String(raw.getUTCMonth() + 1).padStart(2, '0');
    const d = String(raw.getUTCDate()).padStart(2, '0');
    return `${y}-${m}-${d}T00:00:00-07:00`;
  }
  if (typeof raw === 'string' && /^\d{4}-\d{2}-\d{2}/.test(raw)) {
    return `${raw.slice(0, 10)}T00:00:00-07:00`;
  }
  return '2026-05-27T00:00:00-07:00';
}
const deadline = normalizeDeadline(meta?.deadline);
const goal = thresholds?.goal ?? 2000;

// PAC endorsement banner (Prompt 12). Fetched server-side from
// public_pac_endorsements view (only `verified` rows, no PII). Renders
// only when there's at least 1 PAC. The first PAC is psychologically
// the most valuable — surfacing it here, not just in the coalition
// section below, makes "at least one school's PAC has signed off"
// visible to every visitor in the first viewport.
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
type HeroPac = { school: string; students: number };
let pacEndorsements: HeroPac[] = [];
if (supabaseUrl && supabaseKey) {
  try {
    const res = await fetch(
      `${supabaseUrl}/rest/v1/public_pac_endorsements?select=school,students&order=approval_date.desc.nullslast`,
      { headers: { apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` } }
    );
    if (res.ok) pacEndorsements = await res.json();
  } catch { /* keep empty */ }
}
const firstPac = pacEndorsements[0];
const totalPacs = pacEndorsements.length;
---

<section class="hero">
  <div class="wrap-wide hero__inner">

    {/* PAC endorsement banner (Prompt 12 + client polling). Always
        emitted in the DOM but `hidden` when no PAC has been verified
        yet — that way the inline poll script (below) can flip it
        visible later without needing the page to be rebuilt. SSR
        seeds the initial state; polling refreshes every 60s. */}
    <a
      class="hero__pac-banner sans"
      href="#coalition"
      data-pac-banner
      data-supabase-url={supabaseUrl}
      data-supabase-key={supabaseKey}
      data-lang={lang}
      hidden={pacEndorsements.length === 0}
    >
      <span class="hero__pac-banner__badge" aria-hidden="true">✓</span>
      <span class="hero__pac-banner__text">
        <I18nText en="Endorsed by" zh="已获 endorse：" lang={lang} />
        {' '}
        <strong data-pac-schools>{pacEndorsements.map((p) => p.school).join(', ')}</strong>
      </span>
      <span class="hero__pac-banner__chevron" aria-hidden="true">→</span>
    </a>

    {/* Countdown pill + consequence (Prompt 11). The pill alone reads
        as abstract time scarcity ("28 days" — feels far away). Pairing
        it with the locked-in consequence line activates loss aversion:
        "after this date, the cuts persist for the 2026-27 school
        year." Tooltip on the countdown gives the procedural detail. */}
    <div class="hero__countdown-row">
      <Countdown deadline={deadline} lang={lang} />
    </div>
    <p class="hero__countdown-consequence sans">
      {lang === 'zh' ? (
        <>
          5 月 27 日之后，削减将<strong>锁定到 2026-27 学年</strong>。9 月之前没有&ldquo;下一次机会&rdquo;。
        </>
      ) : (
        <>
          After May 27, the cuts are <strong>locked in for the 2026-27 school year</strong>. There is no &ldquo;next chance&rdquo; before September.
        </>
      )}
    </p>

    {/* Kicker */}
    <p class="hero__kicker sans">
      <I18nText
        en="BC Budget 2026 · Burnaby School District 41 · Arbitration funding"
        zh="BC Budget 2026 · Burnaby 学区 SD41 · 仲裁裁决拨款"
        lang={lang}
      />
    </p>

    {/* Headline (highlights $X.XM as a styled span) */}
    <h1 class="hero__headline">
      {(() => {
        const parts = headline.split(askAmount);
        if (parts.length === 2) {
          return (
            <>{parts[0]}<span class="hero__amount">{askAmount}</span>{parts[1]}</>
          );
        }
        return headline;
      })()}
    </h1>

    {/* Subheadline */}
    {subheadline && <p class="hero__sub">{subheadline}</p>}

    {/* Counter + Progress */}
    <div class="hero__counter">
      <SignatureCounter lang={lang} goal={goal} />
    </div>

    <ProgressBar lang={lang} />

    {/* Dual CTA */}
    <div class="hero__cta-row">
      <a class="btn btn--primary btn--lg" href={localizedUrl('/#act', lang)}>
        <I18nText
          en="Sign + email your MLA — 60 seconds"
          zh="签名 + 给你的 MLA 发邮件 — 60 秒"
          lang={lang}
        />
      </a>
      <a class="btn btn--ghost btn--lg" href={localizedUrl('/#why', lang)}>
        <I18nText
          en="Read the case first"
          zh="先看证据"
          lang={lang}
        />
      </a>
    </div>

    {/* Founder credit */}
    <p class="hero__founder sans">
      <I18nText en="Founded by " zh="发起人：" lang={lang} />
      <strong>{founderName}</strong>
      {founderRole && <span class="muted">, {founderRole}</span>}
      {' · '}
      <a href={localizedUrl('/#about', lang)}>
        <I18nText en="About this campaign" zh="关于本活动" lang={lang} />
      </a>
    </p>

  </div>
</section>

<script>
  // PAC banner client-side polling. SSR seeds the initial state from
  // Supabase at build time; without polling, every new PAC verification
  // would only show up after a Netlify rebuild. 60s interval matches
  // SignatoriesFeed. Updates textContent + hidden flag on existing
  // elements — does NOT innerHTML rebuild, so Astro's scoped CSS
  // (data-astro-cid attrs) keeps matching.
  document.querySelectorAll<HTMLElement>('[data-pac-banner]').forEach((banner) => {
    const url = banner.dataset.supabaseUrl;
    const key = banner.dataset.supabaseKey;
    const lang = (banner.dataset.lang === 'zh' ? 'zh' : 'en') as 'en' | 'zh';
    if (!url || !key) return;

    const schoolsEl = banner.querySelector<HTMLElement>('[data-pac-schools]');

    type Pac = { school: string; students: number };

    async function poll() {
      try {
        const res = await fetch(
          `${url}/rest/v1/public_pac_endorsements?select=school,students&order=approval_date.desc.nullslast`,
          { headers: { apikey: key!, Authorization: `Bearer ${key!}` } }
        );
        if (!res.ok) return;
        const pacs = (await res.json()) as Pac[];
        if (!Array.isArray(pacs)) return;

        if (pacs.length === 0) {
          banner.hidden = true;
          return;
        }
        banner.hidden = false;
        // List every PAC in the banner. CSS text-overflow:ellipsis on
        // .hero__pac-banner__text trims gracefully if the list grows
        // long. On the day there are 6+ PACs we can revisit the
        // "+N more" abbreviation.
        if (schoolsEl) schoolsEl.textContent = pacs.map((p) => p.school).join(', ');
      } catch {
        /* keep last good state */
      }
    }

    poll();
    setInterval(poll, 60_000);
  });
</script>

<style>
  .hero {
    padding: 48px 0 32px;
    background: var(--cream);
  }
  .hero__inner {
    max-width: 820px;
  }
  /* PAC endorsement banner (Prompt 12). Subtle but unmissable verified-
     style chip; clickable as a jump-link to the coalition section. */
  .hero__pac-banner {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--paper);
    border: 1px solid var(--success, #15803D);
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    margin-bottom: 12px;
    transition: background 0.15s, transform 0.15s;
    max-width: 100%;
  }
  .hero__pac-banner:hover {
    background: rgba(21, 128, 61, 0.06);
    transform: translateY(-1px);
  }
  .hero__pac-banner__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--success, #15803D);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .hero__pac-banner__text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .hero__pac-banner__chevron {
    color: var(--success, #15803D);
    font-weight: 700;
    flex-shrink: 0;
  }

  .hero__countdown-row {
    margin-bottom: 8px;
  }
  .hero__countdown-consequence {
    margin: 0 0 24px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 600px;
  }
  .hero__countdown-consequence strong {
    color: var(--warm);
    font-weight: 700;
  }
  .hero__kicker {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: 12px;
  }
  .hero__headline {
    font-family: var(--font-sans);
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 16px;
    max-width: 800px;
  }
  .hero__amount {
    color: var(--warm);
    font-style: italic;
    font-weight: 800;
    white-space: nowrap;
  }
  .hero__sub {
    font-size: clamp(17px, 2.2vw, 20px);
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0 0 28px;
    max-width: 640px;
  }
  .hero__counter {
    margin: 24px 0 8px;
  }
  .hero__cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 24px 0 16px;
  }
  .hero__founder {
    font-size: 14px;
    color: var(--ink-soft);
    margin-top: 16px;
  }
  .hero__founder a {
    color: var(--accent);
    text-decoration: none;
  }
  .hero__founder a:hover { text-decoration: underline; }

  /* Buttons (shared utility — could lift to tokens.css if reused widely) */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: var(--font-sans);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-md);
    border: 2px solid transparent;
    transition: background 0.15s, color 0.15s, border-color 0.15s, transform 0.1s;
    cursor: pointer;
  }
  .btn--lg {
    padding: 14px 24px;
    font-size: 16px;
  }
  .btn--primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }
  .btn--primary:hover {
    background: var(--accent-deep);
    border-color: var(--accent-deep);
    color: #fff;
    transform: translateY(-1px);
  }
  .btn--ghost {
    background: transparent;
    color: var(--accent);
    border-color: var(--line);
  }
  .btn--ghost:hover {
    border-color: var(--accent);
  }
  @media (prefers-reduced-motion: reduce) {
    .btn { transition: none; }
    .btn:hover { transform: none; }
  }
</style>
