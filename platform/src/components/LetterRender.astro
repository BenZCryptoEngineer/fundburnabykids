---
// LetterRender — bilingual rendering of a confirmed signer's public letter.
//
// Privacy contract (verified in build acceptance — see TODO.md item 2):
//   - Email is NEVER read here (the public_letters view doesn't expose it).
//   - Full surname is NEVER shown — only `last_initial`.
//   - Postal code is NEVER shown — neighbourhood substitutes.
//
// The letter is addressed to the signer's riding MLA when riding_id maps to
// a Burnaby riding. Outside Burnaby (riding_id = NULL), the greeting falls
// back to "Dear Minister of Education and Child Care".

import { getEntry } from 'astro:content';
import I18nText from '~/components/I18nText.astro';
import { formatDate, t } from '~/lib/i18n';
import type { Lang } from '~/lib/i18n';
import type { PublicLetter } from '~/lib/supabase';

interface Props {
  letter: PublicLetter;
  lang: Lang;
  /** Public, shareable URL to this letter — drives the copy-link button. */
  shareUrl: string;
}

const { letter, lang, shareUrl } = Astro.props;

type Mla = {
  id: string;
  name: string;
  riding: { en: string; zh: string };
  riding_id: string | null;
  is_minister?: boolean;
};

const mlasEntry = await getEntry('campaign', 'mlas');
const allMlas: Mla[] = (mlasEntry?.data as any)?.mlas ?? [];
const ridingMla = letter.riding_id
  ? allMlas.find((m) => m.riding_id === letter.riding_id && !m.is_minister)
  : null;
const ridingName = ridingMla ? t(ridingMla.riding, lang) : null;

const signerLabel = `${letter.first_name} ${letter.last_initial}.`;
const signedDate = formatDate(letter.signed_at, lang);
---

<article class="letter-card" lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <header class="letter-card__meta sans">
    <span class="letter-card__verified" aria-label={lang === 'zh' ? '已确认' : 'Verified'}>
      <span class="letter-card__check" aria-hidden="true">✓</span>
      <I18nText en="Verified" zh="已确认" lang={lang} />
    </span>
    <span class="letter-card__date">
      <I18nText en="Signed " zh="签署于 " lang={lang} />
      <time datetime={letter.signed_at}>{signedDate}</time>
    </span>
  </header>

  <p class="letter-card__signer sans">
    <strong>{signerLabel}</strong>
  </p>
  <p class="letter-card__locator sans muted">
    {letter.school}
    {letter.neighbourhood && <> · {letter.neighbourhood}</>}
    {ridingName && <> · {ridingName}</>}
  </p>

  <div class="letter-card__body">
    {ridingMla ? (
      <p class="letter-card__greeting">
        <I18nText en="Dear MLA " zh="尊敬的 MLA " lang={lang} />
        {ridingMla.name},
      </p>
    ) : (
      <p class="letter-card__greeting">
        <I18nText
          en="Dear Minister of Education and Child Care,"
          zh="尊敬的教育及儿童保育厅长："
          lang={lang}
        />
      </p>
    )}

    {lang === 'zh' ? (
      <>
        <p>
          我作为本拿比第 41 学区一名 <strong>{letter.school}</strong> 的学生家长写信给你。我的孩子在 {letter.grade} 年级，我所在的社区是 {letter.neighbourhood}。
        </p>
        <p>
          我请求 BC 省政府动用 2026 年度预算中 50 亿元的「应急款项」(Contingencies Vote)，全额拨付 SD41 面临的 940 万加元仲裁裁决款项。预算文件本身明确指出该笔拨款用于覆盖「当前集体谈判任务的成本」——这正是这笔款项的性质。
        </p>
        <p>三个理由说明为什么这件事重要：</p>
        <ol>
          <li>这笔成本不是 SD41 的过错。BCPSEA 已公开承认：如果他们在 2022 年正确解读了薪资表，这笔成本本应在当时获得全额拨款。SD41 并非那次谈判的当事方。</li>
          <li>学区已无任何缓冲。去年 SD41 从运营预算中削减了 420 万元，包括辅导员、校工、影响 1,200 名学生的 7 年级乐团，以及高级学习项目。无限制储备金约为 430 万元，不到仲裁裁决的一半。</li>
          <li>这是一项明确指向的拨款来源，而非泛泛而谈。50 亿元的应急款项正是为这类成本而存在——预算时点未能预见、源自集体谈判、金额尚不确定。940 万元仅占该笔拨款的 0.19%。</li>
        </ol>
        <p>
          我希望在 SD41 于 2026 年 5 月 27 日通过预算之前，能收到一份书面答复，说明省府是否将从「应急款项」中拨付这 940 万元。
        </p>
        <p class="letter-card__signoff">
          —{' '}
          <strong>{signerLabel}</strong>，{letter.school}
          {ridingName && (
            <>
              <br />
              {ridingName} 选区选民
            </>
          )}
        </p>
      </>
    ) : (
      <>
        <p>
          I am writing as a parent of a student at <strong>{letter.school}</strong> in Burnaby School District 41. My child is in Grade {letter.grade}, and we live in the {letter.neighbourhood} neighbourhood.
        </p>
        <p>
          I am asking the Province to fully fund the $9.4 million arbitration liability facing SD41 by drawing on the $5 billion Contingencies Vote in Budget 2026. The budget documents themselves describe that allocation as covering "current collective bargaining mandate costs" — which is precisely what this liability is.
        </p>
        <p>Three reasons this matters:</p>
        <ol>
          <li>The cost is not SD41's fault. BCPSEA has publicly acknowledged that the cost would have been fully funded in 2022 had they correctly interpreted the salary grid. SD41 was not a party to that negotiation.</li>
          <li>The district has no cushion left. Last year SD41 cut $4.2 million from the operating budget, including counsellors, custodians, the Grade 7 band program affecting 1,200 students, and advanced learning programs. Unrestricted reserves sit at roughly $4.3 million — less than half the arbitration liability.</li>
          <li>This is a specific funding source, not a general ask. The $5 billion Contingencies Vote exists precisely for costs like this — unforeseen, arising from collective bargaining, uncertain at budget time. $9.4M represents 0.19% of that allocation.</li>
        </ol>
        <p>
          I would appreciate a written response on whether the Province will fund the $9.4M from the Contingencies Vote before SD41 adopts its budget on May 27, 2026.
        </p>
        <p class="letter-card__signoff">
          —{' '}
          <strong>{signerLabel}</strong>, {letter.school}
          {ridingName && (
            <>
              <br />
              Constituent of {ridingName}
            </>
          )}
        </p>
      </>
    )}
  </div>

  <footer class="letter-card__footer sans">
    <button
      type="button"
      class="letter-card__share"
      data-share-url={shareUrl}
      data-share-copied={lang === 'zh' ? '已复制' : 'Copied!'}
      data-share-default={lang === 'zh' ? '复制链接' : 'Copy link'}
    >
      <I18nText en="Copy link" zh="复制链接" lang={lang} />
    </button>
    <code class="letter-card__url" aria-label={lang === 'zh' ? '分享链接' : 'Share URL'}>{shareUrl}</code>
  </footer>

  <p class="letter-card__withdraw sans">
    <a href={`${lang === 'zh' ? '/zh/withdraw/' : '/withdraw/'}${encodeURIComponent(letter.letter_token)}/`}>
      <I18nText
        en="Withdraw my signature"
        zh="撤回我的签名"
        lang={lang}
      />
    </a>
  </p>
</article>

<script>
  document.querySelectorAll<HTMLButtonElement>('.letter-card__share').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.shareUrl ?? location.href;
      const copied = btn.dataset.shareCopied ?? 'Copied!';
      const original = btn.dataset.shareDefault ?? btn.textContent ?? 'Copy link';
      try {
        await navigator.clipboard.writeText(url);
        btn.textContent = copied;
      } catch {
        // Fallback: select the URL element for manual copy.
        const code = btn.parentElement?.querySelector('.letter-card__url');
        if (code) {
          const range = document.createRange();
          range.selectNodeContents(code);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
        btn.textContent = copied;
      }
      setTimeout(() => { btn.textContent = original; }, 2000);
    });
  });
</script>

<style>
  .letter-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 32px;
    box-shadow: var(--shadow-sm);
    max-width: 720px;
  }
  .letter-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 13px;
    color: var(--muted);
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 20px;
  }
  .letter-card__verified {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--success);
    font-weight: 600;
  }
  .letter-card__check {
    display: inline-grid;
    place-items: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--success-soft);
    color: var(--success);
    font-size: 11px;
    font-weight: 700;
  }
  .letter-card__signer {
    font-size: 22px;
    margin: 0;
    color: var(--ink);
  }
  .letter-card__locator {
    font-size: 14px;
    margin: 4px 0 24px;
  }
  .letter-card__body {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink);
  }
  .letter-card__body p { margin: 0 0 16px; }
  .letter-card__body ol { padding-left: 24px; margin: 0 0 16px; }
  .letter-card__body li { margin-bottom: 10px; }
  .letter-card__greeting {
    font-weight: 600;
    margin-bottom: 16px !important;
  }
  .letter-card__signoff {
    margin-top: 24px !important;
    padding-top: 16px;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
  }
  .letter-card__footer {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    padding-top: 20px;
    margin-top: 24px;
    border-top: 1px solid var(--line);
    font-size: 13px;
  }
  .letter-card__share {
    background: var(--accent);
    color: #fff;
    border: 2px solid var(--accent);
    border-radius: var(--radius-md);
    padding: 8px 14px;
    font-family: var(--font-sans);
    font-weight: 600;
    cursor: pointer;
    flex-shrink: 0;
  }
  .letter-card__share:hover {
    background: var(--accent-deep);
    border-color: var(--accent-deep);
  }
  .letter-card__url {
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 6px 10px;
    color: var(--ink-soft);
    font-size: 12px;
    word-break: break-all;
    flex: 1;
    min-width: 0;
  }
  .muted { color: var(--muted); }
  @media (max-width: 560px) {
    .letter-card { padding: 24px 20px; }
    .letter-card__signer { font-size: 20px; }
    .letter-card__body { font-size: 15px; }
  }
  .letter-card__withdraw {
    margin: 16px 0 0;
    padding-top: 12px;
    text-align: center;
    font-size: 12px;
  }
  .letter-card__withdraw a {
    color: var(--muted);
    text-decoration: underline;
  }
  .letter-card__withdraw a:hover { color: var(--danger, #B91C1C); }
  @media print {
    .letter-card__footer,
    .letter-card__withdraw { display: none; }
    .letter-card {
      border: none;
      box-shadow: none;
      padding: 0;
    }
  }
</style>
