---
// FAQ accordion using native <details> elements (per source HTML pattern).
// CSS-only animation via the +/- summary indicator.

import { getEntry } from 'astro:content';
import { t } from '~/lib/i18n';
import I18nText from '~/components/I18nText.astro';
import type { Lang } from '~/lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const faqEntry = await getEntry('campaign', 'faq');
const items: Array<{
  id: string;
  q: { en: string; zh: string };
  a: { en: string; zh: string };
}> = (faqEntry?.data as any)?.faq ?? [];
---

<section class="faq" id="faq">
  <div class="wrap">
    <header class="faq__header">
      <p class="kicker sans">
        <I18nText
          en="Common questions"
          zh="常见问题"
          lang={lang}
        />
      </p>
      <h2>
        <I18nText
          en="Before you sign — what people ask."
          zh="签名之前 — 大家会问的问题。"
          lang={lang}
        />
      </h2>
    </header>

    <div class="faq__list">
      {items.map((it) => (
        <details class="faq__item" id={`faq-${it.id}`}>
          <summary class="faq__q sans">{t(it.q, lang)}</summary>
          <div class="faq__a">
            <p>{t(it.a, lang)}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq {
    padding: 64px 0;
    background: var(--paper);
    border-top: 1px solid var(--line);
  }
  .faq__header {
    margin-bottom: 32px;
    max-width: 640px;
  }
  .kicker {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 12px;
  }
  .faq__header h2 {
    font-family: var(--font-sans);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    color: var(--ink);
  }
  .faq__list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq__item {
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    background: var(--paper);
    transition: border-color 0.15s;
  }
  .faq__item[open] {
    border-color: var(--accent);
  }
  .faq__q {
    cursor: pointer;
    padding: 16px 48px 16px 20px;
    font-size: 16px;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.4;
    position: relative;
    list-style: none;
  }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::after {
    content: "+";
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-sans);
    font-size: 22px;
    font-weight: 400;
    color: var(--muted);
    line-height: 1;
  }
  .faq__item[open] .faq__q::after {
    content: "−";
    color: var(--accent);
  }
  .faq__a {
    padding: 0 20px 20px;
    color: var(--ink-soft);
    line-height: 1.65;
  }
  .faq__a p {
    margin: 0;
  }
</style>
