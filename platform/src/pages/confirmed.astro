---
import CampaignLayout from '~/layouts/CampaignLayout.astro';
import I18nText from '~/components/I18nText.astro';
import { pickLang, localizedUrl } from '~/lib/i18n';

const lang = pickLang(Astro.url.pathname);
const status = Astro.url.searchParams.get('status') || 'ok';
const isAlready = status === 'already';

// confirm-signature redirects with ?t=<letter_token> on success so we can
// surface the signer's shareable letter URL right here, no extra DB lookup.
// We don't validate the token shape against the DB — wrong tokens just 404
// on the linked page. ?t is absent for the `already` branch by design
// (we don't expose tokens for repeat clicks).
const letterToken = (Astro.url.searchParams.get('t') ?? '').trim();
const safeToken = /^[A-Za-z0-9_-]{16,128}$/.test(letterToken) ? letterToken : '';
const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? 'https://fundburnabykids.ca';
const letterPath = lang === 'zh' ? '/zh/letters/' : '/letters/';
const letterUrl = safeToken ? `${siteOrigin}${letterPath}${encodeURIComponent(safeToken)}` : null;
// Withdraw URL — same letter_token doubles as the withdrawal credential.
// Surface it here (alongside the letter URL) so signers don't have to dig
// through the letter page or privacy policy to find the self-serve flow.
const withdrawPath = lang === 'zh' ? '/zh/withdraw/' : '/withdraw/';
const withdrawUrl = safeToken ? `${siteOrigin}${withdrawPath}${encodeURIComponent(safeToken)}/` : null;
---

<CampaignLayout
  lang={lang}
  noindex
  title={lang === 'zh' ? '签名已确认 — Fund Burnaby Kids' : 'Signature confirmed — Fund Burnaby Kids'}
>
  <section class="confirm-page">
    <div class="wrap">
      <div class="confirm-card">
        <div class="confirm-icon" aria-hidden="true">✓</div>
        <h1>
          {isAlready ? (
            <I18nText
              en="You're already signed."
              zh="你已经签过名了。"
              lang={lang}
            />
          ) : (
            <I18nText
              en="Your signature is confirmed."
              zh="你的签名已确认。"
              lang={lang}
            />
          )}
        </h1>
        <p class="confirm-lede">
          <I18nText
            en="Your name is now on the public record we will show MLAs, the Minister, and reporters. Thank you."
            zh="你的名字现在已经进入我们将向 MLA、教育部长和媒体公开的名单。谢谢。"
            lang={lang}
          />
        </p>

        {letterUrl && (
          <div class="confirm-letter">
            <h2 class="sans">
              <I18nText en="Your letter" zh="你的信件页面" lang={lang} />
            </h2>
            <p class="confirm-letter__lede">
              <I18nText
                en="Every confirmed signer gets a permanent page that shows their letter to the MLA — share it with neighbours, post it on WeChat or Twitter."
                zh="每位已确认签署人都有一个永久页面，展示他们写给 MLA 的信件 —— 可以分享给邻居、发到微信或 Twitter。"
                lang={lang}
              />
            </p>
            <div class="confirm-letter__row">
              <a class="btn btn--primary btn--small" href={letterUrl} target="_blank" rel="noopener">
                <I18nText en="Open my letter →" zh="打开我的信件页面 →" lang={lang} />
              </a>
              <button
                type="button"
                class="confirm-letter__copy"
                data-copy-url={letterUrl}
                data-copied={lang === 'zh' ? '已复制' : 'Copied!'}
                data-default={lang === 'zh' ? '复制链接' : 'Copy link'}
              >
                <I18nText en="Copy link" zh="复制链接" lang={lang} />
              </button>
            </div>
            <code class="confirm-letter__url" aria-label={lang === 'zh' ? '链接' : 'URL'}>{letterUrl}</code>
          </div>
        )}

        {/* What happens next — timeline that answers "where does my
            signature actually go?" Per Prompt 10 self-efficacy
            framing: visitors who understand the procedural path are
            more likely to share. */}
        <div class="confirm-timeline">
          <h2 class="sans">
            <I18nText en="What happens next" zh="接下来会发生什么" lang={lang} />
          </h2>
          <ul>
            <li>
              <span class="confirm-timeline__icon" aria-hidden="true">📨</span>
              <I18nText
                en="Your email is in 7 MLA inboxes today — staff sort by postal code, yours is in your riding's pile."
                zh="你的邮件今天就进了 7 位 MLA 的收件箱 — 工作人员按邮编分流，你的会进对应选区的那一摞。"
                lang={lang}
              />
            </li>
            <li>
              <span class="confirm-timeline__icon" aria-hidden="true">🏛️</span>
              <I18nText
                en="At 500 confirmed signers, we print every letter and hand-deliver to all 5 Burnaby MLA constituency offices alongside local press outreach."
                zh="累积到 500 名确认签名后，我们把所有信件打印出来，亲手送到 5 位 Burnaby MLA 选区办公室，同步联系本地媒体。"
                lang={lang}
              />
            </li>
            <li>
              <span class="confirm-timeline__icon" aria-hidden="true">🎯</span>
              <I18nText
                en="Goal: 2,000 parents by May 27 budget vote (≈400 per riding) — at that scale the petition becomes a political object the Education Minister must respond to in writing."
                zh="目标：5 月 27 日预算通过日前到 2000 名家长（每区约 400）— 达到这个规模，请愿就成为 Education Minister 必须书面回应的政治文件。"
                lang={lang}
              />
            </li>
            <li>
              <span class="confirm-timeline__icon" aria-hidden="true">📅</span>
              <I18nText
                en="After May 27, the cuts are locked in for the 2026-27 school year. There's no &ldquo;next chance&rdquo; before September."
                zh="5 月 27 日之后，削减将锁定到 2026-27 学年。9 月之前没有&ldquo;下一次机会&rdquo;。"
                lang={lang}
              />
            </li>
          </ul>
        </div>

        {/* Tell 2 other parents — primary share CTA per Prompt 10.
            navigator.share is the mobile-native picker; the explicit
            WhatsApp + Twitter + Copy buttons cover desktop browsers
            (where navigator.share isn't supported) and any user who
            prefers a specific channel. */}
        <div class="confirm-share">
          <h2 class="sans">
            <I18nText
              en="📲 Tell 2 other Burnaby parents"
              zh="📲 告诉 2 位本拿比家长"
              lang={lang}
            />
          </h2>
          <p class="confirm-share__lede">
            <I18nText
              en="One parent telling another is the fastest path from 100 signatures to 1,000."
              zh="一位家长告诉另一位家长 — 这是从 100 个签名到 1,000 个签名最快的方法。"
              lang={lang}
            />
          </p>
          <div
            class="confirm-share__buttons"
            data-share-text={lang === 'zh'
              ? '我刚签了 Fund Burnaby Kids — 一个要求 BC 省政府在 SD41 学区 5 月 27 日通过 2026-27 预算之前全额拨付 940 万加元仲裁裁决款的活动。60 秒就能加入：https://fundburnabykids.ca/'
              : "I just signed Fund Burnaby Kids — a campaign asking BC to fully fund the $9.4M arbitration shortfall before SD41 adopts its 2026-27 budget on May 27. 60 seconds to add your name: https://fundburnabykids.ca/"}
            data-share-title={lang === 'zh' ? 'Fund Burnaby Kids' : 'Fund Burnaby Kids'}
            data-share-url="https://fundburnabykids.ca/"
          >
            <button type="button" class="btn btn--primary btn--small" data-native-share>
              <I18nText en="📲 Share" zh="📲 分享" lang={lang} />
            </button>
            <a
              class="btn btn--ghost btn--small"
              data-share-whatsapp
              target="_blank"
              rel="noopener noreferrer"
            >WhatsApp</a>
            <a
              class="btn btn--ghost btn--small"
              data-share-twitter
              target="_blank"
              rel="noopener noreferrer"
            >Twitter / X</a>
            <button
              type="button"
              class="confirm-letter__copy"
              data-share-copy
              data-copied={lang === 'zh' ? '已复制 ✓' : 'Copied ✓'}
              data-default={lang === 'zh' ? '复制链接' : 'Copy link'}
            >
              <I18nText en="Copy link" zh="复制链接" lang={lang} />
            </button>
          </div>
        </div>

        <div class="confirm-next">
          <h2 class="sans">
            <I18nText en="What else you can do" zh="其他可以做的事" lang={lang} />
          </h2>
          <ul>
            <li>
              <I18nText
                en="If you haven't sent the pre-filled email to your MLA yet,"
                zh="如果你还没把预填邮件发给你的 MLA，"
                lang={lang}
              />{' '}
              <a href={localizedUrl('/#act', lang)}>
                <I18nText en="open it now" zh="现在打开" lang={lang} />
              </a>.
            </li>
            <li>
              <I18nText
                en="If your child's PAC hasn't endorsed yet,"
                zh="如果你孩子学校的 PAC 还没正式 endorse，"
                lang={lang}
              />{' '}
              <a href={localizedUrl('/#coalition', lang)}>
                <I18nText en="here's the kit they need" zh="这里是他们需要的资料包" lang={lang} />
              </a>.
            </li>
            <li>
              <I18nText
                en="If you have questions or a journalist contact,"
                zh="如果有疑问，或有记者联络渠道，"
                lang={lang}
              />{' '}
              <a href="mailto:ben@fundburnabykids.ca">
                <I18nText en="email Ben directly" zh="直接发邮件给 Ben" lang={lang} />
              </a>.
            </li>
          </ul>
        </div>

        {withdrawUrl && (
          <div class="confirm-withdraw-block">
            <h2 class="sans">
              <I18nText
                en="Want to remove your signature later?"
                zh="想以后移除你的签名？"
                lang={lang}
              />
            </h2>
            <p class="confirm-withdraw-block__lede">
              <I18nText
                en="Save this link. It removes your name from the public list — no questions asked, takes two clicks."
                zh="保存这个链接。点开就能从公开名单中移除你的名字 — 两步确认，无须解释。"
                lang={lang}
              />
            </p>
            <div class="confirm-withdraw-block__row">
              <a class="btn btn--ghost btn--small" href={withdrawUrl}>
                <I18nText en="Open the withdraw page →" zh="打开移除页面 →" lang={lang} />
              </a>
              <button
                type="button"
                class="confirm-letter__copy"
                data-copy-url={withdrawUrl}
                data-copied={lang === 'zh' ? '已复制' : 'Copied!'}
                data-default={lang === 'zh' ? '复制链接' : 'Copy link'}
              >
                <I18nText en="Copy link" zh="复制链接" lang={lang} />
              </button>
            </div>
            <code class="confirm-letter__url" aria-label={lang === 'zh' ? '移除链接' : 'Withdraw URL'}>{withdrawUrl}</code>
          </div>
        )}

        <p class="confirm-back">
          <a href={localizedUrl('/', lang)}>
            ← <I18nText en="Back to campaign" zh="返回主页" lang={lang} />
          </a>
        </p>
      </div>
    </div>
  </section>
</CampaignLayout>

<style>
  .confirm-page {
    padding: 64px 0;
  }
  .confirm-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 48px 32px;
    box-shadow: var(--shadow-sm);
  }
  .confirm-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--success-soft);
    color: var(--success);
    display: grid;
    place-items: center;
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 24px;
  }
  .confirm-page h1 {
    font-size: 28px;
    margin-bottom: 12px;
  }
  .confirm-lede {
    font-size: 18px;
    color: var(--ink-soft);
    margin-bottom: 32px;
  }
  .confirm-next {
    border-top: 1px solid var(--line);
    padding-top: 24px;
    margin-bottom: 24px;
  }
  .confirm-next h2 {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    margin-bottom: 12px;
    font-weight: 600;
  }
  .confirm-next ul {
    list-style: none;
    padding: 0;
  }
  .confirm-next li {
    padding-left: 24px;
    position: relative;
    margin-bottom: 12px;
    line-height: 1.6;
  }
  .confirm-next li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  /* What happens next — timeline. Slightly heavier visual weight than
     the action list below, since this is the procedural-transparency
     answer to "where does my signature go?" */
  .confirm-timeline {
    border-top: 1px solid var(--line);
    padding-top: 24px;
    margin-bottom: 24px;
  }
  .confirm-timeline h2 {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    margin-bottom: 16px;
    font-weight: 600;
  }
  .confirm-timeline ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .confirm-timeline li {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 8px;
    margin-bottom: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
    font-size: 14px;
  }
  .confirm-timeline li:last-child { margin-bottom: 0; }
  .confirm-timeline__icon {
    font-size: 16px;
    line-height: 1.4;
  }

  /* Tell 2 other parents — share block. Highest-leverage call-to-
     action on this page; visual weight should match the letter block. */
  .confirm-share {
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: 20px 22px;
    margin-bottom: 24px;
  }
  .confirm-share h2 {
    font-size: 16px;
    margin: 0 0 8px;
    color: var(--ink);
    font-weight: 700;
  }
  .confirm-share__lede {
    margin: 0 0 16px;
    color: var(--ink-soft);
    font-size: 14px;
    line-height: 1.5;
  }
  .confirm-share__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .confirm-back a {
    text-decoration: none;
    color: var(--accent);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
  }
  .confirm-back a:hover { color: var(--accent-deep); }

  .confirm-withdraw-block {
    border-top: 1px solid var(--line);
    padding-top: 24px;
    margin: 24px 0;
  }
  .confirm-withdraw-block h2 {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    margin-bottom: 12px;
    font-weight: 600;
  }
  .confirm-withdraw-block__lede {
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0 0 16px;
    font-size: 14px;
  }
  .confirm-withdraw-block__row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 12px;
  }
  .btn--ghost {
    background: var(--paper);
    color: var(--accent);
    border-color: var(--line);
  }
  .btn--ghost:hover {
    border-color: var(--accent);
    color: var(--accent-deep);
  }

  .confirm-letter {
    border-top: 1px solid var(--line);
    padding-top: 24px;
    margin-bottom: 24px;
  }
  .confirm-letter h2 {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    margin-bottom: 12px;
    font-weight: 600;
  }
  .confirm-letter__lede {
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0 0 16px;
  }
  .confirm-letter__row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 12px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 16px;
    border-radius: var(--radius-md);
    border: 2px solid transparent;
    font-family: var(--font-sans);
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
  }
  .btn--small { font-size: 14px; padding: 8px 14px; }
  .btn--primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }
  .btn--primary:hover {
    background: var(--accent-deep);
    border-color: var(--accent-deep);
  }
  .confirm-letter__copy {
    background: var(--paper);
    color: var(--accent);
    border: 2px solid var(--line);
    border-radius: var(--radius-md);
    padding: 8px 14px;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
  }
  .confirm-letter__copy:hover { border-color: var(--accent); }
  .confirm-letter__url {
    display: block;
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 8px 12px;
    color: var(--ink-soft);
    font-size: 12px;
    word-break: break-all;
  }
</style>

<script>
  // Copy-link buttons (used by both letter URL block and share block).
  document.querySelectorAll<HTMLButtonElement>('.confirm-letter__copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      // Two flavours of copy: data-copy-url (specific URL like the
      // letter or withdraw URL) OR no data-copy-url + parent has
      // data-share-text (the share block — copy the share text).
      let url = btn.dataset.copyUrl ?? '';
      if (!url && btn.dataset.shareCopy !== undefined) {
        url = btn.closest<HTMLElement>('.confirm-share__buttons')?.dataset.shareText ?? '';
      }
      const copied = btn.dataset.copied ?? 'Copied!';
      const original = btn.dataset.default ?? btn.textContent ?? 'Copy link';
      try {
        await navigator.clipboard.writeText(url);
      } catch {
        // Best-effort fallback: select the URL text for manual copy.
        const code = btn.parentElement?.parentElement?.querySelector('.confirm-letter__url');
        if (code) {
          const range = document.createRange();
          range.selectNodeContents(code);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
      }
      btn.textContent = copied;
      setTimeout(() => { btn.textContent = original; }, 2000);
    });
  });

  // Share block — wire up navigator.share + WhatsApp + Twitter intent links.
  document.querySelectorAll<HTMLElement>('.confirm-share__buttons').forEach((wrap) => {
    const text = wrap.dataset.shareText ?? '';
    const title = wrap.dataset.shareTitle ?? 'Fund Burnaby Kids';
    const url = wrap.dataset.shareUrl ?? 'https://fundburnabykids.ca/';
    const encoded = encodeURIComponent(text);

    // WhatsApp web/app intent. wa.me?text= works on both web + native.
    const whatsappEl = wrap.querySelector<HTMLAnchorElement>('[data-share-whatsapp]');
    if (whatsappEl) whatsappEl.href = `https://wa.me/?text=${encoded}`;

    // Twitter / X intent. The share text already includes the URL,
    // so we don't pass &url= (which would duplicate it in the tweet).
    const twitterEl = wrap.querySelector<HTMLAnchorElement>('[data-share-twitter]');
    if (twitterEl) twitterEl.href = `https://twitter.com/intent/tweet?text=${encoded}`;

    // navigator.share — mobile system picker. Opens the OS share sheet
    // if the browser supports it (most mobile browsers do); on desktop
    // most browsers don't, so the explicit WhatsApp/Twitter/Copy buttons
    // remain the working path.
    const nativeBtn = wrap.querySelector<HTMLButtonElement>('[data-native-share]');
    if (nativeBtn) {
      nativeBtn.addEventListener('click', async () => {
        if (typeof navigator.share === 'function') {
          try {
            await navigator.share({ title, text, url });
          } catch {
            /* user cancelled or share failed — silent */
          }
        } else {
          // Desktop fallback: copy the share text + flash the button label.
          try { await navigator.clipboard.writeText(text); } catch {}
          const original = nativeBtn.textContent;
          nativeBtn.textContent = 'Copied ✓';
          setTimeout(() => { nativeBtn.textContent = original; }, 2000);
        }
      });
    }
  });
</script>
