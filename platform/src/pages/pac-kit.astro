---
// Printable PAC Endorsement Kit — same content as the modal but laid
// out for print (Letter, two pages). Single source of truth: pac-kit.yaml.
//
// Linked from the modal's "printable version" footer link and from
// any direct emails to PAC chairs.

import { getEntry } from 'astro:content';
import { pickLang, t } from '~/lib/i18n';
import I18nText from '~/components/I18nText.astro';
import SvgVisual from '~/components/SvgVisual.astro';
import '~/styles/tokens.css';

const lang = pickLang(Astro.url.pathname);
const meta = (await getEntry('campaign', 'fund-burnaby-kids'))?.data as any;
const kit = (await getEntry('campaign', 'pac-kit'))?.data as any;

const brandName: string = meta?.brand_name ? t(meta.brand_name, lang) : 'Fund Burnaby Kids';
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{lang === 'zh' ? 'PAC Endorsement 资料包 (打印版)' : 'PAC Endorsement Kit (Printable)'} — {brandName}</title>
  <meta name="robots" content="noindex" />
</head>
<body data-lang={lang}>

<article class="kit">
  {/* Page 1 — visual case */}
  <header class="kit__masthead">
    <h1 class="kit__title sans">
      <I18nText
        en="PAC Endorsement Kit"
        zh="PAC Endorsement 资料包"
        lang={lang}
      />
    </h1>
    <p class="kit__subtitle sans">{brandName} — A {brandName === 'Fund Burnaby Kids' ? 'Burnaby Kids First' : ''} campaign</p>
    <p class="kit__meta sans muted">
      <I18nText en="Printed " zh="打印于 " lang={lang} />
      {new Intl.DateTimeFormat(lang === 'zh' ? 'zh-CN' : 'en-CA', { year: 'numeric', month: 'long', day: 'numeric' }).format(new Date())}
      {' · '}
      <I18nText en="2 pages" zh="2 页" lang={lang} />
    </p>
  </header>

  <section class="kit__visuals">
    <h2 class="sans">
      <I18nText en="The case in four diagrams" zh="四张图说明" lang={lang} />
    </h2>
    <div class="kit__visual-grid">
      <SvgVisual visual="responsibility" lang={lang} headline={lang === 'zh' ? '1 · 谁应负责' : '1 · WHO is responsible'} />
      <SvgVisual visual="money" lang={lang} headline={lang === 'zh' ? '2 · 钱在哪里' : '2 · WHERE the money lives'} />
      <SvgVisual visual="scale" lang={lang} headline={lang === 'zh' ? '3 · 数量级' : '3 · SCALE of the gap'} />
      <SvgVisual visual="cascade" lang={lang} headline={lang === 'zh' ? '4 · 后果如何叠加' : '4 · CONSEQUENCES if unfunded'} />
    </div>
  </section>

  <div class="page-break"></div>

  {/* Page 2 — written brief */}
  <section class="kit__brief">
    <h2 class="sans">
      <I18nText en="The case in full" zh="完整案情" lang={lang} />
    </h2>

    {kit?.briefing?.items && (
      <ul class="kit__briefing">
        {kit.briefing.items.map((item: any) => <li>{t(item, lang)}</li>)}
      </ul>
    )}

    {(kit?.do || kit?.dont) && (
      <div class="kit__section">
        <h3 class="sans">
          {kit.intro?.heading
            ? t(kit.intro.heading, lang)
            : <I18nText en="What endorsing means" zh="endorse 意味着什么" lang={lang} />}
        </h3>
        <div class="kit__do-dont">
          {kit.do && (
            <div class="kit__do-dont-col kit__do-dont-col--do">
              <h4 class="sans">{t(kit.do.heading, lang)}</h4>
              <ul>
                {(kit.do.items ?? []).map((it: any) => <li>{t(it, lang)}</li>)}
              </ul>
            </div>
          )}
          {kit.dont && (
            <div class="kit__do-dont-col kit__do-dont-col--dont">
              <h4 class="sans">{t(kit.dont.heading, lang)}</h4>
              <ul>
                {(kit.dont.items ?? []).map((it: any) => <li>{t(it, lang)}</li>)}
              </ul>
            </div>
          )}
        </div>
      </div>
    )}

    {kit?.motion_text?.body && (
      <div class="kit__section">
        <h3 class="sans">
          {kit.motion_text.heading
            ? t(kit.motion_text.heading, lang)
            : <I18nText en="Standard motion text" zh="标准动议文字" lang={lang} />}
        </h3>
        <blockquote class="kit__motion">
          {t(kit.motion_text.body, lang)}
        </blockquote>
      </div>
    )}

    {kit?.qa?.items && Array.isArray(kit.qa.items) && (
      <div class="kit__section">
        <h3 class="sans">
          {kit.qa.heading
            ? t(kit.qa.heading, lang)
            : <I18nText en="Anticipated questions" zh="可能的提问" lang={lang} />}
        </h3>
        <dl class="kit__qa">
          {kit.qa.items.map((qa: any) => (
            <>
              <dt class="sans">{t(qa.q, lang)}</dt>
              <dd>{t(qa.a, lang)}</dd>
            </>
          ))}
        </dl>
      </div>
    )}

    {kit?.sources?.items && (
      <div class="kit__section">
        <h3 class="sans">
          {kit.sources.heading
            ? t(kit.sources.heading, lang)
            : <I18nText en="Primary sources" zh="一手来源" lang={lang} />}
        </h3>
        <ul class="kit__sources">
          {kit.sources.items.map((s: any) => (
            <li>
              {typeof s.label === 'string' ? s.label : t(s.label, lang)}
              {' — '}
              <span class="kit__url">{s.url}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>

  <footer class="kit__footer">
    <p class="sans">
      <strong>{brandName}</strong>
      {' · '}
      <I18nText en="Founded by" zh="发起人" lang={lang} /> {meta?.founder?.name ?? 'Ben Zhou'}
      {' · '}
      <a href="https://fundburnabykids.ca">fundburnabykids.ca</a>
    </p>
    <p class="sans muted">
      <I18nText
        en="Submit your endorsement at fundburnabykids.ca/#coalition. We verify within 24 hours."
        zh="在 fundburnabykids.ca/#coalition 提交 endorsement。24 小时内验证。"
        lang={lang}
      />
    </p>
  </footer>
</article>

<style>
  body {
    background: #fff;
    color: var(--ink);
    font-family: var(--font-serif);
    line-height: 1.5;
    font-size: 11pt;
    margin: 0;
    padding: 0;
  }
  body[data-lang="zh"] {
    font-family: var(--font-sans-zh);
  }

  .kit {
    max-width: 7.5in;
    margin: 0 auto;
    padding: 0.5in;
  }

  .kit__masthead {
    border-bottom: 2px solid var(--accent);
    padding-bottom: 12px;
    margin-bottom: 20px;
  }
  .kit__title {
    font-size: 22pt;
    font-weight: 800;
    color: var(--accent);
    margin: 0 0 4px;
    letter-spacing: -0.01em;
  }
  .kit__subtitle {
    font-size: 11pt;
    color: var(--ink-soft);
    margin: 0 0 4px;
  }
  .kit__meta {
    font-size: 9pt;
    margin: 0;
  }

  .kit__visuals h2,
  .kit__brief h2 {
    font-size: 14pt;
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .kit__visual-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 8px;
  }
  .kit__visual-grid :global(.svg-visual) {
    background: #fff;
    border: 1px solid var(--line);
    padding: 12px;
    border-radius: 4px;
  }
  .kit__visual-grid :global(.svg-visual__media svg) {
    max-height: 2.4in;
  }

  .kit__briefing {
    margin: 0 0 16px;
    padding-left: 20px;
  }
  .kit__briefing li {
    margin-bottom: 6px;
    line-height: 1.5;
  }

  .kit__section {
    margin-bottom: 16px;
  }
  .kit__section h3 {
    font-size: 11pt;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 12px 0 6px;
  }
  .kit__section h4 {
    font-size: 10pt;
    margin: 0 0 4px;
    color: var(--ink);
  }

  .kit__do-dont {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .kit__do-dont-col {
    background: #FAF7F1;
    padding: 8px 12px;
    border-left: 2px solid var(--line);
    border-radius: 2px;
  }
  .kit__do-dont-col--do { border-left-color: var(--success); }
  .kit__do-dont-col--dont { border-left-color: var(--warm); }
  .kit__do-dont-col ul {
    margin: 0;
    padding-left: 16px;
    font-size: 9.5pt;
  }
  .kit__do-dont-col li { margin-bottom: 2px; }

  .kit__motion {
    font-style: italic;
    background: #FAF7F1;
    padding: 12px 16px;
    border-left: 3px solid var(--accent);
    margin: 0;
    font-size: 10.5pt;
    line-height: 1.5;
  }

  .kit__qa { margin: 0; }
  .kit__qa dt {
    font-weight: 700;
    margin-top: 8px;
    color: var(--ink);
  }
  .kit__qa dd {
    margin: 2px 0 8px;
    color: var(--ink-soft);
    font-size: 10pt;
  }

  .kit__sources {
    margin: 0;
    padding-left: 20px;
    font-size: 9.5pt;
  }
  .kit__sources li { margin-bottom: 4px; }
  .kit__url { color: var(--muted); word-break: break-all; }

  .kit__footer {
    margin-top: 24px;
    padding-top: 12px;
    border-top: 1px solid var(--line);
    font-size: 9pt;
  }
  .kit__footer p { margin: 2px 0; }

  .muted { color: var(--muted); }

  /* Print */
  @media print {
    @page {
      size: letter;
      margin: 0.45in 0.55in;
    }
    body { font-size: 10.5pt; }
    .kit { padding: 0; max-width: none; }
    .page-break { page-break-after: always; height: 0; }
  }
  /* On screen, simulate a page break with extra space */
  @media screen {
    .page-break {
      height: 32px;
      border-top: 1px dashed var(--line);
      margin-top: 32px;
    }
  }
</style>
</body>
</html>
