---
// Post-form-submit landing. User just signed; now they need to click the
// confirmation link in the email to complete the signature.
//
// This is DIFFERENT from /confirmed: that one is reached AFTER they click
// the email link.

import CampaignLayout from '~/layouts/CampaignLayout.astro';
import I18nText from '~/components/I18nText.astro';
import { pickLang, localizedUrl } from '~/lib/i18n';

const lang = pickLang(Astro.url.pathname);
---

<CampaignLayout
  lang={lang}
  noindex
  title={lang === 'zh' ? '查收邮件 — Fund Burnaby Kids' : 'Check your email — Fund Burnaby Kids'}
>
  <section class="thanks-page">
    <div class="wrap">
      <div class="thanks-card" data-variant="signature">
        {/* PAC submission lands here too via ?form=pac. We swap the headline
            client-side so the signature flow renders without flicker for the
            common case (the signature 303 has no query string). */}
        <div class="thanks-icon" aria-hidden="true">📬</div>
        <h1 data-pac-headline-target>
          <I18nText
            en="Check your email"
            zh="请查收邮件"
            lang={lang}
          />
        </h1>
        <p class="thanks-lede" data-pac-lede-target>
          <I18nText
            en="We just sent a confirmation link to your email. Click it within 48 hours to add your name to the public count."
            zh="我们刚向你的邮箱发了一封确认邮件。请在 48 小时内点击链接，将你的名字加入公开计数。"
            lang={lang}
          />
        </p>
        <p class="thanks-lede" data-pac-only hidden>
          <I18nText
            en="We received your PAC endorsement. We'll verify it personally — usually within 24 hours — and email the chair address you provided."
            zh="我们已收到你的 PAC endorsement，会人工核实（通常 24 小时内）并通过邮件回复你填写的主席邮箱。"
            lang={lang}
          />
        </p>

        <div class="thanks-next">
          <h2 class="sans">
            <I18nText en="If you don't see it" zh="如果没收到" lang={lang} />
          </h2>
          <ul>
            <li>
              <I18nText
                en="Check your spam / promotions folder. New domains sometimes land there."
                zh="检查垃圾邮件 / 促销标签。新域名有时会被分到那里。"
                lang={lang}
              />
            </li>
            <li>
              <I18nText
                en="The email comes from"
                zh="邮件发件人是"
                lang={lang}
              />
              <strong>campaign@fundburnabykids.ca</strong>
              {' '}
              <I18nText
                en="with subject"
                zh="主题是"
                lang={lang}
              />
              {' '}
              <em>"One click left: confirm your signature for Burnaby kids"</em>
            </li>
            <li>
              <I18nText
                en="Still nothing after 5 minutes? Email"
                zh="5 分钟还没收到？邮件给"
                lang={lang}
              />{' '}
              <a href="mailto:hello@fundburnabykids.ca">hello@fundburnabykids.ca</a>
              {' '}
              <I18nText en="and we'll fix it." zh="，我们处理。" lang={lang} />
            </li>
          </ul>
        </div>

        <div class="thanks-letter-note" data-mailto-block hidden>
          <h2 class="sans">
            <I18nText
              en="The email to your MLA is ready"
              zh="给 MLA 的邮件已准备好"
              lang={lang}
            />
          </h2>
          <p>
            <I18nText
              en="Pre-filled with your name, school, and grade. Click to open it in your default email app, then hit Send."
              zh="已经预填了你的姓名、学校、年级。点击下面的按钮在你的默认邮件应用中打开，按 Send 发送即可。"
              lang={lang}
            />
          </p>
          <p class="thanks-letter-actions">
            <a class="btn btn--primary" href="#" data-mailto-link target="_blank" rel="noopener">
              <I18nText
                en="Open the email →"
                zh="打开邮件 →"
                lang={lang}
              />
            </a>
          </p>
          <p class="sans muted small">
            <I18nText
              en="No email app set up? You can copy the email body below and paste it into your webmail."
              zh="还没设默认邮件应用？可以复制下方内容，贴到 Gmail / Outlook 等网页邮箱中发送。"
              lang={lang}
            />
          </p>
          <details class="thanks-letter-fallback">
            <summary class="sans">
              <I18nText en="Show plain text + addresses" zh="显示纯文本和邮件地址" lang={lang} />
            </summary>
            <div class="thanks-letter-fallback__body">
              <p><strong><I18nText en="To:" zh="收件人：" lang={lang} /></strong> <code data-mailto-to></code></p>
              <p><strong><I18nText en="Cc:" zh="抄送：" lang={lang} /></strong> <code data-mailto-cc></code></p>
              <p><strong><I18nText en="Subject:" zh="主题：" lang={lang} /></strong> <span data-mailto-subject></span></p>
              <pre data-mailto-body class="thanks-letter-body"></pre>
            </div>
          </details>
        </div>

        <script>
          // PAC variant swap. submit.ts redirects PAC endorsements to
          // /confirm-thanks/?form=pac so they don't see "Check your email"
          // (PAC chairs don't get a confirmation email, only an admin
          // notification fires). Signature flow has no ?form param.
          (function pacSwap() {
            const params = new URLSearchParams(window.location.search);
            if (params.get('form') !== 'pac') return;
            const card = document.querySelector<HTMLElement>('.thanks-card[data-variant="signature"]');
            if (card) card.setAttribute('data-variant', 'pac');
            const headline = document.querySelector<HTMLElement>('[data-pac-headline-target]');
            const lede = document.querySelector<HTMLElement>('[data-pac-lede-target]');
            const pacLede = document.querySelector<HTMLElement>('[data-pac-only]');
            const lang = document.documentElement.lang;
            if (headline) headline.textContent = lang === 'zh' ? '已收到你的 endorsement' : 'Endorsement received';
            if (lede) lede.hidden = true;
            if (pacLede) pacLede.hidden = false;
          })();

          // Read the mailto URL stashed by ActionForm's submit handler and
          // wire up the actionable button + plain-text fallback. We render
          // a real <a href="mailto:..."> click target instead of opening
          // mailto from JS (current-tab nav hazard on browsers without a
          // mailto handler — see the corresponding comment in
          // ActionForm.astro).
          const KEY = 'fbk_mailto';
          let url = '';
          try { url = sessionStorage.getItem(KEY) || ''; } catch { /* ignore */ }
          if (!url) {
            // Nothing stashed — leave the block hidden (not everyone opts
            // in to "also open the email"; some skip the consent box).
          } else {
            const block = document.querySelector<HTMLElement>('[data-mailto-block]');
            const link = document.querySelector<HTMLAnchorElement>('[data-mailto-link]');
            const toEl = document.querySelector<HTMLElement>('[data-mailto-to]');
            const ccEl = document.querySelector<HTMLElement>('[data-mailto-cc]');
            const subjEl = document.querySelector<HTMLElement>('[data-mailto-subject]');
            const bodyEl = document.querySelector<HTMLElement>('[data-mailto-body]');
            if (link) link.href = url;
            // Parse the mailto URL into displayable parts for the fallback.
            try {
              const afterMailto = url.replace(/^mailto:/, '');
              const [toPart, queryPart = ''] = afterMailto.split('?');
              const params = new URLSearchParams(queryPart);
              if (toEl) toEl.textContent = decodeURIComponent(toPart);
              if (ccEl) ccEl.textContent = params.get('cc') || '';
              if (subjEl) subjEl.textContent = params.get('subject') || '';
              if (bodyEl) bodyEl.textContent = params.get('body') || '';
            } catch { /* leave fallback empty if parse fails */ }
            if (block) block.hidden = false;
          }
        </script>

        <p class="thanks-back">
          <a href={localizedUrl('/', lang)}>
            ← <I18nText en="Back to campaign" zh="返回主页" lang={lang} />
          </a>
        </p>
      </div>
    </div>
  </section>
</CampaignLayout>

<style>
  .thanks-page { padding: 64px 0; }
  .thanks-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 48px 32px;
    box-shadow: var(--shadow-sm);
  }
  .thanks-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }
  h1 { font-size: 28px; margin-bottom: 12px; }
  .thanks-lede {
    font-size: 18px;
    color: var(--ink-soft);
    margin-bottom: 32px;
  }
  .thanks-next {
    border-top: 1px solid var(--line);
    padding-top: 24px;
    margin-bottom: 24px;
  }
  .thanks-next h2 {
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    margin-bottom: 12px;
    font-weight: 600;
  }
  .thanks-next ul {
    list-style: none;
    padding: 0;
  }
  .thanks-next li {
    padding-left: 24px;
    position: relative;
    margin-bottom: 12px;
    line-height: 1.6;
  }
  .thanks-next li::before {
    content: "·";
    position: absolute;
    left: 4px;
    color: var(--accent);
    font-weight: 700;
  }
  .thanks-letter-note {
    background: var(--cream);
    border-left: 3px solid var(--warm);
    padding: 16px 20px;
    border-radius: 4px;
    margin: 24px 0;
  }
  .thanks-letter-note h2 {
    font-family: var(--font-sans);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--warm);
    margin: 0 0 8px;
    font-weight: 600;
  }
  .thanks-letter-note p { margin: 0 0 12px; line-height: 1.5; }
  .thanks-letter-actions { margin: 16px 0 !important; }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 18px;
    border-radius: var(--radius-md);
    border: 2px solid transparent;
    font-family: var(--font-sans);
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
  }
  .btn--primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }
  .btn--primary:hover {
    background: var(--accent-deep);
    border-color: var(--accent-deep);
  }
  .thanks-letter-fallback {
    margin-top: 12px;
    font-size: 13px;
  }
  .thanks-letter-fallback summary {
    cursor: pointer;
    color: var(--accent);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .thanks-letter-fallback__body {
    margin-top: 8px;
    padding: 12px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 4px;
  }
  .thanks-letter-fallback__body p { margin: 0 0 6px; word-break: break-word; }
  .thanks-letter-fallback__body code {
    font-size: 12px;
    color: var(--ink-soft);
  }
  .thanks-letter-body {
    margin: 8px 0 0;
    padding: 12px;
    background: var(--cream);
    border: 1px solid var(--line);
    border-radius: 4px;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 12px;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
    max-height: 280px;
    overflow-y: auto;
  }
  .thanks-back {
    margin-top: 24px;
  }
  .thanks-back a {
    text-decoration: none;
    color: var(--accent);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
  }
  .small { font-size: 13px; }
  .muted { color: var(--muted); }
</style>
