---
import CampaignLayout from '~/layouts/CampaignLayout.astro';
import Hero from '~/components/Hero.astro';
import SignatoriesFeed from '~/components/SignatoriesFeed.astro';
import ThreeFacts from '~/components/ThreeFacts.astro';
import PersonaSelector from '~/components/PersonaSelector.astro';
import Journey from '~/components/Journey.astro';
import ActionForm from '~/components/ActionForm.astro';
import MlaScorecard from '~/components/MlaScorecard.astro';
import CoalitionSection from '~/components/CoalitionSection.astro';
import PacKitModal from '~/components/PacKitModal.astro';
import AboutSection from '~/components/AboutSection.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import I18nText from '~/components/I18nText.astro';

const lang = 'en';
---

<CampaignLayout
  lang={lang}
  title="Fund Burnaby Kids — $9.4M from BC Budget 2026 for Burnaby schools"
  description="Sign + send the pre-filled email to your MLA. Budget adopts May 27. Parent-led, non-partisan, Burnaby-only."
  noindex
>
  <Hero lang={lang} />

  <section class="recent">
    <div class="wrap-wide">
      <SignatoriesFeed lang={lang} />
    </div>
  </section>

  <ThreeFacts lang={lang} />

  <PersonaSelector lang={lang} />

  <Journey lang={lang} />

  <ActionForm lang={lang} />

  <MlaScorecard lang={lang} />

  <CoalitionSection lang={lang} />

  <AboutSection lang={lang} />

  <FaqAccordion lang={lang} />

  <PacKitModal lang={lang} />

  <section class="phase-note">
    <div class="wrap">
      <p class="kicker sans">
        <I18nText
          en="Coming in the next batches (Phase 5.6 - 5.7)"
          zh="下面要补的（Phase 5.6 - 5.7）"
          lang={lang}
        />
      </p>
      <ul>
        <li>PAC kit printable page (`/pac-kit`)</li>
        <li>Methodology page (`/methodology`) — verified-signature explainer</li>
        <li>Privacy page port from Phase 4A standalone HTML</li>
        <li>Final integration polish + Lighthouse pass</li>
      </ul>
    </div>
  </section>
</CampaignLayout>

<style>
  .recent {
    padding: 24px 0;
    background: var(--paper);
    border-top: 1px solid var(--line);
  }
  .phase-note {
    padding: 48px 0;
    background: var(--cream);
    border-top: 1px solid var(--line);
  }
  .phase-note .kicker {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--warm);
    font-weight: 600;
    margin: 0 0 12px;
  }
  .phase-note ul {
    padding-left: 20px;
    margin: 0;
    color: var(--ink-soft);
  }
  .phase-note li {
    margin-bottom: 6px;
  }
</style>
