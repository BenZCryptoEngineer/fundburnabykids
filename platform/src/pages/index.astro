---
import CampaignLayout from '~/layouts/CampaignLayout.astro';
import Hero from '~/components/Hero.astro';
import SignatoriesFeed from '~/components/SignatoriesFeed.astro';
import ThreeFacts from '~/components/ThreeFacts.astro';
import PersonaSelector from '~/components/PersonaSelector.astro';
import Journey from '~/components/Journey.astro';
import ActionForm from '~/components/ActionForm.astro';
import RidingMap from '~/components/RidingMap.astro';
import MlaScorecard from '~/components/MlaScorecard.astro';
import CoalitionSection from '~/components/CoalitionSection.astro';
import PacKitModal from '~/components/PacKitModal.astro';
import AboutSection from '~/components/AboutSection.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';

const lang = 'en';
---

<CampaignLayout
  lang={lang}
  title="Fund Burnaby Kids — $9.4M from BC Budget 2026 for Burnaby schools"
  description="Sign + send the pre-filled email to your MLA. Budget adopts May 27. Parent-led, non-partisan, Burnaby-only."
  noindex
>
  <Hero lang={lang} />

  <section class="recent">
    <div class="wrap-wide">
      <SignatoriesFeed lang={lang} />
    </div>
  </section>

  <ThreeFacts lang={lang} />

  <PersonaSelector lang={lang} />

  <Journey lang={lang} />

  <ActionForm lang={lang} />

  <RidingMap lang={lang} />

  <MlaScorecard lang={lang} />

  <CoalitionSection lang={lang} />

  <AboutSection lang={lang} />

  <FaqAccordion lang={lang} />

  <PacKitModal lang={lang} />
</CampaignLayout>

<style>
  .recent {
    padding: 24px 0;
    background: var(--paper);
    border-top: 1px solid var(--line);
  }
</style>
