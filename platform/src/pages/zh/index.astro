---
import CampaignLayout from '~/layouts/CampaignLayout.astro';
import Hero from '~/components/Hero.astro';
import SignatoriesFeed from '~/components/SignatoriesFeed.astro';
import ActionForm from '~/components/ActionForm.astro';
import I18nText from '~/components/I18nText.astro';

const lang = 'zh';
---

<CampaignLayout
  lang={lang}
  title="Fund Burnaby Kids — 为本拿比孩子争取 BC 2026 预算 940 万"
  description="签名 + 发预填邮件给你的 MLA。预算 5 月 27 日通过。家长发起，非党派，仅本拿比。"
  noindex
>
  <Hero lang={lang} />

  <section class="recent">
    <div class="wrap-wide">
      <SignatoriesFeed lang={lang} />
    </div>
  </section>

  <ActionForm lang={lang} />

  <section class="phase-note" id="why">
    <div class="wrap">
      <p class="kicker sans">
        <I18nText
          en="Coming in the next batch (Phase 5.3+)"
          zh="下一批要补的（Phase 5.3+）"
          lang={lang}
        />
      </p>
      <ul>
        <li>三大事实（BCPSEA 承认 · 前期裁员 · Contingencies Vote）</li>
        <li>persona 分层内容（家长 / PAC / Trustee）</li>
        <li>影响地图（10 项服务 × 13 个年级）</li>
        <li>MLA 跟踪表（7 位代表，状态 + 更新日期）</li>
        <li>联盟 + PAC endorsement 资料包</li>
        <li>发起人 + 关于联盟</li>
        <li>FAQ</li>
      </ul>
      <p class="muted small">
        这些数据 YAML 和 SVG 已经在 repo 里。差 Astro 组件。
      </p>
    </div>
  </section>
</CampaignLayout>

<style>
  .recent {
    padding: 24px 0;
    background: var(--paper);
    border-top: 1px solid var(--line);
  }
  .phase-note {
    padding: 48px 0;
    background: var(--cream);
  }
  .phase-note .kicker {
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--warm);
    font-weight: 600;
    margin: 0 0 12px;
  }
  .phase-note ul {
    padding-left: 20px;
    margin: 0 0 12px;
    color: var(--ink-soft);
  }
  .phase-note li {
    margin-bottom: 6px;
  }
  .small { font-size: 13px; }
  .muted { color: var(--muted); }
</style>
