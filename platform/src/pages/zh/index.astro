---
import CampaignLayout from '~/layouts/CampaignLayout.astro';
import Hero from '~/components/Hero.astro';
import SignatoriesFeed from '~/components/SignatoriesFeed.astro';
import ThreeFacts from '~/components/ThreeFacts.astro';
import PersonaSelector from '~/components/PersonaSelector.astro';
import ActionForm from '~/components/ActionForm.astro';
import FaqAccordion from '~/components/FaqAccordion.astro';
import I18nText from '~/components/I18nText.astro';

const lang = 'zh';
---

<CampaignLayout
  lang={lang}
  title="Fund Burnaby Kids — 为本拿比孩子争取 BC 2026 预算 940 万"
  description="签名 + 发预填邮件给你的 MLA。预算 5 月 27 日通过。家长发起，非党派，仅本拿比。"
  noindex
>
  <Hero lang={lang} />

  <section class="recent">
    <div class="wrap-wide">
      <SignatoriesFeed lang={lang} />
    </div>
  </section>

  <ThreeFacts lang={lang} />

  <PersonaSelector lang={lang} />

  <ActionForm lang={lang} />

  <FaqAccordion lang={lang} />

  <section class="phase-note">
    <div class="wrap">
      <p class="kicker sans">
        <I18nText
          en="Coming in the next batches (Phase 5.4 - 5.7)"
          zh="下面几批要补的（Phase 5.4 - 5.7）"
          lang={lang}
        />
      </p>
      <ul>
        <li>影响地图（10 项服务 × 13 个年级，可点击选年级）</li>
        <li>MLA 跟踪表（7 位代表，卡片式 + 最近更新时间）</li>
        <li>联盟 + PAC endorsement 资料包 modal</li>
        <li>发起人 + Burnaby Kids First 关于章节</li>
        <li>PAC 资料包打印页（/pac-kit）</li>
        <li>验证机制说明页（/methodology）</li>
        <li>隐私政策（从 Phase 4A 的独立 HTML 迁过来）</li>
      </ul>
    </div>
  </section>
</CampaignLayout>

<style>
  .recent {
    padding: 24px 0;
    background: var(--paper);
    border-top: 1px solid var(--line);
  }
  .phase-note {
    padding: 48px 0;
    background: var(--cream);
    border-top: 1px solid var(--line);
  }
  .phase-note .kicker {
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--warm);
    font-weight: 600;
    margin: 0 0 12px;
  }
  .phase-note ul {
    padding-left: 20px;
    margin: 0;
    color: var(--ink-soft);
  }
  .phase-note li {
    margin-bottom: 6px;
  }
</style>
